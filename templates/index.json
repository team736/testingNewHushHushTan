        "q1": { "type": "qa", "settings": { "question": "How do I prepare for my tan?", "answer": "<p>Exfoliate 24 hours before and arrive with clean, product-free skin.</p>" } },
        "q2": { "type": "qa", "settings": { "question": "What should I wear to my appointment?", "answer": "<p>Loose, dark, comfortable clothing. Avoid tight straps and jeans.</p>" } },
        "q3": { "type": "qa", "settings": { "question": "How long does a spray tan last?", "answer": "<p>With proper aftercare, your Custom Glow typically lasts 7–10 days.</p>" } },
        "q4": { "type": "qa", "settings": { "question": "When can I shower?", "answer": "<p>Wait 8–12 hours for a Custom Glow. For Rapid Glow, follow your technician's timing.</p>" } },
        "q5": { "type": "qa", "settings": { "question": "How do memberships work?", "answer": "<p>Memberships have a 3-month minimum and require 30 days written notice to cancel. Tans do not roll over month to month. You can freeze your membership for a $10 monthly fee.</p>" } }
