      "blocks": {
        "q1": {
          "type": "qa",
          "settings": {
            "question": "How long will my spray tan last?",
            "answer": "<p>Airbrush tans can last up to ten days depending on skin preparation and aftercare. Long hot baths or showers and exposure to chlorine will speed up the fading process. Using tan extenders or mixing body lotion with self-tanner daily can extend the tan by 50–75%.</p>"
          }
        },
        "q2": {
          "type": "qa",
          "settings": {
            "question": "Will I look orange?",
            "answer": "<p>No. We use violet-based solutions customized to your unique skin tone and undertones for a natural, Mediterranean bronze glow — never orange.</p>"
          }
        },
        "q3": {
          "type": "qa",
          "settings": {
            "question": "How soon can I shower after my session?",
            "answer": "<p>For Rapid Glow, you can rinse in 2–4 hours. For Custom Glow, we recommend waiting 8–12 hours for the color to fully develop.</p>"
          }
        },
        "q4": {
          "type": "qa",
          "settings": {
            "question": "Should I shave before or after?",
            "answer": "<p>Always shave before your appointment, ideally 24 hours prior. Shaving after your tan acts as a mechanical exfoliant and will strip color faster.</p>"
          }
        },
        "q5": {
          "type": "qa",
          "settings": {
            "question": "Can I exercise with my spray tan?",
            "answer": "<p>Avoid sweating or excessive friction until after your first post-tan shower. Once developed, moderate exercise is fine, but heavy sweating may cause premature fading.</p>"
          }
        }
      },
