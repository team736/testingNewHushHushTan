    "services_faq": {
      "type": "glow-moments-faq",
      "blocks": {
        "qa_svc_01": {
          "type": "qa",
          "settings": {
            "question": "Which service should I book for my first appointment?",
            "answer": "<p>Most first-timers start with Custom Glow or Clear Glow. Custom Glow is personalized to your skin tone and undertones. Clear Glow uses a clear solution that develops into a natural-looking finish without an immediate cosmetic bronzer.</p>"
          }
        },
        "qa_svc_02": {
          "type": "qa",
          "settings": {
            "question": "What is the difference between Custom Glow and Clear Glow?",
            "answer": "<p>Custom Glow is mixed for your individual skin tone, undertones, and desired result. Clear Glow is a clear solution designed for a natural-looking finish without an immediate cosmetic bronzer—popular with first-timers who prefer a subtler rinse-day look.</p>"
          }
        },
        "qa_svc_03": {
          "type": "qa",
          "settings": {
            "question": "How quickly can I rinse after a Rapid Glow?",
            "answer": "<p>Rapid Glow is designed to rinse in approximately two to four hours.</p>"
          }
        },
        "qa_svc_04": {
          "type": "qa",
          "settings": {
            "question": "Are prices different at each location?",
            "answer": "<p>Yes. Austin and Houston follow one pricing structure, while Dallas prices differ on core services, memberships, partials, packages, add-ons, group experiences, and Birthday Glow. Use the city selector on this page to view accurate pricing for your studio.</p>"
          }
        },
        "qa_svc_05": {
          "type": "qa",
          "settings": {
            "question": "How do Glow Pass and Glow Club work?",
            "answer": "<p>Glow Pass includes discounts on tans and products. Glow Club includes one complimentary tan per month plus additional discounts. See membership details above for the benefits at your selected studio.</p>"
          }
        },
        "qa_svc_06": {
          "type": "qa",
          "settings": {
            "question": "Can Rapid Glow be used with a membership or package?",
            "answer": "<p>Rapid Glow is not included as the complimentary Glow Club tan or in standard package pricing. An upgrade may be available—ask your studio when booking.</p>"
          }
        },
        "qa_svc_07": {
          "type": "qa",
          "settings": {
            "question": "How long are tan packages valid?",
            "answer": "<p>Packages are valid for six months from purchase and can be mixed and matched across eligible core services.</p>"
          }
        },
        "qa_svc_08": {
          "type": "qa",
          "settings": {
            "question": "Is Austin Mobile Tanning available in Houston or Dallas?",
            "answer": "<p>No. Austin Mobile Tanning is available for Austin only and appears on this page when Austin is selected.</p>"
          }
        },
        "qa_svc_09": {
          "type": "qa",
          "settings": {
            "question": "How many guests are included with Tanning & Mimosas?",
            "answer": "<p>Tanning & Mimosas includes five Custom Glow tans, studio access for the group, and complimentary champagne or mimosas. Additional guests can be added where available—see the group price on this page for your city.</p>"
          }
        },
        "qa_svc_10": {
          "type": "qa",
          "settings": {
            "question": "How should I prepare for my appointment?",
            "answer": "<p>Exfoliate and shave about 24 hours prior, arrive with clean bare skin, avoid lotions/oils, and wear loose dark clothing. See our Tanning Tips page for full prep and aftercare guidance.</p>"
          }
        }
      },
