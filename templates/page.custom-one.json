      "settings": {
        "hero_eyebrow": "Our Story",
        "hero_heading": "A Healthier Glow, Made Personal",
        "hero_text": "Hush Hush Tan was created around a simple belief: a spray tan should complement the person wearing it. From our Austin beginnings to studios in Dallas and Houston, every Hush Hush Tan experience is built around personalized color, attentive service, and natural-looking results.",
        "hero_button_1_label": "Discover Our Story",
        "hero_button_1_link": "#founder",
        "hero_button_2_label": "Choose a Location",
        "hero_button_2_link": "/pages/locations",
        "hero_image": "shopify://shop_images/74d054fb5ba06d-FW507310518.webp",
        "hero_image_alt": "Personalized Hush Hush Tan glow experience",
        "founder_eyebrow": "Founded in Texas",
        "founder_heading": "Created by Izabel Wicker",
        "founder_text_1": "Hush Hush Tan was founded in Austin by Izabel Wicker with a vision for a more personalized approach to sunless tanning. Instead of treating every client the same, the Hush Hush Tan method focuses on skin tone, undertones, desired depth of color, and the occasion behind each appointment.",
        "founder_text_2": "Izabel wanted clients to leave feeling confident in a glow that looked like their own skin — never orange, never one-size-fits-all. That focus on customization shaped both the in-studio experience and the way color is selected for each person.",
        "founder_text_3": "What began as one Texas studio has grown into three locations serving Austin, Dallas, and Houston while maintaining the same attention to detail and welcoming client experience.",
        "founder_image": "shopify://shop_images/IMG_0945.jpg",
        "founder_image_alt": "Hush Hush Tan team",
        "problem_eyebrow": "The Problem She Set Out to Solve",
        "problem_heading": "Beyond One-Shade-Fits-All",
        "problem_text_1": "Many spray-tan experiences treat every client with the same approach. Izabel built Hush Hush Tan around consultation, color matching, and application that respects undertones and lifestyle — so the result looks natural in daylight and photographs.",
        "problem_text_2": "That philosophy continues in every studio: listen first, customize the formula and depth, then apply with care.",
        "problem_image": "shopify://shop_images/IMG_0032.jpg",
        "problem_image_alt": "Natural-looking custom spray tan finish",
        "formula_eyebrow": "The Formula Approach",
        "formula_heading": "Color Mixed Around You",
        "formula_text": "Hush Hush Tan artists select and adjust color around the individual — skin tone, undertones, and the look you want for your occasion. The goal is a believable, personalized finish rather than a single default shade.",
        "difference_eyebrow": "The Hush Hush Difference",
        "difference_heading": "Mixed for Your Undertones",
        "difference_text": "Every appointment begins with a conversation. The artist considers the client’s complexion, undertones, schedule, and desired result before selecting or mixing the appropriate color. The goal is not a one-shade-fits-all tan, but a glow that feels believable and individual.",
        "values_eyebrow": "Values",
        "values_heading": "What Guides Every Glow",
        "press_eyebrow": "Recognized Beyond Texas",
        "press_heading": "A Local Brand with National Recognition",
        "press_text": "Hush Hush Tan’s personalized approach has been recognized by leading fashion, lifestyle, and Texas publications.",
        "press_button_label": "Read Press",
        "press_button_link": "/pages/press",
