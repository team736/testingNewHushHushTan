    "faq": {
      "type": "glow-moments-faq",
      "blocks": {
        "qa1": {
          "type": "qa",
          "settings": {
            "question": "Where is the Austin studio located?",
            "answer": "<p>Our flagship salon is at 1211 West 6th St, Suite #400, Austin, TX 78703 \u2014 nestled in Clarksville just off West 6th Street.</p>"
          }
        },
        "qa2": {
          "type": "qa",
          "settings": {
            "question": "Is parking available in Austin?",
            "answer": "<p>Yes \u2014 street and lot parking are available around the West 6th / Clarksville studio. Arrive a few minutes early so you can park comfortably before your appointment.</p>"
          }
        },
        "qa3": {
          "type": "qa",
          "settings": {
            "question": "What should first-time Austin clients book?",
            "answer": "<p>Start with the Custom Glow. Your artist will consult with you, understand your desired result, and create a custom color formulation matched to your skin tone and undertones.</p>"
          }
        },
        "qa4": {
          "type": "qa",
          "settings": {
            "question": "What should I wear after my appointment?",
            "answer": "<p>Loose, dark clothing and open-toed sandals work best. Disposables are provided on request.</p>"
          }
        },
        "qa5": {
          "type": "qa",
          "settings": {
            "question": "How is my shade customized?",
            "answer": "<p>Every airbrush tan is personally matched to your skin tone, undertones, and desired depth of color \u2014 never a one-size-fits-all formula.</p>"
          }
        },
        "qa6": {
          "type": "qa",
          "settings": {
            "question": "How long does a Custom Glow take to develop?",
            "answer": "<p>Custom Glow typically develops for about 8 hours before rinsing. Rapid Glow is designed to rinse in approximately 2\u20134 hours.</p>"
          }
        },
        "qa7": {
          "type": "qa",
          "settings": {
            "question": "How long will my spray tan last?",
            "answer": "<p>With proper prep and aftercare, most clients enjoy up to about 10 days of even color. Extender products and daily moisturizing can help your glow last longer.</p>"
          }
        },
        "qa8": {
          "type": "qa",
          "settings": {
            "question": "How should I prepare for my Austin appointment?",
            "answer": "<p>Shower, shave, and exfoliate before your appointment. Don't apply moisturizers, makeup, or deodorant afterward. Complete workouts and spa treatments before your tan.</p>"
          }
        }
      },
