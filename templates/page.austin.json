        "r1": {
          "type": "review",
          "settings": {
            "quote": "Hush hush is the only place I will go in Austin! I've had several tans done here and I always love the results. They are accommodating, honest and always make you feel comfortable!",
            "author": "Audrey Kuhl",
            "location": "Austin, TX"
          }
        },
        "r2": {
          "type": "review",
          "settings": {
            "quote": "My experience here was amazing! Everyone was so nice from the start, from Kathy and Chloe at the front to Tarin who did my spray tan! Highly recommend, I will definitely be coming back.",
            "author": "Samantha Robinson",
            "location": "Austin, TX"
          }
        },
        "r3": {
          "type": "review",
          "settings": {
            "quote": "This place is THE best! My tans always come out incredibly even (yes, including hands + feet), have the perfect color/undertone every time, and fade nicely. Every artist has made me extremely comfortable.",
            "author": "Hali Crawford",
            "location": "Austin, TX"
          }
        },
        "r4": {
          "type": "review",
          "settings": {
            "quote": "Greeted by Chloe, who was incredibly kind and helpful during my first tan at Hush Hush. I was sprayed by Tarin, who had amazing attention to detail and made the entire experience feel comfortable and never awkward.",
            "author": "Emma Kenny",
            "location": "Austin, TX"
          }
        }
