    "faq": {
      "type": "glow-moments-faq",
      "blocks": {
        "qa1": {
          "type": "qa",
          "settings": {
            "question": "Where is the Houston studio located?",
            "answer": "<p>Visit us at M-K-T Heights: 600 N Shepherd Dr, Ste. 128, Houston, TX 77007.</p>"
          }
        },
        "qa2": {
          "type": "qa",
          "settings": {
            "question": "Is parking available in Houston?",
            "answer": "<p>M-K-T Heights offers on-site parking for studio guests. Arrive a few minutes early so you can park and check in comfortably.</p>"
          }
        },
        "qa3": {
          "type": "qa",
          "settings": {
            "question": "What should first-time Houston clients book?",
            "answer": "<p>Start with the Custom Glow. Your artist will consult with you and create a custom color formulation designed around your skin tone, undertones, and ideal glow.</p>"
          }
        },
        "qa4": {
          "type": "qa",
          "settings": {
            "question": "What should I wear after my appointment?",
            "answer": "<p>Loose, dark clothing and open-toed sandals work best. Disposables are provided on request.</p>"
          }
        },
        "qa5": {
          "type": "qa",
          "settings": {
            "question": "How is my shade customized?",
            "answer": "<p>Every airbrush tan is personally matched to your skin tone, undertones, and desired depth of color for a natural-looking finish.</p>"
          }
        },
        "qa6": {
          "type": "qa",
          "settings": {
            "question": "How long does a Custom Glow take to develop?",
            "answer": "<p>Custom Glow typically develops for about 8 hours before rinsing. Rapid Glow is designed to rinse in approximately 2\u20134 hours.</p>"
          }
        },
        "qa7": {
          "type": "qa",
          "settings": {
            "question": "How long will my spray tan last?",
            "answer": "<p>With proper prep and aftercare, most clients enjoy up to about 10 days of even color. Extender products and daily moisturizing can help your glow last longer.</p>"
          }
        },
        "qa8": {
          "type": "qa",
          "settings": {
            "question": "How should I prepare for my Houston appointment?",
            "answer": "<p>Shower, shave, and exfoliate before your appointment. Don't apply moisturizers, makeup, or deodorant afterward. Complete workouts and spa treatments before your tan.</p>"
          }
        }
