<section class="section">
  <div class="container">
    <div class="section-head">
      {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}<p class="section-head__sub">{{ section.settings.subheading }}</p>{%- endif -%}
    </div>
    <div class="aftercare-grid">
      <a href="{{ section.settings.feature_cta_url | default: '/collections/tanning-products' }}" class="aftercare-feature">
        {%- if section.settings.feature_image != blank -%}
          <img src="{{ section.settings.feature_image | image_url: width: 1200 }}" alt="{{ section.settings.feature_title | default: 'Glow With Confidence' | escape }}" width="1200" height="1500" loading="lazy">
        {%- else -%}
          <img src="{{ 'hht-studio-glow.png' | asset_url }}" alt="{{ section.settings.feature_title | default: 'Glow With Confidence' | escape }}" width="1200" height="1500" loading="lazy">
        {%- endif -%}
        <div class="aftercare-feature__overlay">
          <h3>{{ section.settings.feature_title | default: 'Glow With Confidence' }}</h3>
          <p>{{ section.settings.feature_text | default: 'Prep, protect, and extend your custom glow.' }}</p>
          <span class="aftercare-feature__btn">{{ section.settings.feature_cta_text | default: 'Explore More' }}</span>
        </div>
      </a>

      <div class="aftercare-products">
        {%- assign products_to_show = section.settings.products_to_show | default: 6 -%}
        {%- if section.settings.collection != blank -%}
          {%- assign shown = 0 -%}
          {%- for product in section.settings.collection.products -%}
            {%- if shown < products_to_show -%}
              <a href="{{ product.url }}" class="aftercare-product">
                <div class="aftercare-product__media">
                  {%- if product.featured_image -%}
                    <img
                      src="{{ product.featured_image | image_url: width: 640 }}"
                      alt="{{ product.featured_image.alt | default: product.title | escape }}"
                      width="640"
                      height="640"
                      loading="lazy">
                  {%- endif -%}
                </div>
                <h3>{{ product.title }}</h3>
                <p>{{ product.price | money }}</p>
              </a>
              {%- assign shown = shown | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
        {%- elsif collections.tanning-products.products.size > 0 -%}
          {%- for product in collections.tanning-products.products limit: 6 -%}
            <a href="{{ product.url }}" class="aftercare-product">
              <div class="aftercare-product__media">
                {%- if product.featured_image -%}
                  <img
                    src="{{ product.featured_image | image_url: width: 640 }}"
                    alt="{{ product.featured_image.alt | default: product.title | escape }}"
                    width="640"
                    height="640"
                    loading="lazy">
                {%- endif -%}
              </div>
              <h3>{{ product.title }}</h3>
              <p>{{ product.price | money }}</p>
            </a>
          {%- endfor -%}
        {%- elsif collections.all.products.size > 0 -%}
          {%- for product in collections.all.products limit: 6 -%}
            <a href="{{ product.url }}" class="aftercare-product">
              <div class="aftercare-product__media">
                {%- if product.featured_image -%}
                  <img
                    src="{{ product.featured_image | image_url: width: 640 }}"
                    alt="{{ product.featured_image.alt | default: product.title | escape }}"
                    width="640"
                    height="640"
                    loading="lazy">
                {%- endif -%}
              </div>
              <h3>{{ product.title }}</h3>
              <p>{{ product.price | money }}</p>
            </a>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
    {%- if section.settings.cta_text != blank -%}
      <div class="text-center" style="margin-top: 48px;">
        <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="btn btn--outline">{{ section.settings.cta_text }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our Featured Products" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get the skin you want to feel" },
    { "type": "text", "id": "subheading", "label": "Subheading" },
    { "type": "image_picker", "id": "feature_image", "label": "Feature image (left)" },
    { "type": "text", "id": "feature_title", "label": "Feature title", "default": "Glow With Confidence" },
    { "type": "text", "id": "feature_text", "label": "Feature text", "default": "Prep, protect, and extend your custom glow." },
    { "type": "text", "id": "feature_cta_text", "label": "Feature button text", "default": "Explore More" },
    { "type": "url", "id": "feature_cta_url", "label": "Feature button URL" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 2, "max": 12, "step": 1, "default": 6 },
    { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Shop all products" },
    { "type": "url", "id": "cta_url", "label": "CTA URL" }
  ],
  "presets": [{ "name": "Featured products" }]
}
{% endschema %}
