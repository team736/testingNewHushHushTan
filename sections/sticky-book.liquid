{%- if section.settings.enabled -%}
  <div class="hht-sticky-book" data-sticky-book aria-hidden="true">
    <a
      href="{{ section.settings.url | default: 'https://go.booker.com/location/hushhushtan/service-menu' }}"
      class="hht-sticky-book__btn"
      target="_blank"
      rel="noopener">
      <span class="hht-sticky-book__spark" aria-hidden="true">
        <svg viewBox="0 0 20 20" width="15" height="15" fill="currentColor"><path d="M10 1l1.4 4.3L15.7 6 12 8.6l1.5 4.4L10 10.3 6.5 13 8 8.6 4.3 6l4.3-.7z"/></svg>
      </span>
      {{ section.settings.text | default: 'Book Now' }}
    </a>
  </div>

  <script>
    (function () {
      var el = document.querySelector('[data-sticky-book]');
      if (!el) return;
      var threshold = {{ section.settings.scroll_threshold | default: 500 }};
      function onScroll() {
        if (window.pageYOffset > threshold) {
          el.classList.add('is-visible');
          el.setAttribute('aria-hidden', 'false');
        } else {
          el.classList.remove('is-visible');
          el.setAttribute('aria-hidden', 'true');
        }
      }
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Sticky Book Now",
  "settings": [
    { "type": "checkbox", "id": "enabled", "label": "Show sticky Book Now button", "default": true },
    { "type": "text", "id": "text", "label": "Button text", "default": "Book Now" },
    { "type": "url", "id": "url", "label": "Booking URL" },
    { "type": "range", "id": "scroll_threshold", "label": "Show after scrolling", "min": 100, "max": 1200, "step": 50, "default": 500, "unit": "px" }
  ],
  "presets": [{ "name": "Sticky Book Now" }]
}
{% endschema %}
