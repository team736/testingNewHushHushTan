<section class="section section--tight">
  <div class="container">
    <div class="map-feature">
      <div>
        {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        <h2>{{ section.settings.heading }}</h2>
        <p class="lead">{{ section.settings.text }}</p>
        <div class="flex" style="margin-top: 22px;">
          <a href="{{ settings.book_austin_url }}" class="btn btn--small">Book Austin</a>
          <a href="{{ settings.book_dallas_url }}" class="btn btn--small btn--outline-lav">Book Dallas</a>
          <a href="{{ settings.book_houston_url }}" class="btn btn--small btn--outline-lav">Book Houston</a>
        </div>
      </div>
      <div class="map-feature__media">
        {%- if section.settings.image != blank -%}
          <img src="{{ section.settings.image | image_url: width: 1200 }}" alt="{{ section.settings.heading | escape }}" width="1200" height="760" loading="lazy">
        {%- else -%}
          <img src="{{ 'hht-glow-editorial.jpg' | asset_url }}" alt="{{ section.settings.heading | escape }}" width="1200" height="760" loading="lazy">
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Location map feature",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Plan your visit" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Find your Hush Hush studio" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Choose Austin, Dallas, or Houston and book directly through Booker." },
    { "type": "image_picker", "id": "image", "label": "Map or studio image" }
  ],
  "presets": [{ "name": "Location map feature" }]
}
{% endschema %}
