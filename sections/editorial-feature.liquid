<section class="section">
  <div class="container">
    <div class="section-head">
      {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}<p class="section-head__sub">{{ section.settings.subheading }}</p>{%- endif -%}
    </div>
    <div class="editorial">
      <a href="{{ section.settings.image_url | default: '#' }}" class="editorial__image">
        {%- if section.settings.image != blank -%}
          <img src="{{ section.settings.image | image_url: width: 1400 }}" alt="{{ section.settings.image_heading | escape }}" width="1400" height="1400" loading="lazy">
        {%- else -%}
          <img src="{{ 'hht-studio-glow.png' | asset_url }}" alt="{{ section.settings.image_heading | escape }}" width="1400" height="1400" loading="lazy">
        {%- endif -%}
        <div class="editorial__image-copy">
          {%- if section.settings.image_heading != blank -%}<h3>{{ section.settings.image_heading }}</h3>{%- endif -%}
          {%- if section.settings.image_cta_text != blank -%}
            <span class="btn btn--outline btn--small" style="background:#fff;color:var(--text);border-color:#fff;">{{ section.settings.image_cta_text }}</span>
          {%- endif -%}
        </div>
      </a>
      <div class="editorial__products">
        {%- assign products_to_show = section.settings.products_to_show | default: 4 -%}
        {%- if section.settings.collection != blank -%}
          {%- assign shown = 0 -%}
          {%- for product in section.settings.collection.products -%}
            {%- if shown < products_to_show -%}
              {% render 'product-card', product: product %}
              {%- assign shown = shown | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
        {%- elsif collections.tanning-products.products.size > 0 -%}
          {%- for product in collections.tanning-products.products limit: 4 -%}
            {% render 'product-card', product: product %}
          {%- endfor -%}
        {%- elsif collections.all.products.size > 0 -%}
          {%- for product in collections.all.products limit: 4 -%}
            {% render 'product-card', product: product %}
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Editorial feature",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Customer favorites" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Customer favorite glow essentials" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Made using clean, non-toxic ingredients. Designed for everyone." },
    { "type": "image_picker", "id": "image", "label": "Large image" },
    { "type": "text", "id": "image_heading", "label": "Image overlay heading", "default": "Empower Yourself" },
    { "type": "text", "id": "image_cta_text", "label": "Image CTA text", "default": "Explore More" },
    { "type": "url", "id": "image_url", "label": "Image link" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 2, "max": 6, "step": 1, "default": 4 }
  ],
  "presets": [{ "name": "Editorial feature" }]
}
{% endschema %}
