          "pkg_per_session": "35", "pkg_glow_getter": "175", "pkg_ultimate": "350", "pkg_elite": "525",
          "svc_clear": "40", "svc_custom": "40", "svc_gold": "45", "svc_brazilian": "50", "svc_rapid": "55", "svc_bbtl": "55", "svc_birthday": "34",
          "svc_face": "5", "svc_partial": "10", "svc_upper_lower": "20",
          "group_price": "50", "mobile_price": "75"
        }
      },
      {
        "type": "tab",
        "settings": {
