{%- assign tab_blocks = section.blocks | where: 'type', 'tab' -%}
{%- assign preview = section.settings.homepage_preview -%}

<section class="hht-pricing-ecosystem" data-pricing-ecosystem id="pricing-{{ section.id }}">
  <div class="hht-pricing-shell">
    {%- if tab_blocks.size > 0 -%}
      <div class="hht-pricing-location-wrap">
        {%- if section.settings.location_label != blank -%}
          <p class="hht-location-label">{{ section.settings.location_label }}</p>
        {%- endif -%}
        <div class="hht-location-tabs" role="tablist" aria-label="Studio location">
          {%- for tab in tab_blocks -%}
            <button
              type="button"
              class="hht-location-tab{% if forloop.first %} active{% endif %}"
              role="tab"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              data-location-tab="{{ forloop.index0 }}"
              id="loc-tab-{{ section.id }}-{{ tab.id }}">
              {{ tab.settings.label }}
            </button>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    <div class="hht-pricing-heading">
      <h2>
        {{ section.settings.heading_before | default: 'Glow More,' }}
        <em>{{ section.settings.heading_emphasis | default: 'Save More' }}</em>
      </h2>
      {%- if section.settings.subheading != blank -%}
        <p>{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    {%- for tab in tab_blocks -%}
      <div
        class="hht-location-panel{% if forloop.first %} is-active{% endif %}"
        data-location-panel="{{ forloop.index0 }}"
        role="tabpanel"
        id="loc-panel-{{ section.id }}-{{ tab.id }}"
        aria-labelledby="loc-tab-{{ section.id }}-{{ tab.id }}"
        {% unless forloop.first %}hidden{% endunless %}
        {{ tab.shopify_attributes }}>
        {% render 'pricing-location-panel', tab: tab, preview: preview %}
      </div>
    {%- endfor -%}

    {%- if preview and section.settings.cta_text != blank -%}
      <div class="hht-pricing-cta">
        {%- if section.settings.cta_eyebrow != blank -%}
          <span>{{ section.settings.cta_eyebrow }}</span>
        {%- endif -%}
        <h3>
          {{ section.settings.cta_heading_before }}
          <em>{{ section.settings.cta_heading_emphasis }}</em>
        </h3>
        {%- if section.settings.cta_subtext != blank -%}
          <p>{{ section.settings.cta_subtext }}</p>
        {%- endif -%}
        <div class="hht-cta-actions">
          <a href="{{ section.settings.cta_url | default: '/pages/memberships' }}" class="hht-primary-cta">{{ section.settings.cta_text }}</a>
          {%- if section.settings.cta_secondary_text != blank -%}
            <a href="{{ section.settings.cta_secondary_url | default: '/pages/locations' }}" class="hht-secondary-cta">{{ section.settings.cta_secondary_text }}</a>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

