        { "type": "text", "id": "svc_custom",    "label": "Custom Glow", "default": "40" },
        { "type": "text", "id": "svc_gold",      "label": "Gold Glow", "default": "45" },
        { "type": "text", "id": "svc_brazilian", "label": "Brazilian Glow", "default": "50" },
        { "type": "text", "id": "svc_rapid",     "label": "Rapid Glow", "default": "55" },
        { "type": "text", "id": "svc_bbtl",      "label": "Bye Bye Tan Line", "default": "55" },
        { "type": "text", "id": "svc_birthday",  "label": "Happy Birthday Glow", "default": "34" },
        { "type": "header", "content": "Partial body ($)" },
        { "type": "text", "id": "svc_face",        "label": "Face", "default": "5" },
        { "type": "text", "id": "svc_partial",     "label": "Partial Upper or Lower", "default": "10" },
        { "type": "text", "id": "svc_upper_lower", "label": "Upper or Lower", "default": "20" },
        { "type": "header", "content": "Group / Mobile ($/person)" },
        { "type": "text", "id": "group_price",  "label": "In-Store Group", "default": "50" },
        { "type": "text", "id": "mobile_price", "label": "Mobile (leave blank to hide)", "default": "75" },
        { "type": "header", "content": "Additional service (optional)" },
        { "type": "text", "id": "extra_service_name",  "label": "Name (e.g. Teeth Whitening)" },
        { "type": "text", "id": "extra_service_price", "label": "Price" }
      ]
    }
  ],
  "presets": [{
    "name": "Pricing tabs",
    "blocks": [
      {
        "type": "tab",
        "settings": {
          "label": "Austin",
          "book_url": "https://go.booker.com/location/hushhushtan/service-menu",
