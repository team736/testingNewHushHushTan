<div class="container section">
  <header class="text-center" style="margin-bottom: 32px;"><h1>My account</h1><p class="muted">{{ customer.email }}</p></header>
  <div class="grid grid--2">
    <div>
      <h3>Recent orders</h3>
      {%- if customer.orders.size > 0 -%}
        <ul style="list-style: none; padding: 0;">
          {%- for order in customer.orders limit: 10 -%}
            <li style="padding: 10px 0; border-bottom: 1px solid var(--line);">
              <a href="{{ order.customer_url }}">{{ order.name }}</a> · {{ order.created_at | date: '%b %d, %Y' }} · {{ order.total_price | money }} · {{ order.financial_status_label }}
            </li>
          {%- endfor -%}
        </ul>
      {%- else -%}
        <p class="muted">You haven't placed any orders yet.</p>
      {%- endif -%}
    </div>
    <div>
      <h3>Account details</h3>
      <p>{{ customer.default_address.first_name }} {{ customer.default_address.last_name }}<br>{{ customer.default_address.address1 }}<br>{{ customer.default_address.city }}, {{ customer.default_address.province }} {{ customer.default_address.zip }}</p>
      <a href="{{ routes.account_addresses_url }}" class="btn btn--outline btn--small">View addresses</a>
      <a href="{{ routes.account_logout_url }}" class="btn btn--ghost btn--small">Log out</a>
    </div>
  </div>
</div>
{% schema %}{ "name": "Account", "settings": [] }{% endschema %}
