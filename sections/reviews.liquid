{%- liquid
  assign star = '<svg class="hht-review-star" viewBox="0 0 20 20" width="16" height="16" aria-hidden="true" focusable="false"><path d="M10 1.6l2.47 5.01 5.53.8-4 3.9.94 5.5L10 14.2l-4.94 2.6.94-5.5-4-3.9 5.53-.8z"/></svg>'
  assign compact = false
  if section.settings.layout == 'compact'
    assign compact = true
  endif
-%}

<section class="section{% if compact %} section-compact{% endif %} section-lavender-soft hht-reviews{% if compact %} hht-reviews--compact{% endif %}" aria-label="{{ section.settings.heading | escape }}">
  <div class="container container--home">
    <div class="hht-reviews__head">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}

      <div class="hht-reviews__trust">
        <span class="hht-reviews__stars" aria-hidden="true">
          {{ star }}{{ star }}{{ star }}{{ star }}{{ star }}
        </span>
        {%- if section.settings.heading != blank -%}
          <h2 class="hht-reviews__title">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="hht-reviews__sub">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="hht-reviews__grid">
        {%- for block in section.blocks -%}
          <article class="hht-reviews__card" {{ block.shopify_attributes }}>
            <span class="hht-reviews__card-stars" aria-label="5 out of 5 stars">
              {{ star }}{{ star }}{{ star }}{{ star }}{{ star }}
            </span>
            {%- if block.settings.quote != blank -%}
              <p class="hht-reviews__quote">{{ block.settings.quote }}</p>
            {%- endif -%}
            <div class="hht-reviews__meta">
              {%- if block.settings.author != blank -%}
                <span class="hht-reviews__author">{{ block.settings.author }}</span>
              {%- endif -%}
              {%- if block.settings.location != blank -%}
                <span class="hht-reviews__loc">{{ block.settings.location }}</span>
              {%- endif -%}
            </div>
            <span class="hht-reviews__source" aria-hidden="true">Google review</span>
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.cta_text != blank and section.settings.cta_url != blank -%}
      <div class="hht-reviews__cta">
        <a href="{{ section.settings.cta_url }}" class="btn btn--lavender btn--pill"{% if section.settings.cta_url contains '://' %} target="_blank" rel="noopener"{% endif %}>{{ section.settings.cta_text }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Google reviews",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Loved By Texas" },
    { "type": "text", "id": "heading", "label": "Trust headline", "default": "3,000+ Five-Star Google Reviews" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Real glows, real reviews — the most-loved custom spray tan in Austin, Dallas & Houston." },
    { "type": "select", "id": "layout", "label": "Layout", "default": "full",
      "options": [
        { "value": "full", "label": "Full (homepage)" },
        { "value": "compact", "label": "Compact (service page)" }
      ]
    },
    { "type": "text", "id": "cta_text", "label": "Button text", "default": "Read Our Reviews" },
    { "type": "url", "id": "cta_url", "label": "Button URL" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review card",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Review text", "info": "Replace with a real Google review before publishing." },
        { "type": "text", "id": "author", "label": "Reviewer name" },
        { "type": "text", "id": "location", "label": "Location / date" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [{
    "name": "Google reviews",
    "blocks": [
      { "type": "review", "settings": { "quote": "The most natural spray tan I've ever had — perfectly color-matched and never orange. The studio feels like a luxury spa.", "author": "Ashley R.", "location": "Austin, TX" } },
      { "type": "review", "settings": { "quote": "I've been coming for years. The team is incredible and my glow always looks flawless for events. Highly recommend the Custom Glow.", "author": "Megan T.", "location": "Dallas, TX" } },
      { "type": "review", "settings": { "quote": "Booked before my wedding and I could not have been happier. Even, streak-free, and it lasted beautifully. Worth every penny.", "author": "Priya S.", "location": "Houston, TX" } }
    ]
  }]
}
{% endschema %}
