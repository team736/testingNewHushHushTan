{%- liquid
  assign star = '<svg class="hht-review-star" viewBox="0 0 20 20" width="15" height="15" aria-hidden="true" focusable="false"><path d="M10 1.6l2.47 5.01 5.53.8-4 3.9.94 5.5L10 14.2l-4.94 2.6.94-5.5-4-3.9 5.53-.8z"/></svg>'
  assign gicon = '<svg viewBox="0 0 24 24" width="17" height="17" aria-hidden="true"><path fill="#4285F4" d="M22.5 12.2c0-.68-.06-1.36-.18-2.02H12v3.83h5.92a5.06 5.06 0 0 1-2.2 3.32v2.75h3.56c2.08-1.92 3.22-4.75 3.22-7.88z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.56-2.75c-.99.66-2.26 1.05-3.72 1.05-2.86 0-5.28-1.93-6.15-4.53H2.18v2.84A11 11 0 0 0 12 23z"/><path fill="#FBBC05" d="M5.85 14.11a6.6 6.6 0 0 1 0-4.22V7.05H2.18a11 11 0 0 0 0 9.9l3.67-2.84z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.2 1.64l3.15-3.15A11 11 0 0 0 2.18 7.05l3.67 2.84C6.72 7.3 9.14 5.38 12 5.38z"/></svg>'
  assign compact = false
  if section.settings.layout == 'compact'
    assign compact = true
  endif
-%}

<section class="section{% if compact %} section-compact{% endif %} section-lavender-soft hht-reviews{% if compact %} hht-reviews--compact{% endif %}" aria-label="{{ section.settings.heading | escape }}">
  <div class="container container--home">
    <div class="hht-reviews__head">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <div class="hht-reviews__trust">
        <span class="hht-reviews__stars" aria-hidden="true">{{ star }}{{ star }}{{ star }}{{ star }}{{ star }}</span>
        {%- if section.settings.heading != blank -%}<h2 class="hht-reviews__title">{{ section.settings.heading }}</h2>{%- endif -%}
        {%- if section.settings.subheading != blank -%}<p class="hht-reviews__sub">{{ section.settings.subheading }}</p>{%- endif -%}
      </div>
    </div>

    {%- if compact and section.blocks.size > 0 -%}
      <div class="hht-reviews__grid">
        {%- for block in section.blocks -%}
          <article class="hht-reviews__card" {{ block.shopify_attributes }}>
            <span class="hht-reviews__card-stars" aria-label="5 out of 5 stars">{{ star }}{{ star }}{{ star }}{{ star }}{{ star }}</span>
            {%- if block.settings.quote != blank -%}<p class="hht-reviews__quote">{{ block.settings.quote }}</p>{%- endif -%}
            <div class="hht-reviews__meta">
              {%- if block.settings.author != blank -%}<span class="hht-reviews__author">{{ block.settings.author }}</span>{%- endif -%}
              {%- if block.settings.location != blank -%}<span class="hht-reviews__loc">{{ block.settings.location }}</span>{%- endif -%}
            </div>
            <span class="hht-reviews__source" aria-hidden="true">Google review</span>
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.cta_text != blank and section.settings.cta_url != blank and compact -%}
      <div class="hht-reviews__cta">
        <a href="{{ section.settings.cta_url }}" class="btn btn--lavender btn--pill"{% if section.settings.cta_url contains '://' %} target="_blank" rel="noopener"{% endif %}>{{ section.settings.cta_text }}</a>
      </div>
    {%- endif -%}
  </div>

  {%- unless compact -%}
    {%- if section.blocks.size > 0 -%}
      <div class="hht-reviews__marquee" data-hht-reviews style="--rev-speed: {{ section.settings.speed | default: 50 }}s;">
        <div class="hht-reviews__track">
          {%- for i in (1..2) -%}
            <div class="hht-reviews__group"{% if i == 2 %} aria-hidden="true"{% endif %}>
              {%- for block in section.blocks -%}
                {%- assign initial = block.settings.author | strip | slice: 0 | upcase -%}
                <article class="hht-reviews__card" {{ block.shopify_attributes }}>
                  <div class="hht-reviews__card-top">
                    <span class="hht-reviews__avatar">
                      <span class="hht-reviews__avatar-initial" aria-hidden="true">{{ initial }}</span>
                      {%- if block.settings.avatar != blank -%}
                        <img src="{{ block.settings.avatar | image_url: width: 96 }}" alt="{{ block.settings.author | escape }}" width="48" height="48" loading="lazy" onerror="this.style.display='none'">
                      {%- endif -%}
                    </span>
                    <div class="hht-reviews__meta">
                      {%- if block.settings.author != blank -%}<span class="hht-reviews__author">{{ block.settings.author }}</span>{%- endif -%}
                      {%- if block.settings.location != blank -%}<span class="hht-reviews__loc">{{ block.settings.location }}</span>{%- endif -%}
                    </div>
                    <span class="hht-reviews__gicon" title="Google review">{{ gicon }}</span>
                  </div>
                  <span class="hht-reviews__card-stars" aria-label="5 out of 5 stars">{{ star }}{{ star }}{{ star }}{{ star }}{{ star }}</span>
                  {%- if block.settings.quote != blank -%}<p class="hht-reviews__quote">{{ block.settings.quote }}</p>{%- endif -%}
                </article>
              {%- endfor -%}
            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    {%- if section.settings.cta_text != blank and section.settings.cta_url != blank -%}
      <div class="container container--home">
        <div class="hht-reviews__cta">
          <a href="{{ section.settings.cta_url }}" class="btn btn--pill"{% if section.settings.cta_url contains '://' %} target="_blank" rel="noopener"{% endif %}>{{ section.settings.cta_text }}</a>
        </div>
      </div>
    {%- endif -%}
  {%- endunless -%}
</section>

{% schema %}
{
  "name": "Google reviews",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Loved By Texas" },
    { "type": "text", "id": "heading", "label": "Trust headline", "default": "3,000+ Five-Star Google Reviews" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Real glows, real reviews — the most-loved custom spray tan in Austin, Dallas & Houston." },
    { "type": "select", "id": "layout", "label": "Layout", "default": "full",
      "options": [
        { "value": "full", "label": "Full (homepage marquee)" },
        { "value": "compact", "label": "Compact (service page)" }
      ]
    },
    { "type": "range", "id": "speed", "label": "Scroll duration", "min": 20, "max": 90, "step": 5, "default": 50, "unit": "s", "info": "Homepage marquee only. Slower = higher number." },
    { "type": "text", "id": "cta_text", "label": "Button text", "default": "Read Our Reviews" },
    { "type": "url", "id": "cta_url", "label": "Button URL" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review card",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Review text" },
        { "type": "text", "id": "author", "label": "Reviewer name" },
        { "type": "text", "id": "location", "label": "Location / date" },
        { "type": "image_picker", "id": "avatar", "label": "Reviewer photo (optional)", "info": "Homepage marquee only. Leave blank for branded initial avatar." }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [{
    "name": "Google reviews",
    "blocks": [
      { "type": "review", "settings": { "quote": "The most natural spray tan I've ever had — perfectly color-matched and never orange. The studio feels like a luxury spa.", "author": "Ashley R.", "location": "Austin, TX" } },
      { "type": "review", "settings": { "quote": "I've been coming for years. The team is incredible and my glow always looks flawless for events.", "author": "Megan T.", "location": "Dallas, TX" } },
      { "type": "review", "settings": { "quote": "Booked before my wedding and I could not have been happier. Even, streak-free, and it lasted beautifully.", "author": "Priya S.", "location": "Houston, TX" } }
    ]
  }]
}
{% endschema %}
