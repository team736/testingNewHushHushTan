<section class="section{% if section.settings.soft_bg %} section-offwhite{% endif %}">
  <div class="container container--home">
    <div class="section-head">
      {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      <h2 class="mb-0">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}<p class="section-head__sub">{{ section.settings.subheading }}</p>{%- endif -%}
    </div>
    <div class="service-cards">
      {%- for block in section.blocks -%}
        <div class="service-card" {{ block.shopify_attributes }}>
          <h3 class="service-card__title">{{ block.settings.title }}</h3>
          {%- if block.settings.price != blank -%}<div class="service-card__price">{{ block.settings.price }}</div>{%- endif -%}
          <p class="service-card__desc">{{ block.settings.description }}</p>
          {%- if block.settings.cta_text != blank -%}
            <a href="{{ block.settings.cta_url }}" class="btn btn--lavender btn--small service-card__cta"{% if block.settings.cta_url contains '://' %} target="_blank" rel="noopener noreferrer"{% endif %}>{{ block.settings.cta_text }}</a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Service cards",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our Services" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Spray tanning services" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    { "type": "checkbox", "id": "soft_bg", "label": "Soft background", "default": false }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Service",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Custom Glow" },
        { "type": "text", "id": "price", "label": "Price", "default": "From $40" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "A signature airbrush tan mixed to your skin's undertones." },
        { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Book now" },
        { "type": "url", "id": "cta_url", "label": "CTA URL" }
      ]
    }
  ],
  "presets": [{ "name": "Service cards" }]
}
{% endschema %}
