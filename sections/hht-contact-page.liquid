    { "type": "text", "id": "hero_eyebrow", "label": "Eyebrow", "default": "Contact" },
    { "type": "text", "id": "hero_heading", "label": "Heading", "default": "Need Assistance? We’re Here to Help." },
    { "type": "html", "id": "hero_lead", "label": "Lead text (HTML)", "default": "Call your nearest studio or send our team a message. For general support, email <a href=\"mailto:contact@hushhushtan.com\">contact@hushhushtan.com</a>. For marketing and partnership inquiries, contact <a href=\"mailto:marketing@hushhushtan.com\">marketing@hushhushtan.com</a>." },
