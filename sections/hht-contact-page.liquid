{{ 'hht-supporting.css' | asset_url | stylesheet_tag }}

<div class="hht-sp" id="hht-contact-page">
  <section class="hht-sp__section">
    <div class="hht-sp__wrap">
      <div class="hht-sp-hero__panel">
        <div class="hht-sp-hero__body">
          <span class="hht-sp__eyebrow">{{ section.settings.hero_eyebrow | escape }}</span>
          <h1 class="hht-sp__h1">{{ section.settings.hero_heading | escape }}</h1>
          <p class="hht-sp__lead">{{ section.settings.hero_lead }}</p>
          <div class="hht-sp__ctas">
            {%- if section.settings.hero_cta1_label != blank -%}
              <a class="btn" href="{{ section.settings.hero_cta1_link }}">{{ section.settings.hero_cta1_label | escape }}</a>
            {%- endif -%}
            {%- if section.settings.hero_cta2_label != blank -%}
              <a class="btn btn--outline" href="{{ section.settings.hero_cta2_link }}">{{ section.settings.hero_cta2_label | escape }}</a>
            {%- endif -%}
          </div>
        </div>
        <div class="hht-sp-hero__media">
          {%- if section.settings.hero_image -%}
            <img src="{{ section.settings.hero_image | image_url: width: 1280 }}" alt="{{ section.settings.hero_image_alt | escape }}" width="640" height="427" loading="eager">
          {%- else -%}
            <img src="{{ 'hht-contact-team.jpg' | asset_url }}" alt="{{ section.settings.hero_image_alt | escape }}" width="640" height="427" loading="eager">
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>

  <section class="hht-sp__section hht-sp__section--warm">
    <div class="hht-sp__wrap">
      <div class="hht-sp__center">
        <span class="hht-sp__eyebrow">{{ section.settings.help_eyebrow | escape }}</span>
        <h2 class="hht-sp__h2">{{ section.settings.help_heading | escape }}</h2>
      </div>
      <div class="hht-sp-grid hht-sp-grid--3">
        <article class="hht-sp-card">
          <span class="hht-sp-card__label">{{ section.settings.card1_label | escape }}</span>
          <h3 class="hht-sp__h3">{{ section.settings.card1_title | escape }}</h3>
          <p>{{ section.settings.card1_text | escape }}</p>
          {%- if section.settings.card1_button_label != blank -%}
            <p style="margin-top:14px;"><a class="btn btn--outline" href="{{ section.settings.card1_button_link }}">{{ section.settings.card1_button_label | escape }}</a></p>
          {%- endif -%}
        </article>
        <article class="hht-sp-card">
          <span class="hht-sp-card__label">{{ section.settings.card2_label | escape }}</span>
          <h3 class="hht-sp__h3">{{ section.settings.card2_title | escape }}</h3>
          <p>{{ section.settings.card2_text }}</p>
        </article>
        <article class="hht-sp-card">
          <span class="hht-sp-card__label">{{ section.settings.card3_label | escape }}</span>
          <h3 class="hht-sp__h3">{{ section.settings.card3_title | escape }}</h3>
          <p>{{ section.settings.card3_text }}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="hht-sp__section" id="studios">
    <div class="hht-sp__wrap">
      <div class="hht-sp__center">
        <span class="hht-sp__eyebrow">{{ section.settings.studios_eyebrow | escape }}</span>
        <h2 class="hht-sp__h2">{{ section.settings.studios_heading | escape }}</h2>
      </div>
      <div class="hht-sp-grid hht-sp-grid--3">
        {%- for block in section.blocks -%}
          {%- if block.type == 'location' -%}
            <article class="hht-sp-loccard" {{ block.shopify_attributes }}>
              <div class="hht-sp-loccard__img">
                {%- if block.settings.image -%}
                  <img src="{{ block.settings.image | image_url: width: 1280 }}" alt="{{ block.settings.image_alt | escape }}" width="640" height="400" loading="lazy">
                {%- elsif block.settings.image_asset != blank -%}
                  <img src="{{ block.settings.image_asset | asset_url }}" alt="{{ block.settings.image_alt | escape }}" width="640" height="400" loading="lazy">
                {%- endif -%}
              </div>
              <div class="hht-sp-loccard__body">
                <span class="hht-sp-card__label">{{ block.settings.label | escape }}</span>
                <h3 class="hht-sp__h3">{{ block.settings.title | escape }}</h3>
                {%- if block.settings.address != blank -%}
                  <p class="hht-sp-loccard__address">{{ block.settings.address }}</p>
                {%- endif -%}
                {%- if block.settings.phone != blank -%}
                  <p class="hht-sp-loccard__phone">Phone: <a href="tel:{{ block.settings.phone }}">{{ block.settings.phone_label | escape }}</a></p>
                {%- endif -%}
                {%- if block.settings.email != blank -%}
                  <p class="hht-sp-loccard__email">Email: <a href="mailto:{{ block.settings.email }}">{{ block.settings.email }}</a></p>
                {%- endif -%}
                {%- if block.settings.hours != blank -%}
                  <p class="hht-sp-loccard__hours">{{ block.settings.hours }}</p>
                {%- endif -%}
                <div class="hht-sp-loccard__actions">
                  {%- if block.settings.book_url != blank -%}
                    <a class="btn" href="{{ block.settings.book_url }}" target="_blank" rel="noopener noreferrer">{{ block.settings.book_label | escape }}</a>
                  {%- endif -%}
                  {%- if block.settings.phone != blank -%}
                    <a class="btn btn--outline" href="tel:{{ block.settings.phone }}">{{ block.settings.call_label | escape }}</a>
                  {%- endif -%}
                  {%- if block.settings.view_url != blank -%}
                    <a class="btn btn--outline" href="{{ block.settings.view_url }}">{{ block.settings.view_label | escape }}</a>
                  {%- endif -%}
                  {%- if block.settings.directions_url != blank -%}
                    <a class="btn btn--outline" href="{{ block.settings.directions_url }}" target="_blank" rel="noopener noreferrer">{{ block.settings.directions_label | escape }}</a>
                  {%- endif -%}
                </div>
              </div>
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>

  <section class="hht-sp__section hht-sp__section--lavender" id="contact-form">
    <div class="hht-sp__wrap">
      <div class="hht-sp__center">
        <span class="hht-sp__eyebrow">{{ section.settings.form_eyebrow | escape }}</span>
        <h2 class="hht-sp__h2">{{ section.settings.form_heading | escape }}</h2>
        <p class="hht-sp__lead">{{ section.settings.form_lead | escape }}</p>
      </div>
      <div class="hht-sp-form">
        {%- form 'contact', class: 'hht-contact-form' -%}
          {%- if form.posted_successfully? -%}
            <div class="note note--ok" role="status">{{ section.settings.form_success | escape }}</div>
          {%- endif -%}
          {%- if form.errors -%}
            <div class="note note--err" role="alert">{{ form.errors | default_errors }}</div>
          {%- endif -%}

          <input type="hidden" name="contact[tags]" value="website-contact">

          <div class="grid-2">
            <div class="field">
              <label for="ContactName">Name</label>
              <input id="ContactName" type="text" name="contact[name]" autocomplete="name" required value="{% if form.name %}{{ form.name }}{% endif %}">
            </div>
            <div class="field">
              <label for="ContactEmail">Email</label>
              <input id="ContactEmail" type="email" name="contact[email]" autocomplete="email" required value="{% if form.email %}{{ form.email }}{% endif %}">
            </div>
          </div>

          <div class="grid-2">
            <div class="field">
              <label for="ContactPhone">Phone <span style="text-transform:none;letter-spacing:0;font-family:var(--font-body);color:var(--sp-muted);">(optional)</span></label>
              <input id="ContactPhone" type="tel" name="contact[phone]" autocomplete="tel" value="{% if form.phone %}{{ form.phone }}{% endif %}">
            </div>
            <div class="field">
              <label for="ContactLocation">Preferred location</label>
              <select id="ContactLocation" name="contact[location]" required>
                <option value="">Select…</option>
                <option value="Austin">Austin</option>
                <option value="Dallas">Dallas</option>
                <option value="Houston">Houston</option>
                <option value="Not location-specific">Not location-specific</option>
              </select>
            </div>
          </div>

          <div class="field">
            <label for="ContactInquiry">Inquiry type</label>
            <select id="ContactInquiry" name="contact[inquiry_type]" required>
              <option value="">Select…</option>
              <option value="Appointment or service question">Appointment or service question</option>
              <option value="Membership or package question">Membership or package question</option>
              <option value="Gift certificate question">Gift certificate question</option>
              <option value="Product question">Product question</option>
              <option value="Existing booking support">Existing booking support</option>
              <option value="Marketing or partnership">Marketing or partnership</option>
              <option value="Other">Other</option>
            </select>
          </div>

          <div class="field">
            <label for="ContactBody">Message</label>
            <textarea id="ContactBody" name="contact[body]" required>{% if form.body %}{{ form.body }}{% endif %}</textarea>
          </div>

          <button type="submit" class="btn" style="width:100%;">{{ section.settings.form_submit_label | escape }}</button>
        {%- endform -%}
      </div>
    </div>
  </section>

  <section class="hht-sp__section">
    <div class="hht-sp__wrap">
      <div class="hht-sp-split hht-sp-split--media-emphasis">
        <div>
          <span class="hht-sp__eyebrow">{{ section.settings.mkt_eyebrow | escape }}</span>
          <h2 class="hht-sp__h2">{{ section.settings.mkt_heading | escape }}</h2>
          <p class="hht-sp__lead">{{ section.settings.mkt_lead | escape }}</p>
          <div class="hht-sp__ctas">
            {%- if section.settings.mkt_cta1_label != blank -%}
              <a class="btn" href="{{ section.settings.mkt_cta1_link }}">{{ section.settings.mkt_cta1_label | escape }}</a>
            {%- endif -%}
            {%- if section.settings.mkt_cta2_label != blank -%}
              <a class="btn btn--outline" href="{{ section.settings.mkt_cta2_link }}">{{ section.settings.mkt_cta2_label | escape }}</a>
            {%- endif -%}
          </div>
        </div>
        <div class="hht-sp-split__media">
          {%- if section.settings.mkt_image -%}
            <img src="{{ section.settings.mkt_image | image_url: width: 1280 }}" alt="{{ section.settings.mkt_image_alt | escape }}" width="640" height="427" loading="lazy">
          {%- else -%}
            <img src="{{ 'hht-partnerships-team.jpg' | asset_url }}" alt="{{ section.settings.mkt_image_alt | escape }}" width="640" height="427" loading="lazy">
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>

  <section class="hht-sp__section hht-sp__section--warm">
    <div class="hht-sp__wrap">
      <div class="hht-sp-cta-center" style="padding-top:0;padding-bottom:0;">
        <span class="hht-sp__eyebrow">{{ section.settings.faq_eyebrow | escape }}</span>
        <h2 class="hht-sp__h2">{{ section.settings.faq_heading | escape }}</h2>
        <p class="hht-sp__lead">{{ section.settings.faq_lead | escape }}</p>
        <div class="hht-sp__ctas">
          {%- if section.settings.faq_cta1_label != blank -%}
            <a class="btn" href="{{ section.settings.faq_cta1_link }}">{{ section.settings.faq_cta1_label | escape }}</a>
          {%- endif -%}
          {%- if section.settings.faq_cta2_label != blank -%}
            <a class="btn btn--outline" href="{{ section.settings.faq_cta2_link }}">{{ section.settings.faq_cta2_label | escape }}</a>
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>
</div>

{% schema %}
