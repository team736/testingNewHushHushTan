{%- liquid
  assign book_url = section.settings.book_url | default: settings.book_austin_url | default: 'https://go.booker.com/location/hushhushtan/service-menu'
  assign book_text = section.settings.book_text | default: 'Book Your Glow'
  if book_url == blank
    assign book_url = 'https://go.booker.com/location/hushhushtan/service-menu'
  endif
  assign menu_index = 0
  assign newsletter_block = nil
  for block in section.blocks
    if block.type == 'newsletter'
      assign newsletter_block = block
    endif
  endfor
-%}

{%- if newsletter_block -%}
<section class="hht-newsletter-band section-lavender-soft" aria-label="Newsletter signup">
  <div class="hht-newsletter-band__inner">
    <div class="section-card-panel hht-newsletter-band__panel" {{ newsletter_block.shopify_attributes }}>
      <h2 class="hht-newsletter-band__title">{{ newsletter_block.settings.heading | default: 'Get In The Know' }}</h2>
      {%- if newsletter_block.settings.text != blank -%}
        <p class="hht-newsletter-band__text">{{ newsletter_block.settings.text }}</p>
      {%- endif -%}

      {%- assign footer_newsletter_id = 'footer-newsletter-' | append: section.id -%}
      {%- form 'customer', class: 'hht-newsletter-band__form', id: footer_newsletter_id -%}
        <input type="hidden" name="contact[tags]" value="newsletter">

        {%- if form.posted_successfully? -%}
          <p class="hht-newsletter-band__message hht-newsletter-band__message--success" role="status">
            {{ newsletter_block.settings.success_message | default: 'Thank you for subscribing. Check your inbox for glow tips and offers.' }}
          </p>
        {%- else -%}
          {%- if form.errors -%}
            <p class="hht-newsletter-band__message hht-newsletter-band__message--error" role="alert">
              {{ form.errors | default_errors }}
            </p>
          {%- endif -%}

          <div class="hht-newsletter-band__signup-pill">
            <label class="visually-hidden" for="footer-email-{{ section.id }}">Email address</label>
            <input
              type="email"
              id="footer-email-{{ section.id }}"
              name="contact[email]"
              class="hht-newsletter-band__signup-input"
              placeholder="{{ newsletter_block.settings.placeholder | default: 'Email address' }}"
              autocomplete="email"
              required
              {% if form.errors %}aria-invalid="true"{% endif %}>
            <button type="submit" class="hht-newsletter-band__signup-btn">
              {{ newsletter_block.settings.button_text | default: 'Subscribe' }}
            </button>
          </div>
        {%- endif -%}
      {%- endform -%}

      {%- if newsletter_block.settings.disclaimer != blank -%}
        <p class="hht-newsletter-band__disclaimer">{{ newsletter_block.settings.disclaimer }}</p>
      {%- endif -%}
    </div>
  </div>
</section>
{%- endif -%}

<footer class="hht-footer" role="contentinfo">
  <div class="container hht-footer__inner">
    <div class="hht-footer__grid">
      {%- comment -%} Column 1 — Brand {%- endcomment -%}
      <div class="hht-footer__col hht-footer__col--brand">
        <a href="{{ routes.root_url }}" class="hht-footer__logo" aria-label="{{ shop.name }} — Home">
          {%- if settings.logo != blank -%}
            <img src="{{ settings.logo | image_url: width: 320 }}" alt="{{ shop.name }}" width="200" height="48" loading="lazy">
          {%- else -%}
            <span class="hht-footer__logo-text">{{ shop.name }}</span>
          {%- endif -%}
        </a>

        <div class="hht-footer__social-row" aria-label="Social media">
          {%- if settings.social_facebook != blank -%}
            <a href="{{ settings.social_facebook }}" target="_blank" rel="noopener">Fb.</a>
          {%- endif -%}
          {%- if settings.social_instagram != blank -%}
            <a href="{{ settings.social_instagram }}" target="_blank" rel="noopener">Ig.</a>
          {%- endif -%}
          {%- if settings.social_tiktok != blank -%}
            <a href="{{ settings.social_tiktok }}" target="_blank" rel="noopener">Tt.</a>
          {%- endif -%}
          {%- if settings.social_pinterest != blank -%}
            <a href="{{ settings.social_pinterest }}" target="_blank" rel="noopener">Pin.</a>
          {%- endif -%}
        </div>

        {%- if section.settings.brand_tagline != blank -%}
          <p class="hht-footer__tagline">{{ section.settings.brand_tagline }}</p>
        {%- endif -%}

        <a href="{{ book_url }}" class="hht-footer__book-link" target="_blank" rel="noopener">{{ book_text }} →</a>
      </div>

      {%- comment -%} Column 2 — Menu groups 1–2 {%- endcomment -%}
      <div class="hht-footer__col hht-footer__col--menus">
        {%- for block in section.blocks -%}
          {%- if block.type == 'menu_column' -%}
            {%- assign menu_index = menu_index | plus: 1 -%}
            {%- if menu_index <= 2 -%}
              {% render 'footer-menu-block', block: block %}
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- comment -%} Column 3 — Menu groups 3–4 {%- endcomment -%}
      <div class="hht-footer__col hht-footer__col--menus">
        {%- assign menu_index = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'menu_column' -%}
            {%- assign menu_index = menu_index | plus: 1 -%}
            {%- if menu_index > 2 -%}
              {% render 'footer-menu-block', block: block %}
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <div class="hht-footer__bottom">
      <p class="hht-footer__copy">
        © {{ 'now' | date: '%Y' }} {{ shop.name }}
        {%- if section.settings.colophon != blank -%}<span class="hht-footer__copy-sep" aria-hidden="true">·</span>{{ section.settings.colophon }}{%- endif -%}
      </p>
      <div class="hht-footer__legal">
        <a href="/policies/privacy-policy">Privacy</a>
        <a href="/policies/terms-of-service">Terms</a>
        <a href="/pages/sitemap">Sitemap</a>
      </div>
      <div class="hht-footer__payments" aria-label="Accepted payment methods">
        <span>Visa</span><span>MC</span><span>Amex</span><span>PayPal</span><span>Apple Pay</span>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "textarea",
      "id": "brand_tagline",
      "label": "Brand description",
      "default": "Customizable spray tanning studios in Austin, Dallas, and Houston. Healthier glow. Flawless confidence."
    },
    {
      "type": "text",
      "id": "book_text",
      "label": "Book link text",
      "default": "Book Your Glow"
    },
    {
      "type": "url",
      "id": "book_url",
      "label": "Book link URL"
    },
    {
      "type": "text",
      "id": "colophon",
      "label": "Copyright tagline",
      "default": "All rights reserved."
    }
  ],
  "blocks": [
    {
      "type": "menu_column",
      "name": "Menu column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Explore" },
        { "type": "link_list", "id": "menu", "label": "Menu (assign in Online Store → Navigation)" },
        { "type": "textarea", "id": "fallback_items", "label": "Fallback items (Title|URL per line)", "info": "Used only if no Menu is selected above" }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Get In The Know" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Join us for glow tips, new drops, packages and special offers." },
        { "type": "text", "id": "placeholder", "label": "Email placeholder", "default": "Email address" },
        { "type": "text", "id": "button_text", "label": "Button text", "default": "Subscribe" },
        { "type": "text", "id": "success_message", "label": "Success message" },
        { "type": "text", "id": "disclaimer", "label": "Disclaimer", "default": "We respect your privacy. Unsubscribe anytime." }
      ]
    }
  ],
  "max_blocks": 6,
  "default": {
    "blocks": [
      { "type": "menu_column", "settings": { "heading": "Company", "fallback_items": "Our Story|/pages/about-us\nLocations|/pages/locations\nPress|/pages/press\nCareers|https://hushhushtan.com/a/careers/" } },
      { "type": "menu_column", "settings": { "heading": "Shop & Services", "fallback_items": "Tanning Products|/collections/tanning-products\nGift Certificates|/pages/tanning-gift-certificates\nGroup Tanning & Mimosas|/pages/hush-hush-tan-group-tanning-mimosas-package\nMobile Spray Tan|/pages/mobile-spray-tan\nTanning Tips|/pages/tanning-tips" } },
      { "type": "menu_column", "settings": { "heading": "Support", "fallback_items": "Contact|/pages/contact\nFAQs|/pages/faqs\nShipping|/pages/shipping\nPrivacy Policy|/policies/privacy-policy\nTerms of Service|/policies/terms-of-service" } },
      { "type": "menu_column", "settings": { "heading": "Locations", "fallback_items": "Austin|/pages/austin\nDallas|/pages/dallas\nHouston|/pages/houston" } },
      { "type": "newsletter" }
    ]
  }
}
{% endschema %}
