<article class="article">
  <div class="breadcrumb"><a href="{{ blog.url }}">{{ blog.title }}</a> <span class="breadcrumb__sep">/</span> <span aria-current="page">{{ article.title }}</span></div>
  <header>
    <h1 class="article__title">{{ article.title }}</h1>
    <div class="article__meta">{{ article.published_at | date: '%B %d, %Y' }}{% if article.author %} · by {{ article.author }}{% endif %}</div>
  </header>
  {%- if article.image -%}
    <div class="article__hero">
      <img src="{{ article.image | image_url: width: 1600 }}" alt="{{ article.image.alt | default: article.title | escape }}" width="1600" height="1000" loading="eager">
    </div>
  {%- endif -%}
  <div class="article__body rte">{{ article.content }}</div>

  <div class="final-cta" style="margin-top: 64px;">
    <h2 class="mb-0">Ready to glow?</h2>
    <p style="margin: 12px 0 24px;">Book your Custom Glow at Austin, Dallas, or Houston.</p>
    <div class="flex" style="justify-content: center;">
      <a href="{{ pages['locations'].url | default: '/pages/locations' }}" class="btn">Choose Your Location</a>
      <a href="{{ collections['tanning-products'].url | default: routes.all_products_collection_url }}" class="btn btn--ghost" style="color:#fff;">Shop Products</a>
    </div>
  </div>

  {%- if blog.articles.size > 1 -%}
    <section class="section">
      <h2 class="text-center">More from the Get Glowing Guide</h2>
      <div class="blog-grid">
        {%- assign shown = 0 -%}
        {%- for a in blog.articles -%}
          {%- if a.id != article.id and shown < 3 -%}
            <a class="blog-card" href="{{ a.url }}">
              <div class="blog-card__media">{%- if a.image -%}<img src="{{ a.image | image_url: width: 600 }}" alt="{{ a.title | escape }}" width="600" height="450" loading="lazy">{%- endif -%}</div>
              <h3 class="blog-card__title">{{ a.title }}</h3>
            </a>
            {%- assign shown = shown | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    </section>
  {%- endif -%}
</article>

{% schema %}
{ "name": "Article", "settings": [] }
{% endschema %}
