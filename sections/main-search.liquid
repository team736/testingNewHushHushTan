<div class="container section">
  <h1>Search</h1>
  <form action="{{ routes.search_url }}" method="get" role="search" class="form" style="max-width: 720px;">
    <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search…" aria-label="Search">
    <button type="submit" class="btn">Search</button>
  </form>

  {%- if search.performed -%}
    <p class="muted small" style="margin: 24px 0;">{{ search.results_count }} results for "{{ search.terms | escape }}"</p>
    {%- if search.results.size > 0 -%}
      <div class="collection-grid">
        {%- for item in search.results -%}
          {%- if item.object_type == 'product' -%}
            {% render 'product-card', product: item %}
          {%- else -%}
            <a href="{{ item.url }}" class="product-card">
              <h3 class="product-card__title">{{ item.title }}</h3>
              <div class="muted small">{{ item.excerpt | strip_html | truncate: 100 }}</div>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- else -%}
      <p class="muted">No results found.</p>
    {%- endif -%}
  {%- endif -%}
</div>

{% schema %}
{ "name": "Search", "settings": [] }
{% endschema %}
