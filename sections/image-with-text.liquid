<section class="section">
  <div class="container">
    <div class="image-with-text{% if section.settings.image_side == 'right' %} image-with-text--reverse{% endif %}">
      <div class="image-with-text__media">
        {%- if section.settings.image != blank -%}
          <img src="{{ section.settings.image | image_url: width: 1200 }}"
               sizes="(max-width: 900px) 100vw, 50vw"
               alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}"
               loading="lazy" width="1000" height="1200">
        {%- else -%}
          <img src="{{ 'hht-studio-glow.png' | asset_url }}" alt="{{ section.settings.heading | escape }}" loading="lazy" width="1000" height="1200">
        {%- endif -%}
      </div>
      <div>
        {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        <h2>{{ section.settings.heading }}</h2>
        <div class="rte">{{ section.settings.text }}</div>
        {%- if section.settings.cta_text != blank -%}
          <a href="{{ section.settings.cta_url }}" class="btn" style="margin-top: 12px;">{{ section.settings.cta_text }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image with text",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "select", "id": "image_side", "label": "Image side", "options": [
      {"value":"left","label":"Left"},{"value":"right","label":"Right"}
    ], "default": "left" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Everyone will notice. No one will know." },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Our masterful airbrush technique uses natural, eco-certified DHA formulas that are cruelty-free, paraben-free, and alcohol-free. The result is a flawless, customizable glow that looks like it's truly yours.</p>" },
    { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Our Story" },
    { "type": "url", "id": "cta_url", "label": "CTA URL" }
  ],
  "presets": [{ "name": "Image with text" }]
}
{% endschema %}
