<section class="section section--tight">
  <div class="container">
    <div class="promo-grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.url | default: '#' }}" class="promo-card" {{ block.shopify_attributes }} style="{% if block.settings.bg_color != blank %}background:{{ block.settings.bg_color }};{% endif %}">
          <div class="promo-card__media">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 1200 }}" alt="{{ block.settings.heading | escape }}" width="1200" height="600" loading="lazy">
            {%- else -%}
              {%- assign fallback_asset = 'hht-spray-tanning.png' -%}
              {%- if forloop.index == 2 -%}{%- assign fallback_asset = 'hht-products.png' -%}{%- endif -%}
              <img src="{{ fallback_asset | asset_url }}" alt="{{ block.settings.heading | escape }}" width="1200" height="600" loading="lazy">
            {%- endif -%}
          </div>
          <div class="promo-card__copy">
            {%- if block.settings.eyebrow != blank -%}<div class="promo-card__eyebrow">{{ block.settings.eyebrow }}</div>{%- endif -%}
            <h3 class="promo-card__title">{{ block.settings.heading }}</h3>
            {%- if block.settings.cta_text != blank -%}
              <span class="btn btn--outline btn--small">{{ block.settings.cta_text }}</span>
            {%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Promo cards",
  "max_blocks": 3,
  "blocks": [
    {
      "type": "card",
      "name": "Promo card",
      "settings": [
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "New Collection" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Custom Glow Experience" },
        { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Explore More" },
        { "type": "url", "id": "url", "label": "Link" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "color", "id": "bg_color", "label": "Background color (fallback)" }
      ]
    }
  ],
  "presets": [{
    "name": "Promo cards",
    "blocks": [
      { "type": "card", "settings": { "eyebrow": "Our signature", "heading": "Custom Glow Spray Tanning", "cta_text": "Book Now" } },
      { "type": "card", "settings": { "eyebrow": "Extend your glow", "heading": "Tanning Products & Skincare", "cta_text": "Shop Now" } }
    ]
  }]
}
{% endschema %}
