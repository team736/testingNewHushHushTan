<section class="section section--tight">
  <div class="container" style="max-width: 760px; text-align: {{ section.settings.text_align }};">
    {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
    {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
    <div class="rte">{{ section.settings.text }}</div>
    {%- if section.settings.cta_text != blank -%}
      <a href="{{ section.settings.cta_url }}" class="btn" style="margin-top: 16px;">{{ section.settings.cta_text }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Rich text",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Customizable spray tanning, clean formulas, and booking links for Austin, Dallas, and Houston.</p>" },
    { "type": "select", "id": "text_align", "label": "Align", "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"}], "default": "center" },
    { "type": "text", "id": "cta_text", "label": "CTA text" },
    { "type": "url", "id": "cta_url", "label": "CTA URL" }
  ],
  "presets": [{ "name": "Rich text" }]
}
{% endschema %}
