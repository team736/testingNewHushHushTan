<section class="section faq-premium">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <div class="section-head">
        {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        <h2>{{ section.settings.heading }}</h2>
        {%- if section.settings.subheading != blank -%}<p class="section-head__sub">{{ section.settings.subheading }}</p>{%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.settings.show_banner -%}
      <div class="faq-banner">
        {%- if section.settings.banner_image != blank -%}
          <img src="{{ section.settings.banner_image | image_url: width: 1800 }}" alt="{{ section.settings.heading | default: 'Frequently asked questions' | escape }}" width="1800" height="760" loading="lazy">
        {%- else -%}
          <img src="{{ 'hht-spray-tanning.png' | asset_url }}" alt="{{ section.settings.heading | default: 'Frequently asked questions' | escape }}" width="1800" height="760" loading="lazy">
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- assign group_blocks = section.blocks | where: 'type', 'group' -%}
    {%- if group_blocks.size > 1 -%}
      <div class="faq-layout">
        <div class="faq-tabs" role="tablist">
          {%- for g in group_blocks -%}
            <button class="{% if forloop.first %}is-active{% endif %}" data-faq-tab="panel-{{ g.id }}" {% if forloop.first %}aria-selected="true"{% endif %}>{{ g.settings.title }}</button>
          {%- endfor -%}
        </div>

        <div class="faq-panels">
          {%- for g in group_blocks -%}
            <div class="faq-panel{% if forloop.first %} is-active{% endif %}" id="panel-{{ g.id }}">
              <h3 class="faq__group-title">{{ g.settings.title }}</h3>
              {%- assign current = -1 -%}
              {%- for blk in section.blocks -%}
                {%- if blk.id == g.id -%}{%- assign current = forloop.index0 -%}{%- endif -%}
              {%- endfor -%}
              {%- for inner in section.blocks -%}
                {%- if forloop.index0 > current and inner.type == 'qa' -%}
                  <details class="faq__item">
                    <summary>{{ inner.settings.question }}</summary>
                    <div class="faq__answer">{{ inner.settings.answer }}</div>
                  </details>
                {%- elsif forloop.index0 > current and inner.type == 'group' -%}
                  {%- break -%}
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- else -%}
      <div class="faq-premium__list-wrap" style="max-width: 820px; margin: 0 auto;">
        {%- for blk in section.blocks -%}
          {%- if blk.type == 'group' -%}
            <h3 class="faq__group-title">{{ blk.settings.title }}</h3>
          {%- elsif blk.type == 'qa' -%}
            <details class="faq__item">
              <summary>{{ blk.settings.question }}</summary>
              <div class="faq__answer">{{ blk.settings.answer }}</div>
            </details>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.show_view_all -%}
      <div class="text-center" style="margin-top: 40px;">
        <a href="{{ section.settings.view_all_url | default: '/pages/faqs' }}" class="btn btn--pill btn--outline">View All FAQs</a>
      </div>
    {%- endif -%}
  </div>
</section>

<script>
  document.querySelectorAll('[data-faq-tab]').forEach(function(btn){
    btn.addEventListener('click', function(){
      var root = btn.closest('.faq-layout');
      root.querySelectorAll('[data-faq-tab]').forEach(function(b){ b.classList.remove('is-active'); b.setAttribute('aria-selected','false'); });
      root.querySelectorAll('.faq-panel').forEach(function(p){ p.classList.remove('is-active'); });
      btn.classList.add('is-active'); btn.setAttribute('aria-selected','true');
      var p = root.querySelector('#' + btn.getAttribute('data-faq-tab'));
      if (p) p.classList.add('is-active');
    });
  });
</script>

{% schema %}
{
  "name": "FAQ accordion",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently asked questions" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Everything you need to feel ready for your glow." },
    { "type": "checkbox", "id": "show_banner", "label": "Show image banner", "default": false },
    { "type": "image_picker", "id": "banner_image", "label": "Banner image" },
    { "type": "checkbox", "id": "show_view_all", "label": "Show View all FAQs link", "default": false },
    { "type": "url", "id": "view_all_url", "label": "View all URL" }
  ],
  "blocks": [
    {
      "type": "group",
      "name": "Group heading",
      "settings": [
        { "type": "text", "id": "title", "label": "Group title", "default": "Before Your Tan" }
      ]
    },
    {
      "type": "qa",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "How should I prepare for my spray tan?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Exfoliate 24 hours before, shave/wax at least 12 hours prior, and arrive with clean, product-free skin.</p>" }
      ]
    }
  ],
  "presets": [{
    "name": "FAQ accordion",
    "blocks": [
      { "type": "group", "settings": { "title": "Before Your Tan" } },
      { "type": "qa" },
      { "type": "qa", "settings": { "question": "What should I wear?", "answer": "<p>Wear loose, dark, comfortable clothing. Avoid tight straps and jeans.</p>" } },
      { "type": "group", "settings": { "title": "During Your Appointment" } },
      { "type": "qa", "settings": { "question": "How long is the appointment?", "answer": "<p>A Custom Glow takes about 15–20 minutes start to finish.</p>" } },
      { "type": "group", "settings": { "title": "Aftercare" } },
      { "type": "qa", "settings": { "question": "How long does a spray tan last?", "answer": "<p>With proper aftercare, your Custom Glow lasts 7–10 days.</p>" } },
      { "type": "qa", "settings": { "question": "When can I shower?", "answer": "<p>Wait 8–12 hours for a Custom Glow. For Rapid Glow, follow the technician's timing.</p>" } }
    ]
  }]
}
{% endschema %}
