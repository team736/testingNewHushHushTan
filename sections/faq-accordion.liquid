{%- assign book_url = section.settings.book_url | default: settings.book_austin_url | default: 'https://go.booker.com/location/hushhushtan/service-menu' -%}

<section class="section hht-stitch-faq" id="faq-{{ section.id }}">
  <div class="container">
    <div class="hht-stitch-faq__head">
      {%- if section.settings.eyebrow != blank -%}
        <span class="hht-stitch-faq__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="hht-stitch-faq__title">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="hht-stitch-faq__sub">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    {%- if section.settings.show_banner -%}
      <div class="hht-stitch-faq__banner">
        {%- if section.settings.banner_image != blank -%}
          <img src="{{ section.settings.banner_image | image_url: width: 1800 }}" alt="" width="1800" height="760" loading="lazy">
        {%- else -%}
          <img src="{{ 'hht-glow-wall-2.jpg' | asset_url }}" alt="" width="1800" height="760" loading="lazy">
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="hht-stitch-faq__grid">
      {%- if section.settings.show_prep_sidebar -%}
        <aside class="hht-stitch-faq__prep" aria-label="Glow prep basics">
          <div class="hht-stitch-faq__prep-card">
            <h3 class="hht-stitch-faq__prep-title">Glow Prep Basics</h3>

            <div class="hht-stitch-faq__prep-group">
              <h4 class="hht-stitch-faq__prep-label">Before Your Tan</h4>
              <ul class="hht-stitch-faq__prep-list">
                <li><span class="hht-stitch-faq__prep-check" aria-hidden="true">{% render 'icon', name: 'check-circle' %}</span><span>Exfoliate &amp; shave 24 hours prior.</span></li>
                <li><span class="hht-stitch-faq__prep-check" aria-hidden="true">{% render 'icon', name: 'check-circle' %}</span><span>Avoid lotions or oils on skin.</span></li>
                <li><span class="hht-stitch-faq__prep-check" aria-hidden="true">{% render 'icon', name: 'check-circle' %}</span><span>Wear loose, dark clothing.</span></li>
              </ul>
            </div>

            <div class="hht-stitch-faq__prep-group">
              <h4 class="hht-stitch-faq__prep-label">Day of Your Tan</h4>
              <ul class="hht-stitch-faq__prep-list">
                <li><span class="hht-stitch-faq__prep-check" aria-hidden="true">{% render 'icon', name: 'check-circle' %}</span><span>Arrive with clean, bare skin.</span></li>
                <li><span class="hht-stitch-faq__prep-check" aria-hidden="true">{% render 'icon', name: 'check-circle' %}</span><span>Avoid deodorant and perfume.</span></li>
              </ul>
            </div>

            <div class="hht-stitch-faq__prep-group">
              <h4 class="hht-stitch-faq__prep-label">After Your Tan</h4>
              <ul class="hht-stitch-faq__prep-list">
                <li><span class="hht-stitch-faq__prep-check" aria-hidden="true">{% render 'icon', name: 'check-circle' %}</span><span>Rinse after 8–12 hours (Custom Glow) or follow your technician's Rapid Glow timing.</span></li>
                <li><span class="hht-stitch-faq__prep-check" aria-hidden="true">{% render 'icon', name: 'check-circle' %}</span><span>Moisturize daily with oil-free products.</span></li>
              </ul>
            </div>
          </div>
        </aside>
      {%- endif -%}

      <div class="hht-stitch-faq__accordion" data-hht-accordion>
        {%- assign qa_index = 0 -%}
        {%- for blk in section.blocks -%}
          {%- if blk.type == 'qa' -%}
            {%- assign qa_index = qa_index | plus: 1 -%}
            {%- assign panel_id = 'faq-panel-' | append: section.id | append: '-' | append: qa_index -%}
            <div class="hht-stitch-faq__item{% if qa_index == 1 %} is-open{% endif %}" data-hht-accordion-item>
              <button
                type="button"
                class="hht-stitch-faq__trigger"
                aria-expanded="{% if qa_index == 1 %}true{% else %}false{% endif %}"
                aria-controls="{{ panel_id }}"
                id="faq-trigger-{{ section.id }}-{{ qa_index }}">
                <span class="hht-stitch-faq__question">{{ blk.settings.question }}</span>
                <span class="hht-stitch-faq__icon" aria-hidden="true"></span>
              </button>
              <div
                class="hht-stitch-faq__panel"
                id="{{ panel_id }}"
                role="region"
                aria-labelledby="faq-trigger-{{ section.id }}-{{ qa_index }}"
                {% if qa_index != 1 %}style="max-height:0"{% endif %}>
                <div class="hht-stitch-faq__answer">{{ blk.settings.answer }}</div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    {%- if section.settings.show_ctas -%}
      <div class="hht-stitch-faq__ctas">
        <p class="hht-stitch-faq__cta-label">Still have questions?</p>
        <div class="hht-stitch-faq__cta-row">
          <a href="{{ section.settings.view_all_url | default: '/pages/faqs' }}" class="btn hht-stitch-btn hht-stitch-btn--lavender">Read All FAQs →</a>
          <a href="{{ book_url }}" class="btn hht-stitch-btn hht-stitch-btn--dark" target="_blank" rel="noopener">Book Your Glow</a>
        </div>
      </div>
    {%- elsif section.settings.show_view_all -%}
      <div class="hht-stitch-faq__ctas">
        <a href="{{ section.settings.view_all_url | default: '/pages/faqs' }}" class="btn hht-stitch-btn hht-stitch-btn--lavender">Read All FAQs →</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "FAQ accordion",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Good to Know" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently asked questions" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Everything you need to feel ready for your glow." },
    { "type": "checkbox", "id": "show_prep_sidebar", "label": "Show prep checklist sidebar", "default": true },
    { "type": "checkbox", "id": "show_banner", "label": "Show image banner", "default": false },
    { "type": "image_picker", "id": "banner_image", "label": "Banner image" },
    { "type": "checkbox", "id": "show_ctas", "label": "Show bottom CTAs (Read All FAQs + Book)", "default": true },
    { "type": "checkbox", "id": "show_view_all", "label": "Show View all FAQs link only", "default": false },
    { "type": "url", "id": "view_all_url", "label": "View all URL", "default": "/pages/faqs" },
    { "type": "url", "id": "book_url", "label": "Book Your Glow URL", "info": "Defaults to Austin Booker service menu." }
  ],
  "blocks": [
    {
      "type": "group",
      "name": "Group heading",
      "settings": [
        { "type": "text", "id": "title", "label": "Group title", "default": "Before Your Tan" }
      ]
    },
    {
      "type": "qa",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "How long will my tan last?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Airbrush tans can last up to ten days depending on skin preparation and aftercare.</p>" }
      ]
    }
  ],
  "presets": [{
    "name": "FAQ accordion",
    "blocks": [
      { "type": "qa", "settings": { "question": "How long will my tan last?", "answer": "<p>Airbrush tans can last up to ten days depending on skin preparation and aftercare. Long hot baths or showers and exposure to chlorine will speed up the fading process. Using tan extenders or mixing body lotion with self-tanner daily can extend the tan by 50-75%.</p>" } },
      { "type": "qa", "settings": { "question": "How do I prepare for my airbrush tanning session?", "answer": "<p>Shower, shave, and exfoliate. After showering do not apply any body or face moisturizers, makeup, or deodorant. Complete all grooming and workouts beforehand, and wear loose, dark clothing.</p>" } },
      { "type": "qa", "settings": { "question": "What should I expect after my appointment?", "answer": "<p>You may feel slightly damp for an hour but can resume normal activities. Remain dry and avoid touching your skin to ensure that your tan dries flawlessly. The tan darkens over 2–3 hours. Shower lightly after 8 hours, and avoid pools and hot tubs.</p>" } },
      { "type": "qa", "settings": { "question": "How do I take care of my spray tan?", "answer": "<p>Remain dry for the next 6–8 hours following your appointment. Take short, warm showers with mild soap, shave gently, moisturize with a mild lotion or Hush Hush Tan Enhancer, and apply perfume to clothes rather than skin.</p>" } },
      { "type": "qa", "settings": { "question": "What do I wear for my airbrush tanning session?", "answer": "<p>Women need a bottom cover; complimentary disposable undies are available, plus C-string undies for $6. Men must wear boxers or briefs; disposable options cost $3.</p>" } },
      { "type": "qa", "settings": { "question": "Is airbrush tanning safe?", "answer": "<p>Yes, DHA is FDA-approved and considered nontoxic and non-carcinogenic. Major health organizations have recommended sunless tanning. Pregnant or nursing mothers should consult their doctor before tanning.</p>" } },
      { "type": "qa", "settings": { "question": "Can my tanning membership be frozen?", "answer": "<p>Yes, memberships can be frozen for a $10 monthly fee. Contact contact@hushhushtan.com for details.</p>" } },
      { "type": "qa", "settings": { "question": "Do tans rollover?", "answer": "<p>No, tans do not rollover.</p>" } }
    ]
  }]
}
{% endschema %}
