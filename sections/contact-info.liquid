<section class="section">
  <div class="container container--narrow">
    <header class="contact-header">
      {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      <h1 class="mb-0">{{ section.settings.heading }}</h1>
      {%- if section.settings.text != blank -%}<p>{{ section.settings.text }}</p>{%- endif -%}
    </header>

    <div class="contact-info-row">
      {%- for block in section.blocks -%}
        <div class="contact-info" {{ block.shopify_attributes }}>
          <div class="contact-info__icon">{% render 'icon', name: block.settings.icon %}</div>
          <div>
            <h3>{{ block.settings.heading }}</h3>
            {%- if block.settings.text != blank -%}<div class="muted small" style="margin-bottom: 8px;">{{ block.settings.text | newline_to_br }}</div>{%- endif -%}
            {%- if block.settings.line1 != blank -%}<p>{{ block.settings.line1 }}</p>{%- endif -%}
            {%- if block.settings.line2 != blank -%}<p>{{ block.settings.line2 }}</p>{%- endif -%}
            {%- if block.settings.line3 != blank -%}
              {%- assign line3_digits = block.settings.line3 | remove: '(' | remove: ')' | remove: ' ' | remove: '-' | remove: '.' | remove: '+' -%}
              {%- if line3_digits.size >= 10 -%}
                <p>{% render 'tel-link', phone: block.settings.line3 %}</p>
              {%- else -%}
                <p>{{ block.settings.line3 }}</p>
              {%- endif -%}
            {%- endif -%}
            {%- if block.settings.cta_text != blank -%}
              <p style="margin-top: 16px;"><a href="{{ block.settings.cta_url | default: '#' }}" class="btn--ghost">{{ block.settings.cta_text }} →</a></p>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact info row",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Contact" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Keep In Touch with Us" },
    { "type": "textarea", "id": "text", "label": "Subtext", "default": "Reach out to any of our three Texas locations. We respond within one business day." }
  ],
  "blocks": [
    {
      "type": "info",
      "name": "Info block",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "options": [
          {"value":"map-pin","label":"Map pin"},{"value":"phone","label":"Phone"},{"value":"clock","label":"Clock"},{"value":"chat","label":"Chat"}
        ], "default": "map-pin" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Austin" },
        { "type": "textarea", "id": "text", "label": "Subtext" },
        { "type": "text", "id": "line1", "label": "Line 1" },
        { "type": "text", "id": "line2", "label": "Line 2" },
        { "type": "text", "id": "line3", "label": "Line 3" },
        { "type": "text", "id": "cta_text", "label": "CTA text" },
        { "type": "url", "id": "cta_url", "label": "CTA URL" }
      ]
    }
  ],
  "presets": [{
    "name": "Contact info row",
    "blocks": [
      { "type": "info", "settings": { "icon": "map-pin", "heading": "Austin",  "line1": "1211 West 6th St, Suite #400", "line2": "Austin, TX 78703", "cta_text": "Book Austin" } },
      { "type": "info", "settings": { "icon": "phone",   "heading": "Dallas",  "line1": "4254 Oak Lawn Avenue", "line2": "Dallas, TX 75219", "line3": "469-868-6228", "cta_text": "Book Dallas" } },
      { "type": "info", "settings": { "icon": "clock",   "heading": "Houston", "line1": "Houston studio details to be confirmed", "line2": "", "cta_text": "Book Houston" } }
    ]
  }]
}
{% endschema %}
