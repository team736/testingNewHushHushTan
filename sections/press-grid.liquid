{%- comment -%}
  Hush Hush Tan — Press Grid / Featured-In Marquee  (v4 — bulletproof)

  Architecture change vs. v3: each logo is now hardcoded inline in the
  template (not auto-resolved from blocks). This bypasses all the Shopify
  customizer-cache headaches. The strip "just works" with zero block setup.

  Editable in the customizer:
   • Eyebrow text
   • Heading text
   • Per-logo: show/hide toggle

  To swap out a logo image: edit the URL directly in the LOGOS list below.
  Find the publication name and replace the `image` URL string.
  ───────────────────────────────────────────────────────────────────────
{%- endcomment -%}

{%- assign uid = 'press-' | append: section.id -%}

<style>
  #{{ uid }}.press-featured { padding: 56px 0 64px; }
  #{{ uid }} .press-featured__head { text-align: center; margin-bottom: 40px; }
  #{{ uid }} .press-featured__eyebrow {
    display: inline-block;
    font-family: Arial, sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: #7B5EA7;
    margin-bottom: 12px;
  }
  #{{ uid }} .press-featured__title {
    font-family: Georgia, 'Cormorant Garamond', serif;
    font-size: 32px;
    font-weight: normal;
    color: #2C1A4D;
    margin: 0 0 12px;
    line-height: 1.2;
  }
  #{{ uid }} .press-featured__divider {
    display: inline-block;
    width: 64px;
    height: 1px;
    background: #C4A0E0;
  }

  #{{ uid }} .press-strip {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 48px 64px;
    max-width: 1280px;
    margin: 0 auto;
    padding: 24px 24px 8px;
  }

  #{{ uid }} .press-logo {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 80px;
    opacity: 0.85;
    transition: opacity 0.25s ease, transform 0.25s ease;
  }
  #{{ uid }} .press-logo:hover { opacity: 1; transform: translateY(-2px); }
  #{{ uid }} .press-logo img {
    max-height: 60px;
    max-width: 200px;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
  }

  /* Per-logo height tuning — applied to specific logos that need it */
  #{{ uid }} .press-logo--tall img   { max-height: 70px; }
  #{{ uid }} .press-logo--short img  { max-height: 48px; }
  #{{ uid }} .press-logo--wide img   { max-width: 240px; }

  @media (max-width: 768px) {
    #{{ uid }}.press-featured { padding: 40px 0 44px; }
    #{{ uid }} .press-featured__title { font-size: 24px; }
    #{{ uid }} .press-strip { gap: 28px 36px; padding: 16px 16px 4px; }
    #{{ uid }} .press-logo { height: 56px; }
    #{{ uid }} .press-logo img { max-height: 42px; max-width: 140px; }
    #{{ uid }} .press-logo--tall img { max-height: 52px; }
    #{{ uid }} .press-logo--short img { max-height: 34px; }
    #{{ uid }} .press-logo--wide img { max-width: 170px; }
  }
</style>

<section id="{{ uid }}" class="press-featured section">
  <div class="container container--home">
    <div class="press-featured__head">
      {%- if section.settings.eyebrow != blank -%}
        <span class="press-featured__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="press-featured__title">{{ section.settings.heading }}</h2>
      {%- endif -%}
      <span class="press-featured__divider" aria-hidden="true"></span>
    </div>

    <div class="press-strip">

      {%- if section.settings.show_vogue -%}
        <a class="press-logo" href="https://www.vogue.com/article/best-spray-tan-salons-la-new-york-summer-beauty" target="_blank" rel="noopener" aria-label="Featured in Vogue">
          <img src="https://hushhushtan.com/cdn/shop/files/VOGUE_LOGO.svg" alt="Featured in Vogue" loading="lazy">
        </a>
      {%- endif -%}

      {%- if section.settings.show_instyle -%}
        <a class="press-logo press-logo--short" href="https://hushhushtan.com/pages/press" target="_blank" rel="noopener" aria-label="Featured in InStyle">
          <img src="{{ section.settings.instyle_image_url }}" alt="Featured in InStyle" loading="lazy">
        </a>
      {%- endif -%}

      {%- if section.settings.show_dmagazine -%}
        <a class="press-logo press-logo--wide" href="https://www.dmagazine.com/health-fitness/2018/08/hush-hush-tan-dallas/" target="_blank" rel="noopener" aria-label="Featured in D Magazine">
          <img src="{{ section.settings.dmagazine_image_url }}" alt="Featured in D Magazine" loading="lazy">
        </a>
      {%- endif -%}

      {%- if section.settings.show_papercity -%}
        <a class="press-logo press-logo--wide" href="https://www.papercitymag.com/fashion/austin-hush-hush-tan-opens-dallas-tanning-salon-vogue-approved/" target="_blank" rel="noopener" aria-label="Featured in PaperCity">
          <img src="{{ section.settings.papercity_image_url }}" alt="Featured in PaperCity" loading="lazy">
        </a>
      {%- endif -%}

      {%- if section.settings.show_austinmonthly -%}
        <a class="press-logo press-logo--short" href="https://hushhushtan.com/pages/press" target="_blank" rel="noopener" aria-label="Featured in Austin Monthly">
          <img src="{{ section.settings.austinmonthly_image_url }}" alt="Featured in Austin Monthly" loading="lazy">
        </a>
      {%- endif -%}

      {%- if section.settings.show_austinbeauty -%}
        <a class="press-logo" href="http://austinbeautyguide.com/blog/detail.php?id=64" target="_blank" rel="noopener" aria-label="Featured in Austin Beauty Guide">
          <img src="https://hushhushtan.com/cdn/shop/files/austin-beauty-guide_800x.png?v=1614710658" alt="Featured in Austin Beauty Guide" loading="lazy">
        </a>
      {%- endif -%}

      {%- if section.settings.show_tlm -%}
        <a class="press-logo press-logo--wide" href="https://texaslifestylemag.com/lifestyle/the-21-greatest-gifts-for-mom/" target="_blank" rel="noopener" aria-label="Featured in Texas Lifestyle Magazine">
          <img src="https://hushhushtan.com/cdn/shop/files/TLM_10Years_Color-1-1.svg" alt="Featured in Texas Lifestyle Magazine" loading="lazy">
        </a>
      {%- endif -%}

      {%- if section.settings.show_parkcities -%}
        <a class="press-logo" href="https://www.parkcitiespeople.com/business/austin-based-premier-sunless-tanning-salon-to-open-in-the-shops-of-highland-park/" target="_blank" rel="noopener" aria-label="Featured in Park Cities People">
          <img src="{{ section.settings.parkcities_image_url }}" alt="Featured in Park Cities People" loading="lazy">
        </a>
      {%- endif -%}

      {%- if section.settings.show_leader -%}
        <a class="press-logo press-logo--wide" href="https://www.theleadernews.com/business/hush-hush-tan-debuts-upscale-all-natural-tanning-experience-in-the-heights-in-early-2024/article_bbe41048-990a-11ee-859d-4b1ce6de42cc.html" target="_blank" rel="noopener" aria-label="Featured in The Leader">
          <img src="{{ section.settings.leader_image_url }}" alt="Featured in The Leader" loading="lazy">
        </a>
      {%- endif -%}

      {%- if section.settings.show_communityimpact -%}
        <a class="press-logo" href="https://communityimpact.com/houston/heights-river-oaks-montrose/business/2023/12/06/updated-spray-tan-salon-hush-hush-tan-coming-soon-to-m-k-t-in-the-heights/" target="_blank" rel="noopener" aria-label="Featured in Community Impact">
          <img src="https://hushhushtan.com/cdn/shop/files/CI-Logo-2022-Website-White.svg" alt="Featured in Community Impact" loading="lazy">
        </a>
      {%- endif -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Press grid",
  "settings": [
    { "type": "header",   "content": "Heading" },
    { "type": "text",     "id": "eyebrow", "label": "Eyebrow",  "default": "Featured In" },
    { "type": "text",     "id": "heading", "label": "Heading",  "default": "Trusted by Texas. Recognized nationally." },

    { "type": "header",   "content": "Logo Image URLs",
      "info": "Paste the FULL URL of each logo from Shopify Content. Right-click the file in Content → Files → 'Copy link'. The 3 logos with hardcoded URLs (Vogue, Austin Beauty Guide, TLM, Community Impact) don't need this." },

    { "type": "text",     "id": "instyle_image_url",       "label": "InStyle logo URL",            "default": "https://hushhushtan.com/cdn/shop/files/instyle-logo.png" },
    { "type": "text",     "id": "dmagazine_image_url",     "label": "D Magazine logo URL",         "default": "https://hushhushtan.com/cdn/shop/files/d-magazine-logo.png" },
    { "type": "text",     "id": "papercity_image_url",     "label": "PaperCity logo URL",          "default": "https://hushhushtan.com/cdn/shop/files/papercity-magazine-logo.png" },
    { "type": "text",     "id": "austinmonthly_image_url", "label": "Austin Monthly logo URL",     "default": "https://hushhushtan.com/cdn/shop/files/austin-monthly-logo.png" },
    { "type": "text",     "id": "parkcities_image_url",    "label": "Park Cities People logo URL", "default": "https://hushhushtan.com/cdn/shop/files/park-cities-people-logo.png" },
    { "type": "text",     "id": "leader_image_url",        "label": "The Leader logo URL",         "default": "https://hushhushtan.com/cdn/shop/files/theleader-logo.png" },

    { "type": "header",   "content": "Show / Hide Each Logo" },
    { "type": "checkbox", "id": "show_vogue",           "label": "Vogue",                   "default": true },
    { "type": "checkbox", "id": "show_instyle",         "label": "InStyle",                 "default": true },
    { "type": "checkbox", "id": "show_dmagazine",       "label": "D Magazine",              "default": true },
    { "type": "checkbox", "id": "show_papercity",       "label": "PaperCity",               "default": true },
    { "type": "checkbox", "id": "show_austinmonthly",   "label": "Austin Monthly",          "default": true },
    { "type": "checkbox", "id": "show_austinbeauty",    "label": "Austin Beauty Guide",     "default": true },
    { "type": "checkbox", "id": "show_tlm",             "label": "Texas Lifestyle Magazine","default": true },
    { "type": "checkbox", "id": "show_parkcities",      "label": "Park Cities People",      "default": true },
    { "type": "checkbox", "id": "show_leader",          "label": "The Leader",              "default": true },
    { "type": "checkbox", "id": "show_communityimpact", "label": "Community Impact",        "default": true }
  ],
  "presets": [{ "name": "Press grid" }]
}
{% endschema %}