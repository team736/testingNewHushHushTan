{%- comment -%}
  Hush Hush Tan — Press Grid / Featured-In Marquee
  All publications below pulled from https://hushhushtan.com/pages/press
  Logos use Shopify CDN files already uploaded to the store.

  Per-publication URLs and logo files live in the preset so all blocks
  are pre-populated. They remain fully editable in the theme customizer.
{%- endcomment -%}

<section class="press-featured section section-compact section-lavender-pale section-border-y">
  <div class="container container--home">
    <div class="press-featured__head">
      {%- if section.settings.eyebrow != blank -%}
        <span class="press-featured__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="press-featured__title">{{ section.settings.heading }}</h2>
      <span class="press-featured__divider" aria-hidden="true"></span>
    </div>

    <div class="press-marquee">
      <div class="press-track">
        {%- comment -%} Duplicate the group for the marquee scroll effect {%- endcomment -%}
        {%- for i in (1..2) -%}
          <div class="press-group"{% if i == 2 %} aria-hidden="true"{% endif %}>
            {%- for block in section.blocks -%}
              {%- assign name_down = block.settings.name | downcase | strip -%}
              {%- assign alt_text  = 'Featured in ' | append: block.settings.name -%}

              {%- comment -%} Resolve a CDN logo URL based on the publication name.
                  These point to assets already uploaded to the store. Used as a
                  fallback when the merchandiser hasn't set a custom image_picker. {%- endcomment -%}
              {%- assign cdn_logo = '' -%}
              {%- if name_down contains 'vogue' -%}
                {%- assign cdn_logo = 'https://cdn.shopify.com/s/files/1/0329/1109/7991/files/vogue-logo-b_800x.png?v=1613796049' -%}
              {%- elsif name_down contains 'instyle' -%}
                {%- assign cdn_logo = 'https://cdn.shopify.com/s/files/1/0329/1109/7991/files/instyle-logo-b_800x.png?v=1613796049' -%}
              {%- elsif name_down contains 'austin monthly' -%}
                {%- assign cdn_logo = 'https://cdn.shopify.com/s/files/1/0329/1109/7991/files/austin-monthly-logo-b_800x.png?v=1613796049' -%}
              {%- elsif name_down contains 'austin beauty' -%}
                {%- assign cdn_logo = 'https://cdn.shopify.com/s/files/1/0329/1109/7991/files/austin-beauty-guide-logo-b_800x.png?v=1613796049' -%}
              {%- elsif name_down contains 'miss a' -%}
                {%- assign cdn_logo = 'https://cdn.shopify.com/s/files/1/0329/1109/7991/files/miss-a-logo-b_800x.png?v=1613796049' -%}
              {%- elsif name_down contains 'd magazine' -%}
                {%- assign cdn_logo = 'https://cdn.shopify.com/s/files/1/0329/1109/7991/files/d-magazine_800x.png?v=1614710552' -%}
              {%- elsif name_down contains 'papercity' or name_down contains 'paper city' -%}
                {%- assign cdn_logo = 'https://cdn.shopify.com/s/files/1/0329/1109/7991/files/paper-city_800x.png?v=1614710553' -%}
              {%- elsif name_down contains 'texas lifestyle' -%}
                {%- assign cdn_logo = 'https://cdn.shopify.com/s/files/1/0329/1109/7991/files/texas-lifestyle-magazine_800x.png?v=1614710553' -%}
              {%- elsif name_down contains 'park cities' -%}
                {%- assign cdn_logo = 'https://cdn.shopify.com/s/files/1/0329/1109/7991/files/park-cities-people_800x.png?v=1614710658' -%}
              {%- endif -%}

              <div class="press-logo" {{ block.shopify_attributes }}>
                {%- if block.settings.link != blank -%}
                  <a href="{{ block.settings.link }}" class="press-logo__link" target="_blank" rel="noopener" aria-label="{{ alt_text | escape }}">
                {%- endif -%}

                {%- if block.settings.image != blank -%}
                  <img src="{{ block.settings.image | image_url: width: 320 }}"
                       alt="{{ alt_text | escape }}"
                       width="220" height="80" loading="lazy">
                {%- elsif cdn_logo != '' -%}
                  <img src="{{ cdn_logo }}"
                       alt="{{ alt_text | escape }}"
                       width="220" height="80" loading="lazy">
                {%- else -%}
                  <span class="press-logo__placeholder">{{ block.settings.name }}</span>
                {%- endif -%}

                {%- if block.settings.link != blank -%}
                  </a>
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Press grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Featured In" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Trusted by Texas. Recognized nationally." }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        { "type": "text",         "id": "name",  "label": "Publication name", "info": "Used for alt text and to auto-resolve a CDN logo if no image is uploaded." },
        { "type": "image_picker", "id": "image", "label": "Logo image (optional override)", "info": "Leave blank to use the auto-resolved CDN logo for known publications (Vogue, InStyle, Austin Monthly, Austin Beauty Guide, Miss A, D Magazine, PaperCity, Texas Lifestyle, Park Cities People)." },
        { "type": "url",          "id": "link",  "label": "Article URL" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [{
    "name": "Press grid",
    "blocks": [
      {
        "type": "logo",
        "settings": {
          "name": "Vogue",
          "link": "https://www.vogue.com/article/best-spray-tan-salons-la-new-york-summer-beauty"
        }
      },
      {
