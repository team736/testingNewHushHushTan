<section class="press-featured section section--grey">
  <div class="container container--home">
    <div class="press-featured__head">
      {%- if section.settings.eyebrow != blank -%}
        <span class="press-featured__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="press-featured__title">{{ section.settings.heading }}</h2>
      <span class="press-featured__divider" aria-hidden="true"></span>
    </div>

    <div class="press-marquee">
      <div class="press-track">
        {%- for i in (1..2) -%}
          <div class="press-group"{% if i == 2 %} aria-hidden="true"{% endif %}>
            {%- for block in section.blocks -%}
              {%- assign name_down = block.settings.name | downcase -%}
              {%- assign alt_text = 'Featured in ' | append: block.settings.name -%}
              <div class="press-logo" {{ block.shopify_attributes }}>
                {%- if block.settings.image != blank -%}
                  {%- if block.settings.link != blank -%}<a href="{{ block.settings.link }}" class="press-logo__link">{%- endif -%}
                  <img src="{{ block.settings.image | image_url: width: 320 }}" alt="{{ alt_text | escape }}" width="220" height="80" loading="lazy">
                  {%- if block.settings.link != blank -%}</a>{%- endif -%}
                {%- else -%}
                  {%- if name_down contains 'vogue' -%}
                    <img src="{{ 'press-vogue.png' | asset_url }}" alt="{{ alt_text | escape }}" width="220" height="80" loading="lazy">
                  {%- elsif name_down contains 'instyle' -%}
                    <img src="{{ 'press-instyle.png' | asset_url }}" alt="{{ alt_text | escape }}" width="220" height="80" loading="lazy">
                  {%- elsif name_down contains 'austin' -%}
                    <img src="{{ 'press-austin-monthly.png' | asset_url }}" alt="{{ alt_text | escape }}" width="220" height="80" loading="lazy">
                  {%- else -%}
                    <span class="press-logo__placeholder">{{ block.settings.name }}</span>
                  {%- endif -%}
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Press grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Hush Hush Tan is featured in" }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        { "type": "text", "id": "name", "label": "Name" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [{
    "name": "Press grid",
    "blocks": [
      { "type": "logo", "settings": { "name": "Vogue" } },
      { "type": "logo", "settings": { "name": "Miss A" } },
      { "type": "logo", "settings": { "name": "Austin Monthly" } },
      { "type": "logo", "settings": { "name": "Austin Beauty Guide" } },
      { "type": "logo", "settings": { "name": "InStyle" } },
      { "type": "logo", "settings": { "name": "Vogue" } }
    ]
  }]
}
{% endschema %}
