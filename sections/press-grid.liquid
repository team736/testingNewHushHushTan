          "link": "https://hushhushtan.com/pages/press"
        }
      },
      {
        "type": "logo",
        "settings": {
          "name": "D Magazine",
          "link": "https://www.dmagazine.com/health-fitness/2018/08/hush-hush-tan-dallas/"
        }
      },
      {
        "type": "logo",
        "settings": {
          "name": "PaperCity",
          "link": "https://www.papercitymag.com/fashion/austin-hush-hush-tan-opens-dallas-tanning-salon-vogue-approved/"
        }
      },
      {
        "type": "logo",
        "settings": {
