{%- comment -%}
  Hush Hush Tan — Press Grid / Featured-In Marquee  (v6 — invert applied at parent)

  Each logo is its own block. In the customizer you can:
   • Set the publication name (used for alt text)
   • Pick the logo image directly from Shopify Content
   • Set the article URL
   • Pick the logo size: xs / sm / md / lg / xl
   • Toggle "Invert color" for white-on-transparent logos

  Invert is applied via inline style on the OUTER .press-logo div, not the img.
  Filters inherit through descendants, including anchors. This bypasses any
  theme CSS that could override the img-level rule.
{%- endcomment -%}

{%- assign uid = 'press-' | append: section.id -%}

<style>
  #{{ uid }}.press-featured { padding: 56px 0 64px; }
  #{{ uid }} .press-featured__head { text-align: center; margin-bottom: 40px; }
  #{{ uid }} .press-featured__eyebrow {
    display: inline-block;
    font-family: Arial, sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: #7B5EA7;
    margin-bottom: 12px;
  }
  #{{ uid }} .press-featured__title {
    font-family: Georgia, 'Cormorant Garamond', serif;
    font-size: 32px;
    font-weight: normal;
    color: #2C1A4D;
    margin: 0 0 12px;
    line-height: 1.2;
  }
  #{{ uid }} .press-featured__divider {
    display: inline-block;
    width: 64px;
    height: 1px;
    background: #C4A0E0;
  }

  #{{ uid }} .press-strip {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 48px 64px;
    max-width: 1280px;
    margin: 0 auto;
    padding: 24px 24px 8px;
  }

  #{{ uid }} .press-logo {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 96px;
    opacity: 0.85;
    transition: opacity 0.25s ease, transform 0.25s ease;
  }
  #{{ uid }} .press-logo:hover { opacity: 1; transform: translateY(-2px); }
  #{{ uid }} a.press-logo { text-decoration: none; color: inherit; }
  #{{ uid }} .press-logo img {
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
  }
  #{{ uid }} .press-logo__placeholder {
    font-family: Georgia, 'Cormorant Garamond', serif;
    font-size: 24px;
    color: #51217C;
    letter-spacing: 0.04em;
  }

  /* Per-logo size */
  #{{ uid }} .press-logo--xs img { max-height: 40px; max-width: 140px; }
  #{{ uid }} .press-logo--sm img { max-height: 56px; max-width: 170px; }
  #{{ uid }} .press-logo--md img { max-height: 72px; max-width: 210px; }
  #{{ uid }} .press-logo--lg img { max-height: 88px; max-width: 250px; }
  #{{ uid }} .press-logo--xl img { max-height: 110px; max-width: 290px; }

  @media (max-width: 768px) {
    #{{ uid }}.press-featured { padding: 40px 0 44px; }
    #{{ uid }} .press-featured__title { font-size: 24px; }
    #{{ uid }} .press-strip { gap: 28px 36px; padding: 16px 16px 4px; }
    #{{ uid }} .press-logo { height: 64px; }
    #{{ uid }} .press-logo--xs img { max-height: 28px; max-width: 100px; }
    #{{ uid }} .press-logo--sm img { max-height: 40px; max-width: 120px; }
    #{{ uid }} .press-logo--md img { max-height: 52px; max-width: 150px; }
    #{{ uid }} .press-logo--lg img { max-height: 64px; max-width: 180px; }
    #{{ uid }} .press-logo--xl img { max-height: 78px; max-width: 210px; }
  }
</style>

<section id="{{ uid }}" class="press-featured section">
  <div class="container container--home">
    <div class="press-featured__head">
      {%- if section.settings.eyebrow != blank -%}
        <span class="press-featured__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="press-featured__title">{{ section.settings.heading }}</h2>
      {%- endif -%}
      <span class="press-featured__divider" aria-hidden="true"></span>
    </div>

    <div class="press-strip">
      {%- for block in section.blocks -%}
        {%- assign alt_text  = 'Featured in ' | append: block.settings.name -%}
        {%- assign size_class = 'press-logo--' | append: block.settings.size -%}

        {%- comment -%} Render the WHOLE logo wrapper as the <a> when linked,
            or as a <div> when not. The img is always a direct child of the
            outer element — no nested anchor structure for the invert filter to lose. {%- endcomment -%}

        {%- assign wrapper_style = '' -%}
        {%- if block.settings.invert_color -%}
          {%- assign wrapper_style = 'filter: invert(1); -webkit-filter: invert(1);' -%}
        {%- endif -%}

        {%- if block.settings.link != blank -%}
          <a class="press-logo {{ size_class }}"
             href="{{ block.settings.link }}"
             target="_blank"
             rel="noopener"
             aria-label="{{ alt_text | escape }}"
             {% if wrapper_style != blank %}style="{{ wrapper_style }}"{% endif %}
             {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 600 }}"
                   alt="{{ alt_text | escape }}"
                   loading="lazy">
            {%- else -%}
              <span class="press-logo__placeholder">{{ block.settings.name }}</span>
            {%- endif -%}
          </a>
        {%- else -%}
          <div class="press-logo {{ size_class }}"
               {% if wrapper_style != blank %}style="{{ wrapper_style }}"{% endif %}
               {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 600 }}"
                   alt="{{ alt_text | escape }}"
                   loading="lazy">
            {%- else -%}
              <span class="press-logo__placeholder">{{ block.settings.name }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Press grid",
  "settings": [
    { "type": "header", "content": "Heading" },
    { "type": "text",   "id": "eyebrow", "label": "Eyebrow", "default": "Featured In" },
    { "type": "text",   "id": "heading", "label": "Heading", "default": "Trusted by Texas. Recognized nationally." }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        { "type": "text",         "id": "name",  "label": "Publication name", "info": "Used for alt text. Example: Vogue" },
        { "type": "image_picker", "id": "image", "label": "Logo image",       "info": "Select directly from your Shopify Content files." },
        { "type": "url",          "id": "link",  "label": "Article URL" },
        {
          "type": "select", "id": "size", "label": "Logo size",
          "info": "md = default. Bump up for tall/script logos. Reduce for wide wordmarks that already feel big.",
          "options": [
            { "value": "xs", "label": "Extra small" },
            { "value": "sm", "label": "Small" },
            { "value": "md", "label": "Medium — default" },
            { "value": "lg", "label": "Large" },
            { "value": "xl", "label": "Extra large" }
          ],
          "default": "md"
        },
        {
          "type": "checkbox", "id": "invert_color", "label": "Invert color (for white logos)",
          "info": "Turn ON if the logo file is white-on-transparent. Flips white to black so it shows on light backgrounds. Only use on pure monochrome white logos — distorts color logos.",
          "default": false
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [{
    "name": "Press grid",
    "blocks": [
      { "type": "logo", "settings": { "name": "Vogue",                    "size": "md", "link": "https://www.vogue.com/article/best-spray-tan-salons-la-new-york-summer-beauty" } },
      { "type": "logo", "settings": { "name": "InStyle",                  "size": "md", "link": "https://hushhushtan.com/pages/press" } },
      { "type": "logo", "settings": { "name": "D Magazine",               "size": "lg", "link": "https://www.dmagazine.com/health-fitness/2018/08/hush-hush-tan-dallas/" } },
      { "type": "logo", "settings": { "name": "PaperCity",                "size": "lg", "link": "https://www.papercitymag.com/fashion/austin-hush-hush-tan-opens-dallas-tanning-salon-vogue-approved/" } },
      { "type": "logo", "settings": { "name": "Austin Monthly",           "size": "md", "link": "https://hushhushtan.com/pages/press" } },
      { "type": "logo", "settings": { "name": "Austin Beauty Guide",      "size": "lg", "link": "http://austinbeautyguide.com/blog/detail.php?id=64" } },
      { "type": "logo", "settings": { "name": "Texas Lifestyle Magazine", "size": "lg", "link": "https://texaslifestylemag.com/lifestyle/the-21-greatest-gifts-for-mom/" } },
      { "type": "logo", "settings": { "name": "Park Cities People",       "size": "lg", "link": "https://www.parkcitiespeople.com/business/austin-based-premier-sunless-tanning-salon-to-open-in-the-shops-of-highland-park/" } },
      { "type": "logo", "settings": { "name": "The Leader",               "size": "lg", "link": "https://www.theleadernews.com/business/hush-hush-tan-debuts-upscale-all-natural-tanning-experience-in-the-heights-in-early-2024/article_bbe41048-990a-11ee-859d-4b1ce6de42cc.html" } },
      { "type": "logo", "settings": { "name": "Community Impact",         "size": "md", "invert_color": true, "link": "https://communityimpact.com/houston/heights-river-oaks-montrose/business/2023/12/06/updated-spray-tan-salon-hush-hush-tan-coming-soon-to-m-k-t-in-the-heights/" } }
    ]
  }]
}
{% endschema %}