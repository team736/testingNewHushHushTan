{%- comment -%}
  Hush Hush Tan — Press Grid / Featured-In Marquee  (v3 — verified logo + article mapping)

  Every logo below links to its specific article on the live press page:
  https://hushhushtan.com/pages/press

  Logo source files are all in Shopify Content (admin → Content → Files).
  Visual sizing is controlled by inline CSS (max-height + per-logo scale)
  so each logo lands at the same optical weight regardless of source dimensions.

  ── FILENAME SANITY-CHECK ──────────────────────────────────────────────
  The 3 SVGs that were confirmed uploaded:
    • VOGUE_LOGO.svg
    • TLM_10Years_Color-1-1.svg
    • CI-Logo-2022-Website-White.svg   (NOTE: white-on-transparent, may be invisible on lavender)

  The 6 logos shown in chat (PNG/SVG, not yet confirmed in uploads folder):
    • The Leader              → assumed: theleader-logo.png
    • Park Cities People      → assumed: park-cities-people-logo.png
    • Austin Monthly          → assumed: austin-monthly-logo.png
    • PaperCity Magazine      → assumed: papercity-magazine-logo.png
    • D Magazine              → assumed: d-magazine-logo.png
    • InStyle                 → assumed: instyle-logo.png

  IF YOUR ACTUAL UPLOADED FILENAMES DIFFER, just edit the URLs in the
  `case "name"` block below. Each one is on its own line, easy find/replace.
  ───────────────────────────────────────────────────────────────────────
{%- endcomment -%}

{%- assign uid = 'press-' | append: section.id -%}
{%- assign cdn_base = 'https://hushhushtan.com/cdn/shop/files/' -%}

<style>
  #{{ uid }} .press-marquee { padding: 8px 0 16px; }
  #{{ uid }} .press-track   { display: flex; align-items: center; justify-content: center; }
  #{{ uid }} .press-group {
    display: flex; align-items: center; justify-content: center;
    flex-wrap: wrap;
    gap: 48px 64px;
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
  }
  #{{ uid }} .press-logo {
    flex: 0 0 auto;
    display: flex; align-items: center; justify-content: center;
    height: 96px;
    opacity: 0.78;
    transition: opacity 0.25s ease, transform 0.25s ease;
  }
  #{{ uid }} .press-logo:hover { opacity: 1; transform: translateY(-2px); }
  #{{ uid }} .press-logo__link { display: inline-flex; align-items: center; }
  #{{ uid }} .press-logo img {
    max-height: 80px;
    width: auto; height: auto;
    max-width: 260px;
    object-fit: contain;
    display: block;
  }
  #{{ uid }} .press-logo__placeholder {
    font-family: Georgia, 'Cormorant Garamond', serif;
    font-size: 24px; color: #51217C; letter-spacing: 0.04em;
  }

  /* Per-logo scale: account for thin/script/boxed marks */
  #{{ uid }} .press-logo--xs img { max-height: 50px; }
  #{{ uid }} .press-logo--sm img { max-height: 65px; }
  #{{ uid }} .press-logo--md img { max-height: 80px; }
  #{{ uid }} .press-logo--lg img { max-height: 96px; }
  #{{ uid }} .press-logo--xl img { max-height: 112px; }

  @media (max-width: 768px) {
    #{{ uid }} .press-group { gap: 28px 36px; padding: 0 16px; }
    #{{ uid }} .press-logo { height: 64px; }
    #{{ uid }} .press-logo img { max-height: 54px; max-width: 180px; }
    #{{ uid }} .press-logo--xs img { max-height: 36px; }
    #{{ uid }} .press-logo--sm img { max-height: 46px; }
    #{{ uid }} .press-logo--md img { max-height: 54px; }
    #{{ uid }} .press-logo--lg img { max-height: 64px; }
    #{{ uid }} .press-logo--xl img { max-height: 74px; }
  }
</style>

<section id="{{ uid }}" class="press-featured section section-compact section-lavender-pale section-border-y">
  <div class="container container--home">
    <div class="press-featured__head">
      {%- if section.settings.eyebrow != blank -%}
        <span class="press-featured__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="press-featured__title">{{ section.settings.heading }}</h2>
      <span class="press-featured__divider" aria-hidden="true"></span>
    </div>

    <div class="press-marquee">
      <div class="press-track">
        <div class="press-group">
          {%- for block in section.blocks -%}
            {%- assign name_down = block.settings.name | downcase | strip -%}
            {%- assign alt_text  = 'Featured in ' | append: block.settings.name -%}

            {%- comment -%} Auto-resolve logo URL from Shopify Content based on publication name.
                Override with the image_picker on any individual block. {%- endcomment -%}
            {%- assign cdn_logo = '' -%}
            {%- if name_down contains 'vogue' -%}
              {%- assign cdn_logo = cdn_base | append: 'VOGUE_LOGO.svg' -%}
            {%- elsif name_down contains 'instyle' -%}
              {%- assign cdn_logo = cdn_base | append: 'instyle-logo.png' -%}
            {%- elsif name_down contains 'd magazine' or name_down contains 'd-magazine' -%}
              {%- assign cdn_logo = cdn_base | append: 'd-magazine-logo.png' -%}
            {%- elsif name_down contains 'papercity' or name_down contains 'paper city' -%}
              {%- assign cdn_logo = cdn_base | append: 'papercity-magazine-logo.png' -%}
            {%- elsif name_down contains 'austin monthly' -%}
              {%- assign cdn_logo = cdn_base | append: 'austin-monthly-logo.png' -%}
            {%- elsif name_down contains 'austin beauty' -%}
              {%- assign cdn_logo = cdn_base | append: 'austin-beauty-guide_800x.png?v=1614710658' -%}
            {%- elsif name_down contains 'texas lifestyle' or name_down contains 'tlm' -%}
              {%- assign cdn_logo = cdn_base | append: 'TLM_10Years_Color-1-1.svg' -%}
            {%- elsif name_down contains 'park cities' -%}
              {%- assign cdn_logo = cdn_base | append: 'park-cities-people-logo.png' -%}
            {%- elsif name_down contains 'community impact' -%}
              {%- assign cdn_logo = cdn_base | append: 'CI-Logo-2022-Website-White.svg' -%}
            {%- elsif name_down contains 'leader' -%}
              {%- assign cdn_logo = cdn_base | append: 'theleader-logo.png' -%}
            {%- elsif name_down contains 'voyage' -%}
              {%- comment -%} VoyageHouston has no logo file — uses text placeholder {%- endcomment -%}
              {%- assign cdn_logo = '' -%}
            {%- endif -%}

            {%- assign size_class = 'press-logo--' | append: block.settings.size -%}

            <div class="press-logo {{ size_class }}" {{ block.shopify_attributes }}>
              {%- if block.settings.link != blank -%}
                <a href="{{ block.settings.link }}" class="press-logo__link" target="_blank" rel="noopener" aria-label="{{ alt_text | escape }}">
              {%- endif -%}

              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 520 }}"
                     alt="{{ alt_text | escape }}"
                     width="520" height="180" loading="lazy">
              {%- elsif cdn_logo != '' -%}
                <img src="{{ cdn_logo }}"
                     alt="{{ alt_text | escape }}"
                     width="520" height="180" loading="lazy">
              {%- else -%}
                <span class="press-logo__placeholder">{{ block.settings.name }}</span>
              {%- endif -%}

              {%- if block.settings.link != blank -%}
                </a>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Press grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Featured In" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Trusted by Texas. Recognized nationally." }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        { "type": "text",         "id": "name",  "label": "Publication name", "info": "Used for alt text and to auto-resolve a logo from Shopify Content." },
