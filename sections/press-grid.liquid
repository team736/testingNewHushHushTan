<section class="section section--tight">
  <div class="container">
    <div class="text-center" style="margin-bottom: 32px;">
      {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      <h2 class="mb-0" style="font-size: 1.3rem; letter-spacing: .12em; text-transform: uppercase; font-family: var(--font-body); font-weight: 400; color: var(--muted);">{{ section.settings.heading }}</h2>
    </div>
    <div class="press-grid">
      {%- for block in section.blocks -%}
        <div class="press-grid__item" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {%- if block.settings.link != blank -%}<a href="{{ block.settings.link }}">{%- endif -%}
            <img src="{{ block.settings.image | image_url: width: 240 }}" alt="{{ block.settings.name }}" width="160" height="60" style="height:auto;max-width:160px;" loading="lazy">
            {%- if block.settings.link != blank -%}</a>{%- endif -%}
          {%- else -%}
            {%- assign name_down = block.settings.name | downcase -%}
            {%- if name_down contains 'vogue' -%}
              <img src="{{ 'press-vogue.png' | asset_url }}" alt="Vogue" width="160" height="60" style="height:auto;max-width:160px;" loading="lazy">
            {%- elsif name_down contains 'instyle' -%}
              <img src="{{ 'press-instyle.png' | asset_url }}" alt="InStyle" width="160" height="60" style="height:auto;max-width:160px;" loading="lazy">
            {%- elsif name_down contains 'austin' or name_down contains 'texas' -%}
              <img src="{{ 'press-austin-monthly.png' | asset_url }}" alt="Austin Monthly" width="160" height="60" style="height:auto;max-width:160px;" loading="lazy">
            {%- else -%}
              <div style="font-family: var(--font-heading); font-size: 1.3rem; color: var(--muted); text-align: center;">{{ block.settings.name }}</div>
            {%- endif -%}
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Press grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Hush Hush Tan is featured in" }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        { "type": "text", "id": "name", "label": "Name" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [{
    "name": "Press grid",
    "blocks": [
      { "type": "logo", "settings": { "name": "Vogue" } },
      { "type": "logo", "settings": { "name": "InStyle" } },
      { "type": "logo", "settings": { "name": "Allure" } },
      { "type": "logo", "settings": { "name": "Texas Monthly" } },
      { "type": "logo", "settings": { "name": "Refinery29" } },
      { "type": "logo", "settings": { "name": "Cosmopolitan" } }
    ]
  }]
}
{% endschema %}
