<section class="section">
  <div class="container">
    <div class="final-cta">
      {%- if section.settings.eyebrow != blank -%}<span class="eyebrow" style="color:rgba(255,255,255,.8);">{{ section.settings.eyebrow }}</span>{%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.text != blank -%}<p>{{ section.settings.text }}</p>{%- endif -%}
      <div class="flex" style="justify-content: center;">
        {%- if section.settings.cta1_text != blank -%}<a href="{{ section.settings.cta1_url | default: '#' }}" class="btn">{{ section.settings.cta1_text }}</a>{%- endif -%}
        {%- if section.settings.cta2_text != blank -%}<a href="{{ section.settings.cta2_url | default: '#' }}" class="btn btn--outline" style="background:transparent;color:#fff;border-color:#fff;">{{ section.settings.cta2_text }}</a>{%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Final CTA",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Ready to glow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Book your Custom Glow today" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Three Texas locations. Mixed for your undertones." },
    { "type": "text", "id": "cta1_text", "label": "Primary CTA text", "default": "Choose Your Location" },
    { "type": "url", "id": "cta1_url", "label": "Primary CTA URL" },
    { "type": "text", "id": "cta2_text", "label": "Secondary CTA text", "default": "Shop Products" },
    { "type": "url", "id": "cta2_url", "label": "Secondary CTA URL" }
  ],
  "presets": [{ "name": "Final CTA" }]
}
{% endschema %}
