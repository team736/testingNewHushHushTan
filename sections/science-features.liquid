{%- liquid
  assign learn_url = section.settings.cta_url
  if learn_url == blank
    assign learn_url = '/pages/about-us'
  endif
  assign image_fallback = section.settings.image_fallback | default: 'hht-product-shelf.jpg'
-%}

<section class="hht-science-section" id="science-features-{{ section.id }}">
  <div class="container container--home hht-science-inner">
    <div class="hht-science-hero">
      <div class="hht-science-copy">
        {%- if section.settings.eyebrow != blank -%}
          <span class="hht-science-eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2>
          {{ section.settings.headline_line1 }}<br>
          {{ section.settings.headline_line2_before }}<em>{{ section.settings.headline_line2_emphasis }}</em>
        </h2>
        {%- if section.settings.subtext != blank -%}
          <p>{{ section.settings.subtext }}</p>
        {%- endif -%}
        {%- if section.settings.cta_text != blank -%}
          <a href="{{ learn_url }}" class="hht-science-link">{{ section.settings.cta_text }} {% render 'icon', name: 'arrow-right' %}</a>
        {%- endif -%}
      </div>

      <div class="hht-science-media">
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 1200 }}"
            srcset="{{ section.settings.image | image_url: width: 800 }} 800w, {{ section.settings.image | image_url: width: 1200 }} 1200w"
            sizes="(min-width: 900px) 520px, 100vw"
            alt="{{ section.settings.image.alt | default: 'Hush Hush Tan aftercare products' | escape }}"
            width="1200"
            height="1200"
            loading="lazy">
        {%- else -%}
          <img
            src="{{ image_fallback | asset_url }}"
            alt="Hush Hush Tan aftercare products on studio shelf"
            width="1200"
            height="1200"
            loading="lazy">
        {%- endif -%}
      </div>
    </div>

    <div class="hht-feature-cards">
      {%- for block in section.blocks -%}
        <article class="hht-feature-card" {{ block.shopify_attributes }}>
          <div class="hht-icon-wrap">
            <div class="hht-icon">
              {% render 'science-feature-icon', icon: block.settings.icon %}
            </div>
          </div>
          {%- if block.settings.title != blank -%}
            <h3>{{ block.settings.title }}</h3>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <p>{{ block.settings.text }}</p>
          {%- endif -%}
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Science feature section",
  "tag": "section",
  "class": "hht-science-section-wrap",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Hush Hush Standard"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Feature image",
      "info": "Square crop recommended. Default uses hht-product-shelf.jpg."
    },
    {
      "type": "text",
      "id": "image_fallback",
      "label": "Fallback asset filename",
      "default": "hht-product-shelf.jpg"
    },
    {
      "type": "text",
      "id": "headline_line1",
      "label": "Headline line 1",
      "default": "Clean, Conscious,"
    },
    {
      "type": "text",
      "id": "headline_line2_before",
      "label": "Headline line 2 (before accent)",
      "default": "Performance "
    },
    {
      "type": "text",
      "id": "headline_line2_emphasis",
      "label": "Headline accent (lavender italic)",
      "default": "Science."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Unreservedly honest products that truly work, while being kind to skin and the planet. We bridge the gap between luxury skincare and professional bronzing."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Link text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Link URL"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Feature card",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "sparkle", "label": "Custom color" },
            { "value": "book", "label": "Luxury formula" },
            { "value": "award", "label": "Award" },
            { "value": "shield", "label": "Shield check" }
          ],
          "default": "sparkle"
        },
        { "type": "text", "id": "title", "label": "Title", "default": "Custom Color" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Every shade hand-mixed to flatter your unique undertones for a seamless, natural finish." }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Science feature section",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "icon": "sparkle",
            "title": "Custom Color",
            "text": "Every shade hand-mixed to flatter your unique undertones for a seamless, natural finish."
          }
        },
        {
          "type": "card",
          "settings": {
            "icon": "book",
            "title": "Luxury Formula",
            "text": "Clean, vegan, and paraben-free solutions enriched with antioxidants made to nourish and hydrate."
          }
        },
        {
          "type": "card",
          "settings": {
            "icon": "award",
            "title": "Award Winning",
            "text": "Voted best spray tan in Texas year after year by leading publications and our loyal community."
          }
        },
        {
          "type": "card",
          "settings": {
            "icon": "shield",
            "title": "Trusted Since 2007",
            "text": "Nearly two decades perfecting the art of the glow with precision, passion, and professional care."
          }
        }
      ]
    }
  ]
}
{% endschema %}
