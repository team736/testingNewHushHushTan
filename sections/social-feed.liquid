{%- liquid
  assign fallbacks = 'hht-moment-group.jpg,hht-moment-prep.jpg,hht-glow-editorial.jpg,hht-moment-aftercare.jpg,hht-reception.jpg,hht-glow-wall-art.jpg' | split: ','
-%}

<section class="section section-compact hht-social" aria-label="{{ section.settings.heading | escape }}">
  <div class="container container--home">
    <div class="section-head">
      {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.handle != blank -%}
        <p class="section-head__sub">
          <a href="{{ section.settings.profile_url }}" class="hht-social__handle" target="_blank" rel="noopener">{{ section.settings.handle }}</a>
        </p>
      {%- endif -%}
    </div>

    <div class="hht-social__grid">
      {%- for block in section.blocks -%}
        {%- assign fb = fallbacks[forloop.index0] | default: 'hht-glow-wall.jpg' -%}
        {%- assign link = block.settings.link | default: section.settings.profile_url -%}
        <a class="hht-social__tile" href="{{ link }}" target="_blank" rel="noopener" {{ block.shopify_attributes }} aria-label="View on Instagram">
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 500 }}" alt="Hush Hush Tan on social" width="500" height="500" loading="lazy">
          {%- else -%}
            <img src="{{ fb | asset_url }}" alt="Hush Hush Tan on social" width="500" height="500" loading="lazy">
          {%- endif -%}
          <span class="hht-social__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.2" cy="6.8" r="1" fill="currentColor" stroke="none"/></svg>
          </span>
        </a>
      {%- endfor -%}
    </div>

    {%- if section.settings.cta_text != blank and section.settings.profile_url != blank -%}
      <div class="hht-social__cta">
        <a href="{{ section.settings.profile_url }}" class="btn btn--pill btn--outline" target="_blank" rel="noopener">{{ section.settings.cta_text }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Social media feed",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "@HushHushTan" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Follow The Glow" },
    { "type": "text", "id": "handle", "label": "Handle text", "default": "@hushhushtan" },
    { "type": "url", "id": "profile_url", "label": "Instagram profile URL" },
    { "type": "text", "id": "cta_text", "label": "Button text", "default": "Follow Us on Instagram" }
  ],
  "blocks": [
    {
      "type": "post",
      "name": "Post",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "url", "id": "link", "label": "Post link" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [{
    "name": "Social media feed",
    "blocks": [
      { "type": "post" }, { "type": "post" }, { "type": "post" },
      { "type": "post" }, { "type": "post" }, { "type": "post" }
    ]
  }]
}
{% endschema %}
