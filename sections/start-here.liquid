{%- liquid
  assign img = section.settings.image
-%}

<section class="section hht-starthere" aria-label="{{ section.settings.heading | escape }}">
  <div class="container container--home">
    <div class="hht-starthere__panel">
      <div class="hht-starthere__media">
        {%- if img != blank -%}
          <img src="{{ img | image_url: width: 900 }}" alt="Hush Hush Tan Custom Glow" width="900" height="1000" loading="lazy">
        {%- else -%}
          <img src="{{ 'hht-glow-editorial.jpg' | asset_url }}" alt="Hush Hush Tan Custom Glow" width="900" height="1000" loading="lazy">
        {%- endif -%}
      </div>

      <div class="hht-starthere__body">
        {%- if section.settings.eyebrow != blank -%}
          <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="hht-starthere__title">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.feature != blank -%}
          <p class="hht-starthere__feature">{{ section.settings.feature }}</p>
        {%- endif -%}
        {%- if section.settings.text != blank -%}
          <p class="hht-starthere__text">{{ section.settings.text }}</p>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <ul class="hht-starthere__list">
            {%- for block in section.blocks -%}
              <li class="hht-starthere__item" {{ block.shopify_attributes }}>
                <span class="hht-starthere__tick" aria-hidden="true">
                  <svg viewBox="0 0 20 20" width="14" height="14" focusable="false"><path d="M7.6 13.4L4 9.8l1.3-1.3 2.3 2.3 6-6L15 6z" fill="currentColor"/></svg>
                </span>
                <span>{{ block.settings.text }}</span>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- if section.settings.cta_text != blank and section.settings.cta_url != blank -%}
          <div class="hht-starthere__cta">
            <a href="{{ section.settings.cta_url }}" class="btn btn--pill"{% if section.settings.cta_url contains '://' %} target="_blank" rel="noopener"{% endif %}>{{ section.settings.cta_text }}</a>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "New to HHT — Start here",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "First Time?" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "New to HHT? Start Here" },
    { "type": "text", "id": "feature", "label": "Featured service", "default": "The Custom Glow — our signature first-time experience." },
    { "type": "textarea", "id": "text", "label": "Supporting copy", "default": "New to spray tanning? The Custom Glow is the perfect place to begin. Your artist hand-mixes a shade to match your skin tone and undertones for a natural, streak-free finish — no orange, no guesswork. Just tell us your occasion and we'll take care of the rest." },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "cta_text", "label": "Button text", "default": "Book Now" },
    { "type": "url", "id": "cta_url", "label": "Button URL" }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "Highlight point",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Color-matched to your skin tone" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [{
    "name": "New to HHT — Start here",
    "blocks": [
      { "type": "point", "settings": { "text": "Hand-mixed, color-matched shade" } },
      { "type": "point", "settings": { "text": "Natural, streak-free finish — never orange" } },
      { "type": "point", "settings": { "text": "Perfect for your first-ever spray tan" } }
    ]
  }]
}
{% endschema %}
