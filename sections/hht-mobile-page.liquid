    { "type": "textarea", "id": "area_lead", "label": "Lead text", "default": "Mobile tanning is currently offered through the Austin studio only. A travel fee applies for eligible locations more than ten miles from the studio, and a separate hotel travel fee may apply." },
    { "type": "text", "id": "area_cta1_label", "label": "Outline button label", "default": "View Austin Location" },
    { "type": "text", "id": "area_cta1_link", "label": "Outline button link", "default": "/pages/austin" },
    { "type": "text", "id": "area_cta2_label", "label": "Booking button label", "default": "Book Mobile Tanning", "info": "Links to the booking URL above." },
    { "type": "image_picker", "id": "area_image", "label": "Image" },
