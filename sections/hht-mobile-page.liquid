    { "type": "text", "id": "steps_heading", "label": "Heading", "default": "Five Steps to Mobile Glow" },
    { "type": "header", "content": "Service Area" },
    { "type": "text", "id": "area_eyebrow", "label": "Eyebrow", "default": "Service Area" },
