    { "type": "text", "id": "default_city", "label": "Default city key", "default": "austin", "info": "Used by the ?location= deep link (austin, dallas, houston)." },
    { "type": "header", "content": "Hero" },
    { "type": "text", "id": "hero_eyebrow", "label": "Hero eyebrow", "default": "Group Experiences" },
