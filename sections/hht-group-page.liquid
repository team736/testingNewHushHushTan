{%- comment -%} Group Tanning & Mimosas — schema-driven section (customizer editable) {%- endcomment -%}
{%- liquid
  assign default_city = section.settings.default_city | default: 'austin'
-%}

{{ 'hht-supporting.css' | asset_url | stylesheet_tag }}

<div class="hht-sp" id="hht-group-page" data-hht-city-root data-default-city="{{ default_city }}">
  {%- comment -%} Hero {%- endcomment -%}
  <section class="hht-sp__section">
    <div class="hht-sp__wrap">
      <div class="hht-sp-hero__panel">
        <div class="hht-sp-hero__body">
          <span class="hht-sp__eyebrow">{{ section.settings.hero_eyebrow }}</span>
          <h1 class="hht-sp__h1">{{ section.settings.hero_heading }}</h1>
          <p class="hht-sp__lead">{{ section.settings.hero_lead }}</p>
          <div class="hht-sp__ctas">
            {%- if section.settings.hero_cta1_label != blank %}
            <a href="{{ section.settings.hero_cta1_link }}" class="btn">{{ section.settings.hero_cta1_label }}</a>
            {%- endif -%}
            {%- if section.settings.hero_cta2_label != blank %}
            <a href="{{ section.settings.hero_cta2_link }}" class="btn btn--outline">{{ section.settings.hero_cta2_label }}</a>
            {%- endif %}
          </div>
        </div>
        <div class="hht-sp-hero__media">
          {%- if section.settings.hero_image %}
          <img src="{{ section.settings.hero_image | image_url: width: 900 }}" alt="{{ section.settings.hero_image_alt }}" width="900" height="1100" loading="eager">
          {%- else %}
          <img src="{{ 'hht-moment-group.jpg' | asset_url }}" alt="{{ section.settings.hero_image_alt }}" width="900" height="1100" loading="eager">
          {%- endif %}
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} City pricing — Core Services pricing card style {%- endcomment -%}
  <section class="hht-sp__section hht-sp__section--lavender" id="group-pricing">
    <div class="hht-sp__wrap">
      <div class="hht-glow-list">
        <div class="hht-glow-list__card">
          <div class="hht-glow-list__card-head">
            {%- if section.settings.pricing_icon %}
            <img
              class="hht-glow-list__icon"
              src="{{ section.settings.pricing_icon | image_url: width: 112 }}"
              alt=""
              width="56"
              height="56"
              loading="lazy"
            >
            {%- else %}
            <img
              class="hht-glow-list__icon"
              src="{{ 'icon-group-experiences-heart.png' | asset_url }}"
              alt=""
              width="56"
              height="56"
              loading="lazy"
            >
            {%- endif %}
            <h2 class="hht-glow-list__card-title">{{ section.settings.pricing_title }}</h2>
            <p class="hht-glow-list__card-sub">{{ section.settings.pricing_sub }}</p>
            <p class="hht-glow-list__card-lead">{{ section.settings.pricing_lead }}</p>
          </div>
          <div class="hht-glow-list__rows">
            {%- for block in section.blocks -%}
              {%- if block.type == 'city' %}
            <article class="hht-glow-list__row" id="group-panel-{{ block.settings.key }}" {{ block.shopify_attributes }}>
              <div class="hht-glow-list__row-main">
                <div class="hht-glow-list__row-head">
                  <h3 class="hht-glow-list__row-title">{{ block.settings.name }}</h3>
                </div>
                <p class="hht-glow-list__row-desc">{{ block.settings.desc }}</p>
                <a class="btn btn--lavender btn--pill btn--small hht-glow-list__book" href="{{ block.settings.book_url }}" target="_blank" rel="noopener noreferrer">{{ block.settings.book_label }}</a>
              </div>
              <div class="hht-glow-list__row-price">{{ block.settings.price }}</div>
            </article>
              {%- endif -%}
            {%- endfor %}
          </div>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} What's included {%- endcomment -%}
  <section class="hht-sp__section" id="whats-included">
    <div class="hht-sp__wrap">
      <div class="hht-sp__center">
        <span class="hht-sp__eyebrow">{{ section.settings.included_eyebrow }}</span>
        <h2 class="hht-sp__h2">{{ section.settings.included_heading }}</h2>
      </div>
      <div class="hht-sp-grid hht-sp-grid--4">
        {%- for block in section.blocks -%}
          {%- if block.type == 'included' %}
        <article class="hht-sp-card" {{ block.shopify_attributes }}>
          <span class="hht-sp-card__label">{{ block.settings.label }}</span>
          <h3 class="hht-sp__h3">{{ block.settings.title }}</h3>
          <p>{{ block.settings.text }}</p>
        </article>
          {%- endif -%}
        {%- endfor %}
      </div>
    </div>
  </section>

  {%- comment -%} Occasions {%- endcomment -%}
  <section class="hht-sp__section hht-sp__section--warm">
    <div class="hht-sp__wrap">
      <div class="hht-sp__center">
        <span class="hht-sp__eyebrow">{{ section.settings.occasions_eyebrow }}</span>
        <h2 class="hht-sp__h2">{{ section.settings.occasions_heading }}</h2>
      </div>
      <div class="hht-sp-grid hht-sp-grid--3">
        {%- for block in section.blocks -%}
          {%- if block.type == 'occasion' %}
        <article class="hht-sp-card" {{ block.shopify_attributes }}><span class="hht-sp-card__label">{{ block.settings.label }}</span><p>{{ block.settings.text }}</p></article>
          {%- endif -%}
        {%- endfor %}
      </div>
    </div>
  </section>

  {%- comment -%} How it works {%- endcomment -%}
  <section class="hht-sp__section">
    <div class="hht-sp__wrap">
      <div class="hht-sp__center">
        <span class="hht-sp__eyebrow">{{ section.settings.how_eyebrow }}</span>
        <h2 class="hht-sp__h2">{{ section.settings.how_heading }}</h2>
      </div>
      <div class="hht-sp-steps hht-sp-steps--4">
        {%- for block in section.blocks -%}
          {%- if block.type == 'step' %}
        <div class="hht-sp-step" {{ block.shopify_attributes }}><h3 class="hht-sp__h3">{{ block.settings.title }}</h3><p>{{ block.settings.text }}</p></div>
          {%- endif -%}
        {%- endfor %}
      </div>
    </div>
  </section>

  {%- comment -%} Gallery {%- endcomment -%}
  <section class="hht-sp__section hht-sp__section--soft">
    <div class="hht-sp__wrap">
      <div class="hht-sp__center">
        <span class="hht-sp__eyebrow">{{ section.settings.gallery_eyebrow }}</span>
        <h2 class="hht-sp__h2">{{ section.settings.gallery_heading }}</h2>
      </div>
      <div class="hht-sp-gallery">
        {%- for block in section.blocks -%}
          {%- if block.type == 'gallery' %}
        <figure {{ block.shopify_attributes }}>
          {%- if block.settings.image -%}
          <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.alt }}" width="600" height="750" loading="lazy">
          {%- else -%}
          <img src="{{ block.settings.asset | asset_url }}" alt="{{ block.settings.alt }}" width="600" height="750" loading="lazy">
          {%- endif -%}
        </figure>
          {%- endif -%}
        {%- endfor %}
      </div>
      {%- if section.settings.insta_label != blank %}
      <p class="hht-sp__center" style="margin-top:22px;">
        <a class="btn btn--outline" href="{{ section.settings.insta_url }}" target="_blank" rel="noopener noreferrer">{{ section.settings.insta_label }}</a>
      </p>
      {%- endif %}
    </div>
  </section>

  {%- comment -%} Booking details {%- endcomment -%}
  <section class="hht-sp__section">
    <div class="hht-sp__wrap" style="max-width:820px;">
      <div class="hht-sp-notice">
        <span class="hht-sp__eyebrow">{{ section.settings.notice_eyebrow }}</span>
        <h2 class="hht-sp__h2">{{ section.settings.notice_heading }}</h2>
        <ul>
          {%- for block in section.blocks -%}
            {%- if block.type == 'detail' %}
          <li {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
            {%- endif -%}
          {%- endfor %}
        </ul>
      </div>
    </div>
  </section>

  {%- comment -%} Reviews {%- endcomment -%}
  <section class="hht-sp__section hht-sp__section--lavender">
    <div class="hht-sp__wrap">
      <div class="hht-sp__center">
        <span class="hht-sp__eyebrow">{{ section.settings.reviews_eyebrow }}</span>
        <h2 class="hht-sp__h2">{{ section.settings.reviews_heading }}</h2>
      </div>
      <div class="hht-sp-reviews">
        {%- for block in section.blocks -%}
          {%- if block.type == 'review' %}
        <article class="hht-sp-review" {{ block.shopify_attributes }}>
          <div class="hht-sp-review__stars" aria-label="5 out of 5 stars">{{ block.settings.stars }}</div>
          <p class="hht-sp-review__quote">{{ block.settings.quote }}</p>
          <p class="hht-sp-review__meta">{{ block.settings.meta }}</p>
        </article>
          {%- endif -%}
        {%- endfor %}
      </div>
    </div>
  </section>

  {%- comment -%} FAQ {%- endcomment -%}
  <section class="hht-sp__section" id="group-faq">
    <div class="hht-sp__wrap" style="max-width:900px;">
      <div class="hht-sp__center">
        <span class="hht-sp__eyebrow">{{ section.settings.faq_eyebrow }}</span>
        <h2 class="hht-sp__h2">{{ section.settings.faq_heading }}</h2>
      </div>
      <div class="hht-sp-acc" data-hht-acc>
        {%- for block in section.blocks -%}
          {%- if block.type == 'faq' %}
        <div class="hht-sp-acc__item{% if block.settings.open %} is-open{% endif %}" {{ block.shopify_attributes }}>
          <button type="button" class="hht-sp-acc__trig" aria-expanded="{% if block.settings.open %}true{% else %}false{% endif %}">{{ block.settings.question }}<span class="hht-sp-acc__icon" aria-hidden="true"></span></button>
          <div class="hht-sp-acc__panel">{{ block.settings.answer }}</div>
        </div>
          {%- endif -%}
        {%- endfor %}
      </div>
    </div>
  </section>

  {%- comment -%} Final CTA {%- endcomment -%}
  <section class="hht-sp__section hht-sp__section--lavender">
    <div class="hht-sp__wrap">
      <div class="hht-sp-cta-center">
        <span class="hht-sp__eyebrow">{{ section.settings.cta_eyebrow }}</span>
        <h2 class="hht-sp__h2">{{ section.settings.cta_heading }}</h2>
        <p class="hht-sp__lead">{{ section.settings.cta_lead }}</p>
        <div class="hht-sp__ctas">
          {%- if section.settings.cta1_label != blank %}
          <a href="{{ section.settings.cta1_link }}" class="btn">{{ section.settings.cta1_label }}</a>
          {%- endif -%}
          {%- if section.settings.cta2_label != blank %}
          <a href="{{ section.settings.cta2_link }}" class="btn btn--outline">{{ section.settings.cta2_label }}</a>
          {%- endif %}
        </div>
      </div>
    </div>
  </section>
</div>

<script>
(function () {
  var root = document.getElementById('hht-group-page');
  if (!root) return;

  try {
    var params = new URLSearchParams(window.location.search);
    var loc = (params.get('location') || '').toLowerCase();
    if (loc) {
      var panel = document.getElementById('group-panel-' + loc);
      if (panel) {
        window.setTimeout(function () {
          panel.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }, 80);
      }
    }
  } catch (e) {}

  root.querySelectorAll('[data-hht-acc]').forEach(function (acc) {
    acc.querySelectorAll('.hht-sp-acc__trig').forEach(function (trig) {
      trig.addEventListener('click', function () {
        var item = trig.closest('.hht-sp-acc__item');
        var open = item.classList.contains('is-open');
        acc.querySelectorAll('.hht-sp-acc__item').forEach(function (el) {
          el.classList.remove('is-open');
          var b = el.querySelector('.hht-sp-acc__trig');
          if (b) b.setAttribute('aria-expanded', 'false');
        });
        if (!open) {
          item.classList.add('is-open');
          trig.setAttribute('aria-expanded', 'true');
        }
      });
    });
  });
})();
</script>

