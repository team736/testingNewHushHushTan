{%- assign slide_count = section.blocks.size -%}
{%- if slide_count == 0 -%}
  {%- assign slide_count = 1 -%}
{%- endif -%}

<section
  class="hero-slider"
  id="top"
  data-hero-slider
  data-autoplay="{{ section.settings.autoplay_speed | default: 6 | times: 1000 }}"
  {% unless section.settings.autoplay %}data-autoplay-off{% endunless %}
  aria-label="Featured highlights"
  aria-roledescription="carousel">
  <div class="hero-slider__viewport">
    <div class="hero-slider__track">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- render 'hero-slide', block: block, index: forloop.index, first: forloop.first -%}
        {%- endfor -%}
      {%- else -%}
        {%- render 'hero-slide-fallback', section: section -%}
      {%- endif -%}
    </div>
  </div>

  {%- if slide_count > 1 -%}
    <div class="hero-slider__dots" role="tablist" aria-label="Choose slide">
      {%- for block in section.blocks -%}
        <button
          type="button"
          class="hero-slider__dot{% if forloop.first %} is-active{% endif %}"
          role="tab"
          aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
          aria-controls="hero-slide-{{ forloop.index }}"
          data-hero-dot="{{ forloop.index0 }}"
          aria-label="Slide {{ forloop.index }} of {{ section.blocks.size }}">
        </button>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Hero slider",
  "settings": [
    { "type": "checkbox", "id": "autoplay", "label": "Auto-advance slides", "default": true },
    { "type": "range", "id": "autoplay_speed", "label": "Seconds per slide", "min": 4, "max": 12, "step": 1, "default": 6, "unit": "s" }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image (right)" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Memberships & Packages" },
        { "type": "text", "id": "title_line1", "label": "Headline line 1", "default": "Glow More," },
        { "type": "text", "id": "title_line2", "label": "Headline line 2 (accent)", "default": "Save More" },
        { "type": "textarea", "id": "subtitle", "label": "Paragraph", "default": "Join the HHT family and enjoy exclusive savings, priority booking, and the perks of glowing all year long." },
        { "type": "text", "id": "cta_text", "label": "Button text", "default": "View Memberships" },
        { "type": "url", "id": "cta_url", "label": "Button URL" },
        { "type": "text", "id": "image_fallback", "label": "Default image asset filename", "default": "hero-products.jpg", "info": "Used when no image is uploaded. Use PNG for transparent product shots." },
        { "type": "checkbox", "id": "transparent_image", "label": "Transparent / cutout image (no crop)", "default": false },
        { "type": "checkbox", "id": "show_shade_card", "label": "Show shade card overlay", "default": true }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero slider",
