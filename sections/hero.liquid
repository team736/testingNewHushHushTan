            "cta_text": "Book Your Glow",
            "cta_url": "https://go.booker.com/location/hushhushtan/service-menu",
            "image_fallback": "hht-spray-tanning.png",
            "transparent_image": true,
            "show_shade_card": false
          }
        },
        {
