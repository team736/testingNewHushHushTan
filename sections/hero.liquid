{%- liquid
  assign autoplay_ms = section.settings.autoplay_ms | default: 4500

  assign slide_count = 0
  assign std_count = 0
  for block in section.blocks
    if block.type == 'slide'
      assign slide_count = slide_count | plus: 1
    elsif block.type == 'standard'
      assign std_count = std_count | plus: 1
    endif
  endfor
-%}

<section
  class="hero2"
  id="top"
  data-hero-slider
  data-autoplay="{{ autoplay_ms }}"
  {% if section.settings.autoplay == false %}data-autoplay-off{% endif %}
  aria-label="Hero"
  aria-roledescription="carousel">
  <div class="hero2__panel">
    <div class="hero2__stage">
      <div class="hero2__track" data-hero-track>
        {%- assign slide_index = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'slide' -%}
            {%- assign is_first = false -%}
            {%- if slide_index == 0 -%}{%- assign is_first = true -%}{%- endif -%}
            {%- render 'hero-slide-block', block: block, is_first: is_first, slide_index: slide_index -%}
            {%- assign slide_index = slide_index | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- if slide_count > 1 -%}
        <div class="hero2__controls">
          <button type="button" class="hero2__arrow" data-hero-prev aria-label="Previous slide">{% render 'icon', name: 'chevron-left' %}</button>
          <div class="hero2__dots" role="tablist" aria-label="Choose slide">
            {%- for i in (1..slide_count) -%}
              <button
                type="button"
                class="hero2__dot{% if forloop.first %} is-active{% endif %}"
                role="tab"
                aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                aria-label="Slide {{ forloop.index }} of {{ slide_count }}"
                data-hero-dot="{{ forloop.index0 }}"></button>
            {%- endfor -%}
          </div>
          <button type="button" class="hero2__arrow" data-hero-next aria-label="Next slide">{% render 'icon', name: 'chevron-right' %}</button>
        </div>
      {%- endif -%}
    </div>

    {%- if std_count > 0 -%}
      <div class="hero2__standard">
        {%- if section.settings.standard_heading != blank -%}
          <div class="hero2__standard-head">
            <span class="hero2__standard-rule" aria-hidden="true"></span>
            <h2 class="hero2__standard-title">
              <span class="hero2__standard-spark" aria-hidden="true">{% render 'icon', name: 'sparkle' %}</span>
              {{ section.settings.standard_heading }}
              <span class="hero2__standard-spark" aria-hidden="true">{% render 'icon', name: 'sparkle' %}</span>
            </h2>
            <span class="hero2__standard-rule" aria-hidden="true"></span>
          </div>
        {%- endif -%}

        <div class="hero2__cards">
          {%- for block in section.blocks -%}
            {%- if block.type == 'standard' -%}
              <article class="hero2__card" {{ block.shopify_attributes }}>
                <span class="hero2__card-icon">{% render 'science-feature-icon', icon: block.settings.icon %}</span>
                {%- if block.settings.title != blank -%}
                  <h3 class="hero2__card-title">{{ block.settings.title }}</h3>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <p class="hero2__card-text">{{ block.settings.text }}</p>
                {%- endif -%}
              </article>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero slider",
  "settings": [
    { "type": "checkbox", "id": "autoplay", "label": "Auto-advance slides", "default": true },
    { "type": "range", "id": "autoplay_ms", "label": "Slide duration", "min": 3000, "max": 8000, "step": 500, "default": 4500, "unit": "ms" },
    { "type": "header", "content": "The Hush Hush Standard (merged band)" },
    { "type": "text", "id": "standard_heading", "label": "Standard band heading", "default": "The Hush Hush Standard" }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Hero image" },
        { "type": "text", "id": "image_fallback", "label": "Default image filename", "default": "hht-hero-slide-1.webp" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Custom Spray Tanning" },
        { "type": "text", "id": "title_line1", "label": "Heading line 1", "default": "Healthier Glow." },
        { "type": "text", "id": "title_line2", "label": "Heading line 2 (lavender accent)", "default": "Flawless" },
        { "type": "text", "id": "title_line3", "label": "Heading line 3", "default": "Confidence." },
        { "type": "textarea", "id": "subtitle", "label": "Paragraph" },
        { "type": "text", "id": "cta_primary_text", "label": "Primary button text", "default": "Book Now" },
        { "type": "url", "id": "cta_primary_url", "label": "Primary button URL" },
        { "type": "text", "id": "cta_secondary_text", "label": "Secondary button text", "default": "Choose Your Location" },
        { "type": "url", "id": "cta_secondary_url", "label": "Secondary button URL" },
        { "type": "checkbox", "id": "show_pills", "label": "Show feature pills on image", "default": true }
      ]
    },
    {
      "type": "standard",
      "name": "Standard card",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "sparkle", "label": "Custom color" },
            { "value": "book", "label": "Luxury formula" },
            { "value": "award", "label": "Award" },
            { "value": "shield", "label": "Shield check" }
          ],
          "default": "sparkle"
        },
        { "type": "text", "id": "title", "label": "Title", "default": "Custom Color" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Every shade hand-mixed to flatter your undertones." }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Hero slider",
      "blocks": [
        { "type": "slide" },
        { "type": "standard", "settings": { "icon": "sparkle", "title": "Custom Color", "text": "Every shade hand-mixed to flatter your undertones." } },
        { "type": "standard", "settings": { "icon": "book", "title": "Luxury Formula", "text": "Clean, vegan, paraben-free solutions made to nourish." } },
        { "type": "standard", "settings": { "icon": "award", "title": "Award Winning", "text": "Voted best spray tan in Texas year after year." } },
        { "type": "standard", "settings": { "icon": "shield", "title": "Trusted Since 2009", "text": "Nearly two decades perfecting the art of the glow." } }
      ]
    }
  ]
}
{% endschema %}
