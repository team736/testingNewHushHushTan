<section class="page-hero">
  <div class="container">
    <div class="page-hero__card">
      <span class="page-hero__eyebrow">Hush Hush Tan</span>
      <h1 class="page-hero__title">{{ page.title }}</h1>
    </div>
  </div>
</section>

<section class="section section--page-body">
  <div class="container">
    <div class="rte page-body">
      {{ page.content }}
    </div>
  </div>
</section>

{% schema %}
{ "name": "Page", "settings": [] }
{% endschema %}
