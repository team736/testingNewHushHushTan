{%- comment -%}
  Hide empty default page chrome when a redesigned page is still on Default.
  Gated stacks in page.json render instead for these handles.
{%- endcomment -%}
{%- liquid
  assign hht_custom_default = false
  if page.handle == 'our-services'
    or page.handle == 'tanning-gift-certificates'
    or page.handle == 'hush-hush-tan-group-tanning-mimosas-package'
    or page.handle == 'mobile-spray-tan'
    or page.handle == 'faqs'
    or page.handle == 'our-story'
    or page.handle == 'contact'
    assign hht_custom_default = true
  endif
-%}
{%- unless hht_custom_default -%}
<section class="page-hero">
  <div class="container">
    <div class="page-hero__card">
      <span class="page-hero__eyebrow">Hush Hush Tan</span>
      <h1 class="page-hero__title">{{ page.title }}</h1>
    </div>
  </div>
</section>

<section class="section section--page-body">
  <div class="container">
    <div class="rte page-body">
      {{ page.content }}
    </div>
  </div>
</section>
{%- endunless -%}

{% schema %}
{ "name": "Page", "settings": [] }
{% endschema %}
