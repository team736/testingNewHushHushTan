<div class="container section">
  <header class="text-center" style="margin-bottom: 40px;">
    <h1>Shop all collections</h1>
  </header>
  <div class="collection-grid">
    {%- for collection in collections -%}
      {%- unless collection.handle == 'frontpage' -%}
        <a href="{{ collection.url }}" class="product-card">
          <div class="product-card__media">
            {%- if collection.image -%}
              <img src="{{ collection.image | image_url: width: 600 }}" alt="{{ collection.title | escape }}" width="600" height="750" loading="lazy">
            {%- elsif collection.products.first.featured_image -%}
              <img src="{{ collection.products.first.featured_image | image_url: width: 600 }}" alt="{{ collection.title | escape }}" width="600" height="750" loading="lazy">
            {%- endif -%}
          </div>
          <h3 class="product-card__title">{{ collection.title }}</h3>
          <div class="muted small">{{ collection.products_count }} products</div>
        </a>
      {%- endunless -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{ "name": "Collection list", "settings": [] }
{% endschema %}
