{%- liquid
  assign hht_skip = false
  if section.settings.only_on_handle != blank and page.handle != section.settings.only_on_handle
    assign hht_skip = true
  endif
-%}
{%- unless hht_skip -%}
{%- liquid
  assign sid = section.id
  assign austin_url = section.settings.austin_url | default: 'https://go.booker.com/location/HushHushTan/buy/gift-certificate'
  assign dallas_url = section.settings.dallas_url | default: 'https://go.booker.com/location/hushhushtandallas/buy/gift-certificate'
  assign houston_url = section.settings.houston_url | default: 'https://go.booker.com/location/HushHushTanHouston/buy/gift-certificate'
  assign services_url = section.settings.services_url | default: '/pages/our-services'
  assign products_url = section.settings.products_url | default: '/collections/tanning-products'
  assign default_city = section.settings.default_location | default: 'austin'
-%}

{% style %}
  #hht-gift-{{ sid }} {
    --gift-lavender: #EAE3F7;
    --gift-accent: #A69FE2;
    --gift-accent-dark: #8F83D6;
    --gift-ink: #151515;
    --gift-body: #373741;
    --gift-muted: #6F6A70;
    --gift-card: #FFFFFF;
    --gift-warm: #FBFAF7;
    --gift-border: #E7E3F5;
    color: var(--gift-body);
  }
  #hht-gift-{{ sid }} .hht-gift__wrap {
    max-width: var(--container-home, 1120px);
    margin: 0 auto;
    padding: 0 clamp(16px, 4vw, 32px);
  }
  #hht-gift-{{ sid }} .hht-gift__section {
    padding: clamp(40px, 6vw, 72px) 0;
  }
  #hht-gift-{{ sid }} .hht-gift__section--lavender { background: var(--gift-lavender); }
  #hht-gift-{{ sid }} .hht-gift__section--warm { background: var(--gift-warm); }
  #hht-gift-{{ sid }} .hht-gift__section--white { background: #fff; }
  #hht-gift-{{ sid }} .hht-gift__eyebrow {
    display: block;
    font-family: var(--font-eyebrow);
    font-size: var(--type-eyebrow);
    font-weight: 600;
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--gift-accent-dark);
    margin: 0 0 var(--eyebrow-gap, 12px);
  }
  #hht-gift-{{ sid }} .hht-gift__h1,
  #hht-gift-{{ sid }} .hht-gift__h2 {
    font-family: var(--font-heading);
    color: var(--gift-ink);
    letter-spacing: 0;
    margin: 0 0 14px;
    font-weight: 500;
  }
  #hht-gift-{{ sid }} .hht-gift__h1 { font-size: clamp(2rem, 4.2vw, 3.25rem); line-height: 1.1; }
  #hht-gift-{{ sid }} .hht-gift__h2 { font-size: clamp(1.6rem, 3vw, 2.4rem); line-height: 1.15; }
  #hht-gift-{{ sid }} .hht-gift__h3 {
    font-family: var(--font-heading);
    font-size: clamp(1.05rem, 1.6vw, 1.25rem);
    color: var(--gift-ink);
    margin: 0 0 8px;
    font-weight: 500;
  }
  #hht-gift-{{ sid }} .hht-gift__lead {
    font-size: var(--type-body, 1rem);
    line-height: 1.55;
    color: var(--gift-body);
    margin: 0 0 22px;
    max-width: 38rem;
  }
  #hht-gift-{{ sid }} .hht-gift__center { text-align: center; }
  #hht-gift-{{ sid }} .hht-gift__center .hht-gift__lead { margin-left: auto; margin-right: auto; }

  /* Hero */
  #hht-gift-{{ sid }} .hht-gift-hero__panel {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 0;
    align-items: stretch;
    background: #fff;
    border: 1px solid var(--gift-border);
    border-radius: 28px;
    overflow: hidden;
    box-shadow: 0 18px 40px -28px rgba(81, 33, 124, 0.28);
  }
  #hht-gift-{{ sid }} .hht-gift-hero__body {
    padding: clamp(28px, 4vw, 56px);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  #hht-gift-{{ sid }} .hht-gift-hero__media {
    position: relative;
    min-height: 0;
    overflow: hidden;
    background: #F4F1FF;
  }
  #hht-gift-{{ sid }} .hht-gift-hero__media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }
  #hht-gift-{{ sid }} .hht-gift-hero__trust {
    list-style: none; padding: 0; margin: 0 0 26px;
    display: flex; flex-direction: column; gap: 10px;
  }
  #hht-gift-{{ sid }} .hht-gift-hero__trust li {
    display: flex; align-items: center; gap: 10px; color: var(--gift-ink); font-size: 0.95rem;
  }
  #hht-gift-{{ sid }} .hht-gift-hero__trust li::before {
    content: ''; width: 8px; height: 8px; border-radius: 50%; background: var(--gift-accent); flex: 0 0 auto;
  }
  #hht-gift-{{ sid }} .hht-gift-hero__ctas {
    display: flex; flex-wrap: wrap; gap: 12px;
  }
  #hht-gift-{{ sid }} .hht-gift-hero__ctas .btn { min-height: 48px; }

  /* City purchase panel */
  #hht-gift-{{ sid }} .hht-gift-buy {
    background: #fff;
    border: 1px solid var(--gift-border);
    border-radius: 24px;
    padding: clamp(24px, 4vw, 40px);
    box-shadow: 0 14px 34px -26px rgba(81, 33, 124, 0.25);
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }
  #hht-gift-{{ sid }} .hht-gift-toggle {
    display: inline-grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 8px;
    padding: 6px;
    background: #FAF9FF;
    border: 1px solid rgba(166, 159, 226, 0.35);
    border-radius: 999px;
    margin: 18px 0 22px;
    width: min(100%, 420px);
  }
  #hht-gift-{{ sid }} .hht-gift-toggle__btn {
    appearance: none; border: 0; background: transparent; cursor: pointer;
    font-family: var(--font-button); font-size: 0.8125rem; font-weight: 600;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--gift-ink); min-height: 44px; border-radius: 999px; padding: 0 12px;
    transition: background .2s ease, color .2s ease;
  }
  #hht-gift-{{ sid }} .hht-gift-toggle__btn[aria-selected="true"] {
    background: var(--gift-accent); color: #fff;
  }
  #hht-gift-{{ sid }} .hht-gift-buy__note {
    font-size: 0.9rem; color: var(--gift-muted); margin: 0 0 20px;
  }
  #hht-gift-{{ sid }} .hht-gift-buy__studio {
    font-family: var(--font-heading); font-size: 1.35rem; color: var(--gift-ink); margin: 0 0 8px;
  }
  #hht-gift-{{ sid }} .hht-gift-buy__media {
    margin: 0 auto 18px; width: min(100%, 420px); aspect-ratio: 16/10;
    border-radius: 18px; overflow: hidden; background: var(--gift-lavender);
  }
  #hht-gift-{{ sid }} .hht-gift-buy__media img { width: 100%; height: 100%; object-fit: cover; display: none; }
  #hht-gift-{{ sid }}.show-austin [data-gift-img="austin"],
  #hht-gift-{{ sid }}.show-dallas [data-gift-img="dallas"],
  #hht-gift-{{ sid }}.show-houston [data-gift-img="houston"] { display: block; }
  #hht-gift-{{ sid }} .hht-gift-buy__cta { width: min(100%, 420px); min-height: 52px; }

  /* Cards */
  #hht-gift-{{ sid }} .hht-gift-grid {
    display: grid; gap: 18px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 28px;
  }
  #hht-gift-{{ sid }} .hht-gift-grid--3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  #hht-gift-{{ sid }} .hht-gift-grid--4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }
  #hht-gift-{{ sid }} .hht-gift-card {
    background: var(--gift-card);
    border: 1px solid var(--gift-border);
    border-radius: 20px;
    padding: 22px 20px 24px;
  }
  #hht-gift-{{ sid }} .hht-gift-card p { margin: 0; color: var(--gift-body); line-height: 1.5; font-size: 0.95rem; }
  #hht-gift-{{ sid }} .hht-gift-card__label {
    display: inline-block; font-family: var(--font-eyebrow); font-size: 0.6875rem;
    letter-spacing: 0.14em; text-transform: uppercase; color: var(--gift-accent-dark); margin-bottom: 8px;
  }
  #hht-gift-{{ sid }} .hht-gift-fine {
    margin: 18px auto 0; max-width: 44rem; text-align: center;
    font-size: 0.85rem; color: var(--gift-muted); line-height: 1.45;
  }

  /* Gift Value Ideas */
  #hht-gift-{{ sid }} .hht-gift-values-card {
    background: #fff;
    border: 1px solid rgba(166, 159, 226, 0.28);
    border-radius: 28px;
    overflow: hidden;
    margin-top: 8px;
    box-shadow: 0 18px 48px -28px rgba(143, 131, 214, 0.28);
    text-align: left;
  }
  #hht-gift-{{ sid }} .hht-gift-values-card__strip {
    background: #F4F1FF;
    padding: clamp(24px, 3vw, 36px) clamp(20px, 3vw, 32px);
    text-align: center;
    border-bottom: 1px solid rgba(166, 159, 226, 0.22);
  }
  #hht-gift-{{ sid }} .hht-gift-values-card__icon {
    display: block;
    width: 56px;
    height: auto;
    margin: 0 auto 10px;
    object-fit: contain;
  }
  #hht-gift-{{ sid }} .hht-gift-values-card__strip .hht-gift__h2 {
    margin: 0;
    font-style: normal;
    font-weight: 500;
    font-size: clamp(1.75rem, 3vw, 2.35rem);
    line-height: 1.1;
    color: #111;
  }
  #hht-gift-{{ sid }} .hht-gift-values-card__sub {
    margin: 8px 0 0;
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 1rem;
    color: #6F6A70;
  }
  #hht-gift-{{ sid }} .hht-gift-values-card__strip .hht-gift__lead {
    margin: 12px auto 0;
    max-width: 40rem;
    font-style: normal;
    font-size: 0.95rem;
    line-height: 1.55;
    opacity: 1;
    color: #5F5F68;
  }
  #hht-gift-{{ sid }} .hht-gift-values-card__body {
    display: flex;
    flex-direction: column;
    padding: 8px 30px 12px;
  }
  #hht-gift-{{ sid }} .hht-gift-values-row {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto auto;
    column-gap: 20px;
    align-items: start;
    padding: 26px 0 22px;
    border-bottom: 1px solid rgba(231, 227, 245, 0.55);
  }
  #hht-gift-{{ sid }} .hht-gift-values-row:last-child { border-bottom: none; }
  #hht-gift-{{ sid }} .hht-gift-values-row__head {
    grid-column: 1;
    grid-row: 1;
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  #hht-gift-{{ sid }} .hht-gift-values-row__title {
    margin: 0;
    font-family: var(--font-body);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--gift-ink);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    line-height: 1.15;
  }
  #hht-gift-{{ sid }} .hht-gift-values-row__price {
    grid-column: 2;
    grid-row: 1 / span 2;
    align-self: start;
    font-family: var(--font-heading);
    font-size: 1.9rem;
    font-weight: 500;
    color: var(--gift-body);
    line-height: 1;
    text-align: right;
    white-space: nowrap;
  }
  #hht-gift-{{ sid }} .hht-gift-cityprice { display: none; }
  #hht-gift-{{ sid }}.show-austin .gift-price-austin,
  #hht-gift-{{ sid }}.show-dallas .gift-price-dallas,
  #hht-gift-{{ sid }}.show-houston .gift-price-houston { display: inline; }
  #hht-gift-{{ sid }} .hht-gift-values-row__copy {
    grid-column: 1;
    grid-row: 2;
    margin: 8px 0 0;
  }
  #hht-gift-{{ sid }} .hht-gift-values-row__desc {
    margin: 0;
    color: var(--gift-body);
    font-size: 0.92rem;
    line-height: 1.45;
    opacity: 0.85;
  }
  #hht-gift-{{ sid }} .hht-gift-values-row__list {
    margin: 6px 0 0;
    padding: 0;
    list-style: none;
    color: var(--gift-body);
    font-size: 0.92rem;
  }
  #hht-gift-{{ sid }} .hht-gift-values-row__list li {
    margin: 0;
    padding: 1px 0;
  }
  #hht-gift-{{ sid }} a.hht-gift-book-btn {
    display: none !important;
    align-items: center !important;
    justify-content: center !important;
    background: #A69FE2 !important;
    color: #fff !important;
    text-decoration: none !important;
    font-family: var(--font-body) !important;
    font-weight: 600 !important;
    font-size: 0.875rem !important;
    text-transform: none !important;
    letter-spacing: 0 !important;
    padding: 0 28px !important;
    min-height: 48px !important;
    border-radius: 999px !important;
    border: none !important;
    margin-top: 14px !important;
    width: fit-content !important;
    cursor: pointer !important;
    line-height: 1 !important;
    grid-column: 1;
    grid-row: 3;
    transition: background 0.22s ease, transform 0.22s ease;
  }
  #hht-gift-{{ sid }} a.hht-gift-book-btn:hover {
    background: #8F83D6 !important;
    color: #fff !important;
    transform: translateY(-1px);
  }
  #hht-gift-{{ sid }}.show-austin a.hht-gift-book-btn.gift-loc-austin,
  #hht-gift-{{ sid }}.show-dallas a.hht-gift-book-btn.gift-loc-dallas,
  #hht-gift-{{ sid }}.show-houston a.hht-gift-book-btn.gift-loc-houston {
    display: inline-flex !important;
  }
  #hht-gift-{{ sid }} .hht-gift-values-card__foot {
    padding: 8px 30px 26px;
    text-align: center;
    font-size: 0.85rem;
    color: var(--gift-muted);
    line-height: 1.45;
  }
  @media (max-width: 800px) {
    #hht-gift-{{ sid }} .hht-gift-values-card__body { padding: 4px 22px 8px; }
    #hht-gift-{{ sid }} .hht-gift-values-card__strip { padding: 22px 20px 18px; }
    #hht-gift-{{ sid }} .hht-gift-values-row {
      grid-template-columns: 1fr;
      padding: 20px 0 18px;
    }
    #hht-gift-{{ sid }} .hht-gift-values-row__head { grid-column: 1; grid-row: 1; }
    #hht-gift-{{ sid }} .hht-gift-values-row__price {
      grid-column: 1; grid-row: 2; text-align: left; margin-top: 6px; font-size: 1.55rem;
    }
    #hht-gift-{{ sid }} .hht-gift-values-row__copy { grid-row: 3; }
    #hht-gift-{{ sid }} a.hht-gift-book-btn {
      grid-row: 4; min-height: 44px !important; padding: 0 22px !important;
    }
    #hht-gift-{{ sid }} .hht-gift-values-card__foot { padding: 4px 22px 22px; }
  }
  #hht-gift-{{ sid }} .hht-gift-steps {
    display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 18px; margin-top: 28px;
  }
  #hht-gift-{{ sid }} .hht-gift-step {
    background: #fff; border: 1px solid var(--gift-border); border-radius: 20px; padding: 24px 20px; text-align: center;
  }
  #hht-gift-{{ sid }} .hht-gift-step__num {
    display: inline-flex; align-items: center; justify-content: center;
    width: 36px; height: 36px; border-radius: 50%; background: var(--gift-accent); color: #fff;
    font-family: var(--font-button); font-size: 0.8rem; font-weight: 600; margin-bottom: 12px;
  }
  #hht-gift-{{ sid }} .hht-gift-actions { text-align: center; margin-top: 28px; }
  #hht-gift-{{ sid }} .visually-hidden {
    position: absolute !important; height: 1px; width: 1px; overflow: hidden;
    clip: rect(1px, 1px, 1px, 1px); white-space: nowrap;
  }
  #hht-gift-{{ sid }}.hht-gift-booting { opacity: 0; }
  #hht-gift-{{ sid }}:not(.hht-gift-booting) { opacity: 1; transition: opacity .15s ease; }
  @media (prefers-reduced-motion: reduce) {
    #hht-gift-{{ sid }}:not(.hht-gift-booting) { transition: none; }
  }

  @media (max-width: 900px) {
    #hht-gift-{{ sid }} .hht-gift-hero__panel { grid-template-columns: 1fr; }
    #hht-gift-{{ sid }} .hht-gift-hero__media {
      order: -1;
      aspect-ratio: 16 / 10;
      min-height: 200px;
    }
    #hht-gift-{{ sid }} .hht-gift-grid--4,
    #hht-gift-{{ sid }} .hht-gift-grid--3 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    #hht-gift-{{ sid }} .hht-gift-steps { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    #hht-gift-{{ sid }} {
      padding-bottom: calc(24px + env(safe-area-inset-bottom, 0px) + 72px);
    }
    #hht-gift-{{ sid }} .hht-gift-grid,
    #hht-gift-{{ sid }} .hht-gift-grid--3,
    #hht-gift-{{ sid }} .hht-gift-grid--4 { grid-template-columns: 1fr; }
    #hht-gift-{{ sid }} .hht-gift-toggle { width: 100%; border-radius: 18px; }
    #hht-gift-{{ sid }} .hht-gift-hero__ctas .btn,
    #hht-gift-{{ sid }} .hht-gift-buy__cta { width: 100%; }
  }
{% endstyle %}

<section
  id="hht-gift-{{ sid }}"
  class="hht-gift show-{{ default_city }} hht-gift-booting"
  data-hht-gift
  data-default-location="{{ default_city }}"
  data-url-austin="{{ austin_url | escape }}"
  data-url-dallas="{{ dallas_url | escape }}"
  data-url-houston="{{ houston_url | escape }}"
  data-plabel-austin="{{ section.settings.purchase_label_austin | default: 'Purchase an Austin Gift Certificate' | escape }}"
  data-plabel-dallas="{{ section.settings.purchase_label_dallas | default: 'Purchase a Dallas Gift Certificate' | escape }}"
  data-plabel-houston="{{ section.settings.purchase_label_houston | default: 'Purchase a Houston Gift Certificate' | escape }}"
  data-slabel-austin="{{ section.settings.studio_label_austin | default: 'Hush Hush Tan Austin' | escape }}"
  data-slabel-dallas="{{ section.settings.studio_label_dallas | default: 'Hush Hush Tan Dallas' | escape }}"
  data-slabel-houston="{{ section.settings.studio_label_houston | default: 'Hush Hush Tan Houston' | escape }}"
  aria-label="Gift certificates">

  {%- comment -%} ===== HERO ===== {%- endcomment -%}
  <div class="hht-gift__section hht-gift__section--lavender">
    <div class="hht-gift__wrap">
      <div class="hht-gift-hero__panel">
        <div class="hht-gift-hero__body">
          {% if section.settings.hero_eyebrow != blank %}<span class="hht-gift__eyebrow">{{ section.settings.hero_eyebrow }}</span>{% endif %}
          <h1 class="hht-gift__h1">{{ section.settings.hero_heading }}</h1>
          {% if section.settings.hero_text != blank %}<p class="hht-gift__lead">{{ section.settings.hero_text }}</p>{% endif %}
          {%- if section.settings.trust_1 != blank or section.settings.trust_2 != blank or section.settings.trust_3 != blank -%}
          <ul class="hht-gift-hero__trust">
            {% if section.settings.trust_1 != blank %}<li>{{ section.settings.trust_1 }}</li>{% endif %}
            {% if section.settings.trust_2 != blank %}<li>{{ section.settings.trust_2 }}</li>{% endif %}
            {% if section.settings.trust_3 != blank %}<li>{{ section.settings.trust_3 }}</li>{% endif %}
          </ul>
          {%- endif -%}
          <div class="hht-gift-hero__ctas">
            {% if section.settings.hero_cta1 != blank %}<a href="{{ section.settings.hero_cta1_url | default: '#gift-purchase' }}" class="btn btn--pill">{{ section.settings.hero_cta1 }}</a>{% endif %}
            {% if section.settings.hero_cta2 != blank %}<a href="{{ section.settings.hero_cta2_url | default: '#gift-values' }}" class="btn btn--pill btn--outline">{{ section.settings.hero_cta2 }}</a>{% endif %}
          </div>
        </div>
        <div class="hht-gift-hero__media">
          {%- if section.settings.hero_image != blank -%}
            <img src="{{ section.settings.hero_image | image_url: width: 1200 }}" alt="{{ section.settings.hero_image_alt | default: 'Hush Hush Tan gift glow experience' | escape }}" width="900" height="1000" loading="eager">
          {%- else -%}
            <img src="{{ 'hht-glow-editorial.jpg' | asset_url }}" alt="{{ section.settings.hero_image_alt | default: 'Hush Hush Tan gift glow experience' | escape }}" width="900" height="1000" loading="eager">
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} ===== CITY SELECTOR ===== {%- endcomment -%}
  <div class="hht-gift__section hht-gift__section--warm" id="gift-purchase">
    <div class="hht-gift__wrap">
      <div class="hht-gift-buy">
        {% if section.settings.buy_eyebrow != blank %}<span class="hht-gift__eyebrow">{{ section.settings.buy_eyebrow }}</span>{% endif %}
        <h2 class="hht-gift__h2">{{ section.settings.buy_heading }}</h2>
        {% if section.settings.buy_text != blank %}<p class="hht-gift__lead" style="margin-left:auto;margin-right:auto;">{{ section.settings.buy_text }}</p>{% endif %}

        <div class="hht-gift-toggle" role="tablist" aria-label="Gift certificate studio">
          <button type="button" class="hht-gift-toggle__btn" role="tab" data-gift-city="austin" aria-selected="true" aria-controls="hht-gift-live-{{ sid }}">Austin</button>
          <button type="button" class="hht-gift-toggle__btn" role="tab" data-gift-city="dallas" aria-selected="false" aria-controls="hht-gift-live-{{ sid }}">Dallas</button>
