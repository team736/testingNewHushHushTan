<script src="{{ 'hht-gift-certificates.js' | asset_url }}" defer></script>
<script>
  (function () {
    function ready(fn) {
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', fn);
      else fn();
    }
    ready(function () {
      var root = document.getElementById('hht-gift-{{ sid }}');
      if (!root) return;

      var urls = {
        austin: root.getAttribute('data-url-austin'),
        dallas: root.getAttribute('data-url-dallas'),
        houston: root.getAttribute('data-url-houston')
      };
      var purchaseLabels = {
        austin: root.getAttribute('data-plabel-austin'),
        dallas: root.getAttribute('data-plabel-dallas'),
        houston: root.getAttribute('data-plabel-houston')
      };
      var studioLabels = {
        austin: root.getAttribute('data-slabel-austin'),
        dallas: root.getAttribute('data-slabel-dallas'),
        houston: root.getAttribute('data-slabel-houston')
      };
      var buyForLabels = {
        austin: 'BUY FOR AUSTIN',
        dallas: 'BUY FOR DALLAS',
        houston: 'BUY FOR HOUSTON'
      };

      var buttons = root.querySelectorAll('[data-gift-city]');
      var live = root.querySelector('[data-gift-live]');
      var studioLabel = root.querySelector('[data-gift-studio-label]');
      var purchaseLinks = root.querySelectorAll('[data-gift-purchase]');

      function activate(city, pushState) {
        if (!urls[city]) city = 'austin';
        root.classList.remove('show-austin', 'show-dallas', 'show-houston');
        root.classList.add('show-' + city);
        buttons.forEach(function (btn) {
          var on = btn.getAttribute('data-gift-city') === city;
          btn.setAttribute('aria-selected', on ? 'true' : 'false');
        });
        var url = urls[city];
        if (studioLabel) studioLabel.textContent = studioLabels[city];
        purchaseLinks.forEach(function (a) {
          var href = a.getAttribute('data-book-' + city) || url;
          a.setAttribute('href', href);
          if (a.classList.contains('hht-gift-buy__cta') || a.closest('.hht-gift-actions')) {
            a.textContent = purchaseLabels[city];
          }
          a.setAttribute('aria-label', purchaseLabels[city] + ' (opens in a new tab)');
        });
        document.querySelectorAll('[data-hht-sync-book], [data-hht-sync-gift]').forEach(function (el) {
          var href = el.getAttribute('data-book-' + city) || url;
          if (href) el.setAttribute('href', href);
          if (el.hasAttribute('data-gift-buy-for')) el.textContent = buyForLabels[city];
        });
        if (live) live.textContent = city.charAt(0).toUpperCase() + city.slice(1) + ' gift certificate selected.';
        try {
          window.dispatchEvent(new CustomEvent('hht:giftlocationchange', { detail: { city: city } }));
        } catch (e) {}
        if (pushState) {
          try {
            var u = new URL(window.location.href);
            u.searchParams.set('location', city);
            u.hash = '';
            history.replaceState({ hhtGiftLocation: city }, '', u.pathname + u.search);
          } catch (err) {}
        }
      }

      buttons.forEach(function (btn) {
        btn.addEventListener('click', function () {
          activate(btn.getAttribute('data-gift-city'), true);
        });
      });

      function fromUrl() {
        var m = (window.location.search || '').match(/[?&](?:loc|location)=([^&#]+)/i);
        var city = m && m[1] ? decodeURIComponent(m[1]).toLowerCase() : (root.getAttribute('data-default-location') || 'austin');
        if (!urls[city]) city = 'austin';
        activate(city, false);
      }

      try { fromUrl(); } finally { root.classList.remove('hht-gift-booting'); }
      window.addEventListener('popstate', fromUrl);
    });
  })();
</script>

{%- endunless -%}

