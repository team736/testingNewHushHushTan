{%- assign recipient_email = section.settings.recipient_email | default: 'contact@hushhushtan.com' -%}

<section class="section">
  <div class="container container--narrow">
    <div class="contact-form-wrap">
      <h2 class="text-center">{{ section.settings.heading }}</h2>
      {%- if section.settings.text != blank -%}
        <p class="text-center muted" style="margin-bottom: 36px;">{{ section.settings.text }}</p>
      {%- endif -%}
      <p class="text-center muted" style="margin-bottom: 24px;">
        Or email us directly at <a href="mailto:{{ recipient_email }}">{{ recipient_email }}</a>.
      </p>
      {%- form 'contact', class: 'contact-form' -%}
        {%- if form.posted_successfully? -%}
          <div class="full" style="background:var(--soft);padding:16px;border-radius:var(--radius-sm);text-align:center;">Thanks — we'll be in touch shortly.</div>
        {%- endif -%}
        <input type="hidden" name="contact[tags]" value="website-contact">
        <input type="text" name="contact[name]" placeholder="Name" required>
        <input type="email" name="contact[email]" placeholder="Email" required>
        <textarea class="full" name="contact[body]" placeholder="Message" required></textarea>
        <div class="full submit-row">
          <button type="submit" class="btn">Submit</button>
        </div>
      {%- endform -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact form",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Send A Message" },
    { "type": "text", "id": "text", "label": "Subtext", "default": "We'll respond within one business day." },
    { "type": "text", "id": "recipient_email", "label": "Contact email", "default": "contact@hushhushtan.com", "info": "Shown as a mailto link. Set the same address in Shopify Admin → Settings → Notifications so form submissions are delivered there." }
  ],
  "presets": [{ "name": "Contact form" }]
}
{% endschema %}
