<section class="section section--soft newsletter-premium">
  <div class="container">
    <div class="newsletter-band">
      {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.text != blank -%}<p class="newsletter-premium__text">{{ section.settings.text }}</p>{%- endif -%}
      {%- form 'customer', class: 'newsletter-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input type="email" name="contact[email]" placeholder="Enter your email address" aria-label="Email address" required>
        <button type="submit">Subscribe →</button>
      {%- endform -%}
      <p class="small newsletter-premium__disclaimer">{{ section.settings.disclaimer | default: 'We respect your privacy. Unsubscribe anytime.' }}</p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Stay in the know" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Good emails." },
    { "type": "text", "id": "text", "label": "Text", "default": "Be the first to hear about new products, packages and seasonal events." },
    { "type": "text", "id": "disclaimer", "label": "Disclaimer", "default": "We respect your privacy. Unsubscribe anytime." }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
