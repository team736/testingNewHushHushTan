<div class="announcement-bar" role="region" aria-label="Announcement">
  {%- if section.settings.link != blank -%}
    <a href="{{ section.settings.link }}">{{ section.settings.text }}</a>
  {%- else -%}
    {{ section.settings.text }}
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    { "type": "text", "id": "text", "label": "Text", "default": "Locations in Austin · Dallas · Houston — Book your Custom Glow today" },
    { "type": "url", "id": "link", "label": "Link (optional)" }
  ],
  "presets": [{ "name": "Announcement bar" }]
}
{% endschema %}
