<div class="container section" style="max-width: 480px;">
  <h1 class="text-center">Reset your password</h1>
  {%- form 'recover_customer_password', class: 'form' -%}
    {%- if form.posted_successfully? -%}<p>We've sent you a reset email.</p>{%- endif -%}
    <div class="field"><label for="Email">Email</label><input type="email" name="email" id="Email" required></div>
    <button type="submit" class="btn">Reset password</button>
  {%- endform -%}
  <p class="text-center small" style="margin-top: 16px;"><a href="{{ routes.account_login_url }}">Back to login</a></p>
</div>
{% schema %}{ "name": "Reset password", "settings": [] }{% endschema %}
