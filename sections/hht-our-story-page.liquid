    { "type": "text", "id": "problem_heading", "label": "Heading", "default": "Beyond One-Shade-Fits-All" },
    { "type": "textarea", "id": "problem_text_1", "label": "Paragraph 1", "default": "Many spray-tan experiences treat every client with the same approach. Izabel built Hush Hush Tan around consultation, color matching, and application that respects undertones and lifestyle — so the result looks natural in daylight and photographs." },
    { "type": "textarea", "id": "problem_text_2", "label": "Paragraph 2", "default": "That philosophy continues in every studio: listen first, customize the formula and depth, then apply with care." },
    { "type": "image_picker", "id": "problem_image", "label": "Image", "info": "Falls back to the hht-moment-aftercare.jpg theme asset when empty." },
    { "type": "text", "id": "problem_image_alt", "label": "Image alt text", "default": "Natural-looking custom spray tan finish" },
    { "type": "header", "content": "Formula approach" },
    { "type": "text", "id": "formula_eyebrow", "label": "Eyebrow", "default": "The Formula Approach" },
    { "type": "text", "id": "formula_heading", "label": "Heading", "default": "Color Mixed Around You" },
    { "type": "textarea", "id": "formula_text", "label": "Text", "default": "Hush Hush Tan artists select and adjust color around the individual — skin tone, undertones, and the look you want for your occasion. The goal is a believable, personalized finish rather than a single default shade." },
    { "type": "header", "content": "Difference", "info": "Cards in this area are Difference card blocks." },
    { "type": "text", "id": "difference_eyebrow", "label": "Eyebrow", "default": "The Hush Hush Difference" },
    { "type": "text", "id": "difference_heading", "label": "Heading", "default": "Mixed for Your Undertones" },
    { "type": "textarea", "id": "difference_text", "label": "Text", "default": "Every appointment begins with a conversation. The artist considers the client’s complexion, undertones, schedule, and desired result before selecting or mixing the appropriate color. The goal is not a one-shade-fits-all tan, but a glow that feels believable and individual." },
    { "type": "header", "content": "Values", "info": "Cards in this area are Value card blocks." },
    { "type": "text", "id": "values_eyebrow", "label": "Eyebrow", "default": "Values" },
    { "type": "text", "id": "values_heading", "label": "Heading", "default": "What Guides Every Glow" },
    { "type": "header", "content": "Press", "info": "Logos are Press logo blocks." },
    { "type": "text", "id": "press_eyebrow", "label": "Eyebrow", "default": "Recognized Beyond Texas" },
    { "type": "text", "id": "press_heading", "label": "Heading", "default": "A Local Brand with National Recognition" },
    { "type": "textarea", "id": "press_text", "label": "Text", "default": "Hush Hush Tan’s personalized approach has been recognized by leading fashion, lifestyle, and Texas publications." },
    { "type": "text", "id": "press_button_label", "label": "Button label", "default": "Read Press" },
