    { "type": "header", "content": "Gallery", "info": "Images are Gallery image blocks." },
    { "type": "text", "id": "gallery_eyebrow", "label": "Eyebrow", "default": "Gallery" },
    { "type": "text", "id": "gallery_heading", "label": "Heading", "default": "Behind the Glow" },
    { "type": "text", "id": "gallery_button_label", "label": "Button label", "default": "Follow @hushhushtan" },
    { "type": "url", "id": "gallery_button_link", "label": "Button link" },
    { "type": "header", "content": "Final call to action" },
    { "type": "text", "id": "final_eyebrow", "label": "Eyebrow", "default": "Come Glow with Us" },
    { "type": "text", "id": "final_heading", "label": "Heading", "default": "Experience Hush Hush Tan for Yourself" },
    { "type": "textarea", "id": "final_text", "label": "Text", "default": "Choose your nearest Texas studio and book a personalized airbrush-tanning experience." },
    { "type": "text", "id": "final_button_1_label", "label": "Button 1 label", "default": "Choose a Location" },
    { "type": "url", "id": "final_button_1_link", "label": "Button 1 link" },
    { "type": "text", "id": "final_button_2_label", "label": "Button 2 label", "default": "Explore Services" },
    { "type": "url", "id": "final_button_2_link", "label": "Button 2 link" }
  ],
  "blocks": [
