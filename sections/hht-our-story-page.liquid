    ] },
    { "type": "press_logo", "name": "Press logo", "settings": [
      { "type": "image_picker", "id": "image", "label": "Logo image" },
      { "type": "text", "id": "asset_file", "label": "Fallback asset filename", "info": "Theme asset used when no logo image is selected." },
      { "type": "text", "id": "name", "label": "Publication name (alt text)" },
      { "type": "number", "id": "logo_width", "label": "Logo width (px)", "default": 120 }
    ] },
    { "type": "location_card", "name": "Location card", "settings": [
      { "type": "image_picker", "id": "image", "label": "Image" },
      { "type": "text", "id": "asset_file", "label": "Fallback asset filename", "info": "Theme asset used when no image is selected." },
      { "type": "text", "id": "image_alt", "label": "Image alt text" },
      { "type": "text", "id": "label", "label": "Label" },
      { "type": "text", "id": "heading", "label": "Heading" },
      { "type": "textarea", "id": "text", "label": "Text" },
      { "type": "text", "id": "button_label", "label": "Button label" },
      { "type": "url", "id": "button_link", "label": "Button link" }
    ] },
    { "type": "gallery_image", "name": "Gallery image", "settings": [
      { "type": "image_picker", "id": "image", "label": "Image" },
      { "type": "text", "id": "asset_file", "label": "Fallback asset filename", "info": "Theme asset used when no image is selected." },
      { "type": "text", "id": "image_alt", "label": "Image alt text" },
      { "type": "url", "id": "link", "label": "Link" }
    ] }
  ],
  "presets": [
    {
      "name": "Our Story Page",
      "settings": {
        "hero_button_2_link": "/pages/locations",
        "press_button_link": "/pages/press",
        "gallery_button_link": "https://www.instagram.com/hushhushtan/",
        "final_button_1_link": "/pages/locations",
        "final_button_2_link": "/pages/our-services"
      },
      "blocks": [
        { "type": "difference_card", "settings": { "label": "Personalized Color", "text": "Each service is selected around the individual client." } },
        { "type": "difference_card", "settings": { "label": "Expert Application", "text": "Detailed airbrush application supports an even, controlled finish." } },
        { "type": "difference_card", "settings": { "label": "Comfortable Experience", "text": "Private appointments and attentive artists help clients feel informed and at ease." } },
        { "type": "value_card", "settings": { "label": "Personalization", "text": "No two skin tones or desired results are identical." } },
        { "type": "value_card", "settings": { "label": "Confidence", "text": "The experience should help clients feel comfortable, prepared, and confident." } },
        { "type": "value_card", "settings": { "label": "Consistency", "text": "From consultation through aftercare, details matter." } },
        { "type": "value_card", "settings": { "label": "Care", "text": "Clients should understand their service, development time, and aftercare before leaving." } },
