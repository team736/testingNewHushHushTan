{%- liquid
  assign hht_skip = false
  if section.settings.only_on_handle != blank and page.handle != section.settings.only_on_handle
    assign hht_skip = true
  endif
-%}
{%- unless hht_skip -%}
{% style %}
  /* Hard-coded Freight Neo Pro Medium */
  @font-face {
    font-family: 'Freight Neo Pro';
    src: url('https://cdn.shopify.com/s/files/1/0329/1109/7991/files/freight-neo-pro-medium_4.otf?v=1780773403') format('opentype');
    font-weight: 400 700;
    font-style: normal;
    font-display: swap;
  }
  {{ section.settings.body_font | font_face: font_display: 'swap' }}

  div#hht-services-{{ section.id }}, div#hht-services-{{ section.id }} * { box-sizing: border-box; }
  div#hht-services-{{ section.id }} {
    --bg-color: {{ section.settings.bg_color | default: '#FAF8F5' }};
    --heading-color: {{ section.settings.heading_color | default: '#151515' }};
    --text-main: {{ section.settings.text_color | default: '#373741' }};
    --text-light: {{ section.settings.text_light | default: '#6F6A70' }};
    --accent: {{ section.settings.accent_color | default: '#A69FE2' }};
    --card-bg: {{ section.settings.card_bg_color | default: '#FFFFFF' }};
    --card-border: {{ section.settings.card_border_color | default: '#E7E3F5' }};
    --header-strip: {{ section.settings.header_strip_color | default: '#F4F2FF' }};
    --badge-bg: {{ section.settings.badge_bg_color | default: '#A69FE2' }};
    --badge-text: {{ section.settings.badge_text_color | default: '#FFFFFF' }};
    --btn-bg: {{ section.settings.btn_bg_color | default: '#A69FE2' }};
    --btn-text: {{ section.settings.btn_text_color | default: '#FFFFFF' }};
    --btn-hover-bg: {{ section.settings.btn_hover_bg | default: '#8F83D6' }};
    --btn-hover-text: {{ section.settings.btn_hover_text | default: '#FFFFFF' }};
    --toggle-idle-bg: {{ section.settings.toggle_idle_bg | default: '#FAF9FF' }};
    --toggle-idle-text: {{ section.settings.toggle_idle_text | default: '#373741' }};
    --toggle-idle-border: {{ section.settings.toggle_idle_border | default: 'rgba(166, 159, 226, 0.35)' }};
    --toggle-active-bg: {{ section.settings.toggle_active_bg | default: '#A69FE2' }};
    --toggle-active-text: {{ section.settings.toggle_active_text | default: '#FFFFFF' }};
    --toggle-active-border: {{ section.settings.toggle_active_border | default: '#A69FE2' }};
    background-color: var(--bg-color);
    color: var(--text-main);
    font-family: {{ section.settings.body_font.family }}, sans-serif;
    padding: clamp(32px, 5vw, 56px) 20px clamp(48px, 6vw, 72px);
  }
  div#hht-services-{{ section.id }} .hht-container { max-width: 1240px; margin: 0 auto; }

  /* Page Header */
  div#hht-services-{{ section.id }} .hht-header { text-align: center; margin-bottom: 28px; }
  div#hht-services-{{ section.id }} .hht-header--compact { margin-bottom: 20px; }
  div#hht-services-{{ section.id }} .hht-header--compact h1 { font-size: clamp(1.8rem, 3.5vw, 2.6rem); margin-bottom: 12px; }
  div#hht-services-{{ section.id }} .hht-header__eyebrow {
    display: block;
    font-family: {{ section.settings.body_font.family }}, sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 10px;
  }
  div#hht-services-{{ section.id }} .hht-header h1 {
    font-family: 'Freight Neo Pro', {{ section.settings.heading_font_fallback | default: 'Cormorant Garamond' }}, serif;
    font-size: clamp(2.4rem, 4.5vw, 3.4rem);
    color: var(--heading-color);
    margin: 0 0 20px 0;
    font-weight: 500;
    font-style: italic;
    letter-spacing: -0.01em;
  }
  div#hht-services-{{ section.id }} .hht-header h1 .roman { font-style: normal; font-weight: 500; }
  div#hht-services-{{ section.id }} .hht-header .hht-subheading {
    font-size: 0.85rem;
    color: var(--heading-color);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 0 0 16px 0;
    font-weight: 500;
  }

  /* Location Toggle — matches homepage pill tabs */
  div#hht-services-{{ section.id }} .hht-loc-toggle {
    display: inline-flex; align-items: center; gap: 0; padding: 4px;
    border: 1px solid var(--toggle-idle-border); border-radius: 999px;
    background: var(--toggle-idle-bg);
  }
  div#hht-services-{{ section.id }} button.hht-loc-btn {
    display: inline-flex !important; align-items: center !important; justify-content: center !important;
    min-width: 112px; padding: 10px 24px !important;
    border: 0 !important; background: transparent !important;
    font-family: {{ section.settings.body_font.family }}, sans-serif !important;
    font-weight: 500 !important; font-size: 0.875rem !important;
    text-transform: none !important; letter-spacing: 0 !important;
    color: var(--toggle-idle-text) !important;
    cursor: pointer !important;
    transition: background 0.22s ease, color 0.22s ease, box-shadow 0.22s ease !important;
    border-radius: 999px !important; line-height: 1 !important;
    box-shadow: none !important;
  }
  div#hht-services-{{ section.id }} button.hht-loc-btn:hover { color: #7B72C8 !important; }
  div#hht-services-{{ section.id }} button.hht-loc-btn.active {
    background: var(--toggle-active-bg) !important;
    color: var(--toggle-active-text) !important;
    box-shadow: 0 6px 18px rgba(166, 159, 226, 0.34) !important;
  }

  /* Studio photo strip */
  div#hht-services-{{ section.id }} .hht-studio-strip {
    margin: 0 0 28px; border-radius: 18px; overflow: hidden;
    border: 1px solid var(--card-border); background: var(--card-bg);
  }
  div#hht-services-{{ section.id }} .hht-studio-strip__grid {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 3px;
  }
  div#hht-services-{{ section.id }} .hht-studio-strip__cell { aspect-ratio: 4/3; overflow: hidden; }
  div#hht-services-{{ section.id }} .hht-studio-strip__cell img {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }
  div#hht-services-{{ section.id }} .hht-studio-strip__meta {
    padding: 12px 18px; text-align: center;
    font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--accent); font-weight: 600;
  }
  div#hht-services-{{ section.id }} .hht-studio-panel { display: none; }
  div#hht-services-{{ section.id }}.show-loc1 .hht-studio-panel[data-studio="austin"],
  div#hht-services-{{ section.id }}.show-loc2 .hht-studio-panel[data-studio="houston"],
  div#hht-services-{{ section.id }}.show-loc3 .hht-studio-panel[data-studio="dallas"] { display: block; }

  /* Section Card */
  div#hht-services-{{ section.id }} .hht-section-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 22px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 100%;
    box-shadow: 0 16px 44px rgba(85, 74, 140, 0.04);
  }
  div#hht-services-{{ section.id }} .hht-section-card--featured {
    border-color: rgba(166, 159, 226, 0.55);
    box-shadow: 0 20px 50px rgba(166, 159, 226, 0.12);
  }
  div#hht-services-{{ section.id }} .hht-section-card--featured .hht-section-strip {
    background: linear-gradient(180deg, #F4F2FF 0%, #FAF9FF 100%);
    padding: 32px 30px 24px;
  }
  div#hht-services-{{ section.id }} .hht-section-card--featured .hht-section-body {
    display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0 24px;
    padding: 8px 30px 30px;
  }
  div#hht-services-{{ section.id }} .hht-section-card--featured .hht-row {
    border-bottom: 1px solid color-mix(in srgb, var(--card-border) 45%, transparent);
    padding: 22px 0 18px;
  }
  div#hht-services-{{ section.id }} .hht-section-card--compact .hht-section-strip { padding: 18px 22px 14px; }
  div#hht-services-{{ section.id }} .hht-section-card--compact .hht-section-title { font-size: clamp(1.35rem, 2vw, 1.65rem); }
  div#hht-services-{{ section.id }} .hht-section-card--compact .hht-section-body { padding: 4px 22px 20px; }
  div#hht-services-{{ section.id }} .hht-section-card--compact .hht-row { padding: 16px 0 14px; }
  div#hht-services-{{ section.id }} .hht-section-card--compact .hht-row-title { font-size: 0.88rem; }
  div#hht-services-{{ section.id }} .hht-section-card--compact .hht-row-price { font-size: 1.45rem; }
  div#hht-services-{{ section.id }} .hht-section-strip {
    background: var(--header-strip);
    padding: 28px 30px 22px;
    text-align: center;
    border-bottom: 1px solid color-mix(in srgb, var(--card-border) 55%, transparent);
  }
  div#hht-services-{{ section.id }} .hht-section-icon {
    object-fit: contain;
    display: inline-block;
    margin-bottom: 6px;
    height: auto;
  }
  div#hht-services-{{ section.id }} .hht-section-title {
    font-family: 'Freight Neo Pro', {{ section.settings.heading_font_fallback | default: 'Cormorant Garamond' }}, serif;
    font-size: clamp(1.7rem, 2.6vw, 2.1rem);
    color: var(--heading-color);
    margin: 4px 0 6px 0;
    font-weight: 500;
    font-style: italic;
    line-height: 1.1;
  }
  div#hht-services-{{ section.id }} .hht-section-title .roman { font-style: normal; font-weight: 500; }
  div#hht-services-{{ section.id }} .hht-section-note {
    font-size: 0.95rem;
    color: var(--heading-color);
    margin: 0;
    font-style: italic;
    opacity: 0.85;
  }
  div#hht-services-{{ section.id }} .hht-section-body {
    padding: 8px 30px 30px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  /* Service Row */
  div#hht-services-{{ section.id }} .hht-row {
    padding: 26px 0 22px 0;
    border-bottom: 1px solid color-mix(in srgb, var(--card-border) 45%, transparent);
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto auto;
    column-gap: 20px;
    align-items: start;
  }
  div#hht-services-{{ section.id }} .hht-row:last-child { border-bottom: none; }
  div#hht-services-{{ section.id }} .hht-row-head {
    display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
    grid-column: 1; grid-row: 1;
  }
  div#hht-services-{{ section.id }} .hht-row-title {
    font-family: {{ section.settings.body_font.family }}, sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--heading-color);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0;
    line-height: 1.15;
  }
  div#hht-services-{{ section.id }} .hht-row-price {
    font-family: 'Freight Neo Pro', {{ section.settings.heading_font_fallback | default: 'Cormorant Garamond' }}, serif;
    font-size: 1.9rem;
    font-weight: 500;
    color: var(--text-main);
    line-height: 1;
    grid-column: 2;
    grid-row: 1 / span 2;
    align-self: start;
    text-align: right;
    white-space: nowrap;
  }
  div#hht-services-{{ section.id }} .hht-row-price .price-sub {
    display: block;
    font-family: {{ section.settings.body_font.family }}, sans-serif;
    font-size: 0.7rem;
    font-weight: 400;
    color: var(--text-light);
    letter-spacing: 0.05em;
    margin-top: 6px;
    text-transform: none;
  }
  div#hht-services-{{ section.id }} .hht-row-desc {
    font-size: 0.92rem;
    color: var(--text-main);
    line-height: 1.45;
    margin: 8px 0 0 0;
    grid-column: 1;
    grid-row: 2;
    opacity: 0.85;
  }
  div#hht-services-{{ section.id }} .hht-row-desc ul {
    list-style: none; padding: 0; margin: 0;
  }
  div#hht-services-{{ section.id }} .hht-row-desc li {
    padding: 1px 0;
  }

  /* Badge */
  div#hht-services-{{ section.id }} .hht-badge {
    display: inline-flex; align-items: center; gap: 5px;
    background: var(--badge-bg); color: var(--badge-text);
    font-size: 0.62rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.12em;
    padding: 4px 10px 4px 8px; border-radius: 20px;
    line-height: 1; white-space: nowrap;
  }
  div#hht-services-{{ section.id }} .hht-badge .hht-badge-icon {
    font-size: 0.85em; line-height: 1; opacity: 0.95;
    /* let emoji render at its natural color (no text-color inheritance) */
    color: initial;
  }

  /* Book Now button — matches homepage .btn--pill.btn--lavender */
  div#hht-services-{{ section.id }} a.hht-book-btn {
    display: inline-flex !important; align-items: center !important; justify-content: center !important;
    background: var(--btn-bg) !important; color: var(--btn-text) !important;
    text-decoration: none !important;
    font-family: {{ section.settings.body_font.family }}, sans-serif !important;
    font-weight: 600 !important; font-size: 0.875rem !important;
    text-transform: none !important; letter-spacing: 0 !important;
    padding: 0 28px !important; min-height: 48px !important;
    border-radius: 999px !important; border: none !important;
    margin-top: 14px !important;
    transition: background 0.22s ease, transform 0.22s ease, color 0.22s ease !important;
    width: fit-content !important; cursor: pointer !important; line-height: 1 !important;
    grid-column: 1; grid-row: 3;
  }
  div#hht-services-{{ section.id }} a.hht-book-btn:hover {
    background: var(--btn-hover-bg) !important;
    color: var(--btn-hover-text) !important;
    transform: translateY(-1px) !important;
  }

  /* Footer note */
  div#hht-services-{{ section.id }} .hht-section-foot {
    font-size: 0.8rem;
    color: var(--text-light);
    text-align: center;
    padding: 0 30px 22px 30px;
    font-style: italic;
  }

  /* Layout: full-width sections stack with gap; pair-mode renders 2-col grid */
  div#hht-services-{{ section.id }} .hht-section-card { margin-bottom: 20px; }
  div#hht-services-{{ section.id }} .hht-pair-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
  }
  div#hht-services-{{ section.id }} .hht-pair-row .hht-section-card { margin-bottom: 0; }

  /* LeadConnector chat widget */
  div#hht-services-{{ section.id }} {
    padding-bottom: calc(clamp(48px, 6vw, 72px) + env(safe-area-inset-bottom, 0px) + 88px);
  }
  div#hht-services-{{ section.id }}.hht-loc-booting {
    opacity: 0;
  }
  div#hht-services-{{ section.id }}:not(.hht-loc-booting) {
    opacity: 1;
    transition: opacity 0.15s ease;
  }
  @media (prefers-reduced-motion: reduce) {
    div#hht-services-{{ section.id }}:not(.hht-loc-booting) { transition: none; }
    div#hht-services-{{ section.id }} .hht-anim-float:hover,
    div#hht-services-{{ section.id }} .hht-anim-scale:hover { transform: none; }
  }
  div#hht-services-{{ section.id }} .hht-chat-widget-wrap {
    margin-top: 32px; padding-top: 28px;
    border-top: 1px solid color-mix(in srgb, var(--card-border) 55%, transparent);
  }
  div#hht-services-{{ section.id }} .hht-chat-widget-panel { display: none; min-height: 0; }
  div#hht-services-{{ section.id }}.show-loc1 .hht-chat-widget-panel[data-chat-loc="austin"],
  div#hht-services-{{ section.id }}.show-loc2 .hht-chat-widget-panel[data-chat-loc="houston"],
  div#hht-services-{{ section.id }}.show-loc3 .hht-chat-widget-panel[data-chat-loc="dallas"] { display: block; }

  /* Animations */
  div#hht-services-{{ section.id }} .hht-anim-float { transition: transform 0.3s ease, box-shadow 0.3s ease; }
  div#hht-services-{{ section.id }} .hht-anim-float:hover { transform: translateY(-3px); box-shadow: 0 16px 32px rgba(81, 33, 124, 0.08); }
  div#hht-services-{{ section.id }} .hht-anim-glow { transition: box-shadow 0.3s ease, border-color 0.3s ease; }
  div#hht-services-{{ section.id }} .hht-anim-glow:hover { box-shadow: 0 0 24px color-mix(in srgb, var(--accent) 55%, transparent); border-color: var(--accent); }
  div#hht-services-{{ section.id }} .hht-anim-scale { transition: transform 0.3s ease; }
  div#hht-services-{{ section.id }} .hht-anim-scale:hover { transform: scale(1.01); }

  /* Location targeting on rows — loc1 = Austin only, loc12 = Austin+Houston, loc3 = Dallas only */
  div#hht-services-{{ section.id }}.show-loc1 .target-loc2,
  div#hht-services-{{ section.id }}.show-loc1 .target-loc3 { display: none !important; }
  div#hht-services-{{ section.id }}.show-loc2 .target-loc1,
  div#hht-services-{{ section.id }}.show-loc2 .target-loc3,
  div#hht-services-{{ section.id }}.show-loc2 .target-loc12 { display: none !important; }
  div#hht-services-{{ section.id }}.show-loc3 .target-loc1,
  div#hht-services-{{ section.id }}.show-loc3 .target-loc2,
  div#hht-services-{{ section.id }}.show-loc3 .target-loc12 { display: none !important; }

  div#hht-services-{{ section.id }} .loc2-display,
  div#hht-services-{{ section.id }} .loc3-display { display: none !important; }
  div#hht-services-{{ section.id }} a.hht-book-btn.loc2-display,
  div#hht-services-{{ section.id }} a.hht-book-btn.loc3-display { display: none !important; }
  div#hht-services-{{ section.id }}.show-loc2 .loc1-display,
  div#hht-services-{{ section.id }}.show-loc2 .loc3-display { display: none !important; }
  div#hht-services-{{ section.id }}.show-loc2 span.loc2-display { display: inline !important; }
  div#hht-services-{{ section.id }}.show-loc2 span.price-sub.loc2-display { display: block !important; }
  div#hht-services-{{ section.id }}.show-loc2 a.hht-book-btn.loc2-display { display: inline-flex !important; }
  div#hht-services-{{ section.id }}.show-loc3 .loc1-display,
  div#hht-services-{{ section.id }}.show-loc3 .loc2-display { display: none !important; }
  div#hht-services-{{ section.id }}.show-loc3 span.loc3-display { display: inline !important; }
  div#hht-services-{{ section.id }}.show-loc3 span.price-sub.loc3-display { display: block !important; }
  div#hht-services-{{ section.id }}.show-loc3 a.hht-book-btn.loc3-display { display: inline-flex !important; }
  div#hht-services-{{ section.id }} span.price-sub.loc1-display { display: block !important; }
  div#hht-services-{{ section.id }}.show-loc2 span.price-sub.loc1-display,
  div#hht-services-{{ section.id }}.show-loc3 span.price-sub.loc1-display { display: none !important; }

  /* Mobile */
  @media (max-width: 820px) {
    div#hht-services-{{ section.id }} { padding: 28px 14px 48px; }
    div#hht-services-{{ section.id }} .hht-pair-row { grid-template-columns: 1fr; gap: 16px; }
    div#hht-services-{{ section.id }} .hht-section-card--featured .hht-section-body { grid-template-columns: 1fr; }
    div#hht-services-{{ section.id }} .hht-studio-strip__grid { grid-template-columns: repeat(2, 1fr); }
    div#hht-services-{{ section.id }} .hht-section-strip { padding: 22px 20px 18px; }
    div#hht-services-{{ section.id }} .hht-section-body { padding: 6px 22px 24px; }
    div#hht-services-{{ section.id }} .hht-row { grid-template-columns: 1fr auto; column-gap: 14px; }
    div#hht-services-{{ section.id }} .hht-row-title { font-size: 0.95rem; }
    div#hht-services-{{ section.id }} .hht-row-price { font-size: 1.5rem; }
    div#hht-services-{{ section.id }} a.hht-book-btn { min-height: 44px !important; padding: 0 22px !important; font-size: 0.8125rem !important; }
    div#hht-services-{{ section.id }} .hht-loc-toggle { width: 100%; display: grid; grid-template-columns: repeat(3, 1fr); }
    div#hht-services-{{ section.id }} button.hht-loc-btn { width: 100% !important; min-width: 0 !important; padding: 10px 8px !important; font-size: 0.8125rem !important; }
  }
  @media (max-width: 480px) {
    div#hht-services-{{ section.id }} .hht-row {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto auto;
    }
    div#hht-services-{{ section.id }} .hht-row-head { grid-column: 1; grid-row: 1; }
    div#hht-services-{{ section.id }} .hht-row-price { grid-column: 1; grid-row: 2; text-align: left; margin-top: 4px; }
    div#hht-services-{{ section.id }} .hht-row-desc { grid-column: 1; grid-row: 3; }
    div#hht-services-{{ section.id }} a.hht-book-btn { grid-column: 1; grid-row: 4; }
  }
{% endstyle %}

<div id="hht-services-{{ section.id }}" class="hht-services-wrapper show-loc1 hht-loc-booting" data-default-location="{{ section.settings.default_location | default: 'austin' }}">
  <div class="hht-container">

    {%- comment -%} ============ PAGE HEADER ============ {%- endcomment -%}
    {%- unless section.settings.hide_page_heading -%}
    <div class="hht-header{% if section.settings.compact_heading %} hht-header--compact{% endif %}">
      {% if section.settings.eyebrow != blank %}<span class="hht-header__eyebrow">{{ section.settings.eyebrow }}</span>{% endif %}
      <h1>{{ section.settings.heading }}</h1>
      {% if section.settings.show_location_toggle and section.settings.lock_location == false %}
        <div class="hht-subheading">{{ section.settings.subheading }}</div>
        <div class="hht-loc-toggle" role="tablist" aria-label="Studio location">
          <button class="hht-loc-btn loc-btn-1 active" type="button" role="tab" aria-selected="true" aria-controls="hht-services-live-{{ section.id }}">{{ section.settings.loc1_name }}</button>
          <button class="hht-loc-btn loc-btn-2" type="button" role="tab" aria-selected="false" aria-controls="hht-services-live-{{ section.id }}">{{ section.settings.loc2_name }}</button>
          <button class="hht-loc-btn loc-btn-3" type="button" role="tab" aria-selected="false" aria-controls="hht-services-live-{{ section.id }}">{{ section.settings.loc3_name }}</button>
        </div>
        <p id="hht-services-live-{{ section.id }}" class="visually-hidden" aria-live="polite" data-hht-loc-live></p>
      {% elsif section.settings.lock_location -%}
        <div class="hht-subheading">{{ section.settings.subheading }}</div>
      {% endif %}
    </div>
    {%- endunless -%}

    {%- if section.settings.show_studio_photos -%}
    <div class="hht-studio-strip" aria-label="Studio photos">
      <div class="hht-studio-panel" data-studio="austin">
        <div class="hht-studio-strip__grid">
          <div class="hht-studio-strip__cell"><img src="{% if section.settings.austin_photo_1 != blank %}{{ section.settings.austin_photo_1 | image_url: width: 480 }}{% else %}{{ 'hht-location-austin.jpg' | asset_url }}{% endif %}" alt="Hush Hush Tan Austin studio" loading="lazy" width="240" height="180"></div>
          <div class="hht-studio-strip__cell"><img src="{% if section.settings.austin_photo_2 != blank %}{{ section.settings.austin_photo_2 | image_url: width: 480 }}{% else %}{{ 'hht-reception.jpg' | asset_url }}{% endif %}" alt="Austin studio reception" loading="lazy" width="240" height="180"></div>
          <div class="hht-studio-strip__cell"><img src="{% if section.settings.austin_photo_3 != blank %}{{ section.settings.austin_photo_3 | image_url: width: 480 }}{% else %}{{ 'hht-storefront.jpg' | asset_url }}{% endif %}" alt="Austin studio interior" loading="lazy" width="240" height="180"></div>
          <div class="hht-studio-strip__cell"><img src="{% if section.settings.austin_photo_4 != blank %}{{ section.settings.austin_photo_4 | image_url: width: 480 }}{% else %}{{ 'hht-moment-prep.jpg' | asset_url }}{% endif %}" alt="Austin glow prep" loading="lazy" width="240" height="180"></div>
        </div>
        <p class="hht-studio-strip__meta">Austin · West 6th Street</p>
      </div>
      <div class="hht-studio-panel" data-studio="houston">
        <div class="hht-studio-strip__grid">
          <div class="hht-studio-strip__cell"><img src="{% if section.settings.houston_photo_1 != blank %}{{ section.settings.houston_photo_1 | image_url: width: 480 }}{% else %}{{ 'hht-location-houston.jpg' | asset_url }}{% endif %}" alt="Hush Hush Tan Houston studio" loading="lazy" width="240" height="180"></div>
          <div class="hht-studio-strip__cell"><img src="{% if section.settings.houston_photo_2 != blank %}{{ section.settings.houston_photo_2 | image_url: width: 480 }}{% else %}{{ 'hht-moment-group.jpg' | asset_url }}{% endif %}" alt="Houston studio experience" loading="lazy" width="240" height="180"></div>
          <div class="hht-studio-strip__cell"><img src="{% if section.settings.houston_photo_3 != blank %}{{ section.settings.houston_photo_3 | image_url: width: 480 }}{% else %}{{ 'hht-glow-editorial.jpg' | asset_url }}{% endif %}" alt="Houston studio glow" loading="lazy" width="240" height="180"></div>
          <div class="hht-studio-strip__cell"><img src="{% if section.settings.houston_photo_4 != blank %}{{ section.settings.houston_photo_4 | image_url: width: 480 }}{% else %}{{ 'hht-moment-aftercare.jpg' | asset_url }}{% endif %}" alt="Houston aftercare" loading="lazy" width="240" height="180"></div>
        </div>
        <p class="hht-studio-strip__meta">Houston · M-K-T Heights</p>
      </div>
      <div class="hht-studio-panel" data-studio="dallas">
        <div class="hht-studio-strip__grid">
          <div class="hht-studio-strip__cell"><img src="{% if section.settings.dallas_photo_1 != blank %}{{ section.settings.dallas_photo_1 | image_url: width: 480 }}{% else %}{{ 'hht-location-dallas.jpg' | asset_url }}{% endif %}" alt="Hush Hush Tan Dallas studio" loading="lazy" width="240" height="180"></div>
          <div class="hht-studio-strip__cell"><img src="{% if section.settings.dallas_photo_2 != blank %}{{ section.settings.dallas_photo_2 | image_url: width: 480 }}{% else %}{{ 'hht-glow-wall.jpg' | asset_url }}{% endif %}" alt="Dallas studio interior" loading="lazy" width="240" height="180"></div>
          <div class="hht-studio-strip__cell"><img src="{% if section.settings.dallas_photo_3 != blank %}{{ section.settings.dallas_photo_3 | image_url: width: 480 }}{% else %}{{ 'hht-science-shelf.jpg' | asset_url }}{% endif %}" alt="Dallas product shelf" loading="lazy" width="240" height="180"></div>
          <div class="hht-studio-strip__cell"><img src="{% if section.settings.dallas_photo_4 != blank %}{{ section.settings.dallas_photo_4 | image_url: width: 480 }}{% else %}{{ 'hht-glow-wall-2.jpg' | asset_url }}{% endif %}" alt="Dallas glow wall" loading="lazy" width="240" height="180"></div>
        </div>
        <p class="hht-studio-strip__meta">Dallas · Oak Lawn</p>
      </div>
    </div>
    {%- endif -%}

    {%- comment -%}
      ============ RENDER WALK ============
      Two-pass approach:
      Pass 1: Build a list of "sections" — each section_header block is a section, with the service_row blocks that follow it (until the next section_header) as its children.
      Pass 2: Walk the sections list. If a section's "pair_next" is true AND the next section exists, render both inside a .hht-pair-row wrapper. Otherwise render full-width.
    {%- endcomment -%}

    {%- comment -%} Pass 1: assign each block to its parent section index {%- endcomment -%}
    {%- assign section_indexes = '' -%}
    {%- assign current_section_idx = -1 -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'section_header' -%}
        {%- assign current_section_idx = forloop.index0 -%}
        {%- assign section_indexes = section_indexes | append: forloop.index0 | append: ',' -%}
      {%- endif -%}
    {%- endfor -%}
    {%- assign section_idx_list = section_indexes | split: ',' -%}
    {%- assign total_sections = section_idx_list | size -%}

    {%- comment -%} Pass 2: walk sections. Use a counter to know when to skip the next one (because it was paired). {%- endcomment -%}
    {%- assign skip_next = false -%}
    {%- for s_idx_str in section_idx_list -%}
      {%- if skip_next -%}
        {%- assign skip_next = false -%}
        {%- continue -%}
      {%- endif -%}

      {%- assign s_idx = s_idx_str | plus: 0 -%}
      {%- assign section_block = section.blocks[s_idx] -%}

      {%- comment -%} Find next section index (if any) to use as upper bound for child rows {%- endcomment -%}
      {%- assign next_pos = forloop.index0 | plus: 1 -%}
      {%- if next_pos < total_sections -%}
        {%- assign next_s_idx_str = section_idx_list[next_pos] -%}
        {%- assign next_s_idx = next_s_idx_str | plus: 0 -%}
        {%- assign has_next_section = true -%}
      {%- else -%}
        {%- assign next_s_idx = 999999 -%}
        {%- assign has_next_section = false -%}
      {%- endif -%}

      {%- comment -%} Decide if this section pairs with the next one {%- endcomment -%}
      {%- assign pair_now = false -%}
      {%- if section_block.settings.pair_next and has_next_section -%}
        {%- assign pair_now = true -%}
        {%- assign next_section_block = section.blocks[next_s_idx] -%}

        {%- comment -%} Find the bound for the PAIRED section's children {%- endcomment -%}
        {%- assign nextnext_pos = next_pos | plus: 1 -%}
        {%- if nextnext_pos < total_sections -%}
          {%- assign nextnext_s_idx_str = section_idx_list[nextnext_pos] -%}
          {%- assign nextnext_s_idx = nextnext_s_idx_str | plus: 0 -%}
        {%- else -%}
          {%- assign nextnext_s_idx = 999999 -%}
        {%- endif -%}
      {%- endif -%}

      {% if pair_now %}
        <div class="hht-pair-row">
          {%- comment -%} CARD 1 (this section) {%- endcomment -%}
          <div class="hht-section-card hht-section-card--{{ section_block.settings.section_style | default: 'default' }} hht-anim-{{ section_block.settings.animation | default: 'float' }}" {{ section_block.shopify_attributes }}>
            <div class="hht-section-strip">
              {% render 'hht-section-icon', block: section_block %}
              <h2 class="hht-section-title">
                {% if section_block.settings.title_a != blank %}<span class="roman">{{ section_block.settings.title_a }}</span>{% endif %}
                {% if section_block.settings.title_b != blank %} {{ section_block.settings.title_b }}{% endif %}
              </h2>
              {% if section_block.settings.note != blank %}<p class="hht-section-note">{{ section_block.settings.note }}</p>{% endif %}
            </div>
            <div class="hht-section-body">
              {% for child in section.blocks %}
                {% if forloop.index0 > s_idx and forloop.index0 < next_s_idx and child.type == 'service_row' %}
                  <div class="hht-row target-{{ child.settings.target_location | default: 'all' }}" {{ child.shopify_attributes }}>
                    <div class="hht-row-head">
                      <h3 class="hht-row-title">{{ child.settings.title }}</h3>
                      {% if child.settings.badge != blank %}
                        {%- capture badge_style -%}
                          {%- if child.settings.badge_bg != blank %}background:{{ child.settings.badge_bg }};{% endif -%}
                          {%- if child.settings.badge_text_color != blank %}color:{{ child.settings.badge_text_color }};{% endif -%}
                        {%- endcapture -%}
                        <span class="hht-badge"{% if badge_style != blank %} style="{{ badge_style }}"{% endif %}>{% if child.settings.badge_icon != blank %}<span class="hht-badge-icon">{{ child.settings.badge_icon }}</span>{% endif %}{{ child.settings.badge }}</span>
                      {% endif %}
                    </div>
                    <div class="hht-row-price">
                      {% if child.settings.price_prefix != blank %}{{ child.settings.price_prefix }}{% endif %}<span class="loc1-display">{{ child.settings.price_loc1 }}</span><span class="loc2-display">{{ child.settings.price_loc2 }}</span><span class="loc3-display">{{ child.settings.price_loc3 }}</span>
                      {%- liquid
                        assign sub1 = child.settings.price_sub_loc1 | default: child.settings.price_sub
                        assign sub2 = child.settings.price_sub_loc2 | default: child.settings.price_sub
                        assign sub3 = child.settings.price_sub_loc3 | default: child.settings.price_sub
                      -%}
                      {% if sub1 != blank %}<span class="price-sub loc1-display">{{ sub1 }}</span>{% endif %}
                      {% if sub2 != blank %}<span class="price-sub loc2-display">{{ sub2 }}</span>{% endif %}
                      {% if sub3 != blank %}<span class="price-sub loc3-display">{{ sub3 }}</span>{% endif %}
                    </div>
                    {% if child.settings.description != blank %}<p class="hht-row-desc">{{ child.settings.description }}</p>{% endif %}
                    {% if child.settings.benefits != blank %}
                      <div class="hht-row-desc">
                        <ul>
                          {% assign feats = child.settings.benefits | split: ',' %}
                          {% for feat in feats %}<li>· {{ feat | strip }}</li>{% endfor %}
                        </ul>
                      </div>
                    {% endif %}
                    {% if child.settings.button_text != blank %}
                      <a href="{{ child.settings.link_loc1 | default: '#booking' }}" class="hht-book-btn loc1-display">{{ child.settings.button_text }}</a>
                      <a href="{{ child.settings.link_loc2 | default: '#booking' }}" class="hht-book-btn loc2-display">{{ child.settings.button_text }}</a>
                      <a href="{{ child.settings.link_loc3 | default: '#booking' }}" class="hht-book-btn loc3-display">{{ child.settings.button_text }}</a>
                    {% endif %}
                  </div>
                {% endif %}
              {% endfor %}
            </div>
            {% if section_block.settings.footer != blank %}
              <div class="hht-section-foot">{{ section_block.settings.footer }}</div>
            {% endif %}
          </div>

          {%- comment -%} CARD 2 (the paired section) {%- endcomment -%}
          <div class="hht-section-card hht-section-card--{{ next_section_block.settings.section_style | default: 'default' }} hht-anim-{{ next_section_block.settings.animation | default: 'float' }}" {{ next_section_block.shopify_attributes }}>
            <div class="hht-section-strip">
              {% render 'hht-section-icon', block: next_section_block %}
              <h2 class="hht-section-title">
                {% if next_section_block.settings.title_a != blank %}<span class="roman">{{ next_section_block.settings.title_a }}</span>{% endif %}
                {% if next_section_block.settings.title_b != blank %} {{ next_section_block.settings.title_b }}{% endif %}
              </h2>
              {% if next_section_block.settings.note != blank %}<p class="hht-section-note">{{ next_section_block.settings.note }}</p>{% endif %}
            </div>
            <div class="hht-section-body">
              {% for child in section.blocks %}
                {% if forloop.index0 > next_s_idx and forloop.index0 < nextnext_s_idx and child.type == 'service_row' %}
                  <div class="hht-row target-{{ child.settings.target_location | default: 'all' }}" {{ child.shopify_attributes }}>
                    <div class="hht-row-head">
                      <h3 class="hht-row-title">{{ child.settings.title }}</h3>
                      {% if child.settings.badge != blank %}
                        {%- capture badge_style -%}
                          {%- if child.settings.badge_bg != blank %}background:{{ child.settings.badge_bg }};{% endif -%}
                          {%- if child.settings.badge_text_color != blank %}color:{{ child.settings.badge_text_color }};{% endif -%}
                        {%- endcapture -%}
                        <span class="hht-badge"{% if badge_style != blank %} style="{{ badge_style }}"{% endif %}>{% if child.settings.badge_icon != blank %}<span class="hht-badge-icon">{{ child.settings.badge_icon }}</span>{% endif %}{{ child.settings.badge }}</span>
                      {% endif %}
                    </div>
                    <div class="hht-row-price">
                      {% if child.settings.price_prefix != blank %}{{ child.settings.price_prefix }}{% endif %}<span class="loc1-display">{{ child.settings.price_loc1 }}</span><span class="loc2-display">{{ child.settings.price_loc2 }}</span><span class="loc3-display">{{ child.settings.price_loc3 }}</span>
                      {%- liquid
                        assign sub1 = child.settings.price_sub_loc1 | default: child.settings.price_sub
                        assign sub2 = child.settings.price_sub_loc2 | default: child.settings.price_sub
                        assign sub3 = child.settings.price_sub_loc3 | default: child.settings.price_sub
                      -%}
                      {% if sub1 != blank %}<span class="price-sub loc1-display">{{ sub1 }}</span>{% endif %}
                      {% if sub2 != blank %}<span class="price-sub loc2-display">{{ sub2 }}</span>{% endif %}
                      {% if sub3 != blank %}<span class="price-sub loc3-display">{{ sub3 }}</span>{% endif %}
                    </div>
                    {% if child.settings.description != blank %}<p class="hht-row-desc">{{ child.settings.description }}</p>{% endif %}
                    {% if child.settings.benefits != blank %}
                      <div class="hht-row-desc">
                        <ul>
                          {% assign feats = child.settings.benefits | split: ',' %}
                          {% for feat in feats %}<li>· {{ feat | strip }}</li>{% endfor %}
                        </ul>
                      </div>
                    {% endif %}
                    {% if child.settings.button_text != blank %}
                      <a href="{{ child.settings.link_loc1 | default: '#booking' }}" class="hht-book-btn loc1-display">{{ child.settings.button_text }}</a>
                      <a href="{{ child.settings.link_loc2 | default: '#booking' }}" class="hht-book-btn loc2-display">{{ child.settings.button_text }}</a>
                      <a href="{{ child.settings.link_loc3 | default: '#booking' }}" class="hht-book-btn loc3-display">{{ child.settings.button_text }}</a>
                    {% endif %}
                  </div>
                {% endif %}
              {% endfor %}
            </div>
            {% if next_section_block.settings.footer != blank %}
              <div class="hht-section-foot">{{ next_section_block.settings.footer }}</div>
            {% endif %}
          </div>
        </div>
        {%- assign skip_next = true -%}
      {% else %}
        {%- comment -%} FULL-WIDTH single section {%- endcomment -%}
        <div class="hht-section-card hht-section-card--{{ section_block.settings.section_style | default: 'default' }} hht-anim-{{ section_block.settings.animation | default: 'float' }}" {{ section_block.shopify_attributes }}>
          <div class="hht-section-strip">
            {% render 'hht-section-icon', block: section_block %}
            <h2 class="hht-section-title">
              {% if section_block.settings.title_a != blank %}<span class="roman">{{ section_block.settings.title_a }}</span>{% endif %}
              {% if section_block.settings.title_b != blank %} {{ section_block.settings.title_b }}{% endif %}
            </h2>
            {% if section_block.settings.note != blank %}<p class="hht-section-note">{{ section_block.settings.note }}</p>{% endif %}
          </div>
          <div class="hht-section-body">
            {% for child in section.blocks %}
              {% if forloop.index0 > s_idx and forloop.index0 < next_s_idx and child.type == 'service_row' %}
                <div class="hht-row target-{{ child.settings.target_location | default: 'all' }}" {{ child.shopify_attributes }}>
                  <div class="hht-row-head">
                    <h3 class="hht-row-title">{{ child.settings.title }}</h3>
                    {% if child.settings.badge != blank %}
                        {%- capture badge_style -%}
                          {%- if child.settings.badge_bg != blank %}background:{{ child.settings.badge_bg }};{% endif -%}
                          {%- if child.settings.badge_text_color != blank %}color:{{ child.settings.badge_text_color }};{% endif -%}
                        {%- endcapture -%}
                        <span class="hht-badge"{% if badge_style != blank %} style="{{ badge_style }}"{% endif %}>{% if child.settings.badge_icon != blank %}<span class="hht-badge-icon">{{ child.settings.badge_icon }}</span>{% endif %}{{ child.settings.badge }}</span>
                      {% endif %}
                  </div>
                  <div class="hht-row-price">
                    {% if child.settings.price_prefix != blank %}{{ child.settings.price_prefix }}{% endif %}<span class="loc1-display">{{ child.settings.price_loc1 }}</span><span class="loc2-display">{{ child.settings.price_loc2 }}</span><span class="loc3-display">{{ child.settings.price_loc3 }}</span>
                    {%- liquid
                        assign sub1 = child.settings.price_sub_loc1 | default: child.settings.price_sub
                        assign sub2 = child.settings.price_sub_loc2 | default: child.settings.price_sub
                        assign sub3 = child.settings.price_sub_loc3 | default: child.settings.price_sub
                      -%}
                      {% if sub1 != blank %}<span class="price-sub loc1-display">{{ sub1 }}</span>{% endif %}
                      {% if sub2 != blank %}<span class="price-sub loc2-display">{{ sub2 }}</span>{% endif %}
                      {% if sub3 != blank %}<span class="price-sub loc3-display">{{ sub3 }}</span>{% endif %}
                  </div>
                  {% if child.settings.description != blank %}<p class="hht-row-desc">{{ child.settings.description }}</p>{% endif %}
                  {% if child.settings.benefits != blank %}
                    <div class="hht-row-desc">
                      <ul>
                        {% assign feats = child.settings.benefits | split: ',' %}
                        {% for feat in feats %}<li>· {{ feat | strip }}</li>{% endfor %}
                      </ul>
                    </div>
                  {% endif %}
                  {% if child.settings.button_text != blank %}
                    <a href="{{ child.settings.link_loc1 | default: '#booking' }}" class="hht-book-btn loc1-display">{{ child.settings.button_text }}</a>
                    <a href="{{ child.settings.link_loc2 | default: '#booking' }}" class="hht-book-btn loc2-display">{{ child.settings.button_text }}</a>
                    <a href="{{ child.settings.link_loc3 | default: '#booking' }}" class="hht-book-btn loc3-display">{{ child.settings.button_text }}</a>
                  {% endif %}
                </div>
              {% endif %}
            {% endfor %}
          </div>
          {% if section_block.settings.footer != blank %}
            <div class="hht-section-foot">{{ section_block.settings.footer }}</div>
          {% endif %}
        </div>
      {% endif %}
    {%- endfor -%}

    {%- if section.settings.show_chat_widget -%}
    <div class="hht-chat-widget-wrap" aria-label="Studio chat">
      <div class="hht-chat-widget-panel" data-chat-loc="austin" id="hht-chat-austin-{{ section.id }}"></div>
      <div class="hht-chat-widget-panel" data-chat-loc="houston" id="hht-chat-houston-{{ section.id }}"></div>
      <div class="hht-chat-widget-panel" data-chat-loc="dallas" id="hht-chat-dallas-{{ section.id }}"></div>
    </div>
    {%- endif -%}

  </div>
</div>

<script>
  (function() {
    document.addEventListener('DOMContentLoaded', function() {
      var wrapper = document.getElementById('hht-services-{{ section.id }}');
      if (!wrapper) return;
      var btn1 = wrapper.querySelector('.loc-btn-1');
      var btn2 = wrapper.querySelector('.loc-btn-2');
      var btn3 = wrapper.querySelector('.loc-btn-3');

      var widgetIds = {
        austin: '6a271bc1ea8f17ad15e03cce',
        houston: '6a271a87ea8f17ad15dffdb2',
        dallas: '6a271be49372a70f7d3c61f8'
      };
      var loadedWidgets = {};

      function loadChatWidget(city, container) {
        if (!container || loadedWidgets[city]) return;
        var widgetId = widgetIds[city];
        if (!widgetId) return;
        var script = document.createElement('script');
        script.src = 'https://beta.leadconnectorhq.com/loader.js';
        script.setAttribute('data-resources-url', 'https://beta.leadconnectorhq.com/chat-widget/loader.js');
        script.setAttribute('data-widget-id', widgetId);
        script.async = true;
        container.appendChild(script);
        loadedWidgets[city] = true;
      }

      var lockedLocation = {{ section.settings.lock_location | json }};
      var defaultLoc = wrapper.getAttribute('data-default-location') || 'austin';

      var locationMap = [
        { btn: btn1, locClass: 'show-loc1', slug: 'austin', city: 'austin' },
        { btn: btn2, locClass: 'show-loc2', slug: 'houston', city: 'houston' },
        { btn: btn3, locClass: 'show-loc3', slug: 'dallas', city: 'dallas' }
      ];

      function activateByCity(city) {
        for (var i = 0; i < locationMap.length; i++) {
          if (locationMap[i].city === city) return activateByEntry(locationMap[i], false);
        }
        return false;
      }

      function reset() {
        wrapper.classList.remove('show-loc1', 'show-loc2', 'show-loc3');
        if (btn1) { btn1.classList.remove('active'); btn1.setAttribute('aria-selected', 'false'); }
        if (btn2) { btn2.classList.remove('active'); btn2.setAttribute('aria-selected', 'false'); }
        if (btn3) { btn3.classList.remove('active'); btn3.setAttribute('aria-selected', 'false'); }
      }

      function activateByEntry(entry, updateHash) {
        if (!entry) return false;
        reset();
        wrapper.classList.add(entry.locClass);
        if (entry.btn) {
          entry.btn.classList.add('active');
          entry.btn.setAttribute('aria-selected', 'true');
        }
        var chatPanel = wrapper.querySelector('[data-chat-loc="' + entry.city + '"]');
        loadChatWidget(entry.city, chatPanel);
        var live = wrapper.querySelector('[data-hht-loc-live]');
        if (live) {
          live.textContent = (entry.btn ? entry.btn.textContent.trim() : entry.city) + ' pricing and booking options are now shown.';
        }
        document.querySelectorAll('[data-hht-sync-book]').forEach(function (el) {
          var url = el.getAttribute('data-book-' + entry.city);
          if (url) el.setAttribute('href', url);
        });
        try {
          window.dispatchEvent(new CustomEvent('hht:locationchange', { detail: { city: entry.city, slug: entry.slug } }));
        } catch (e) {}
        if (updateHash && !lockedLocation) {
          try {
            var url = new URL(window.location.href);
            url.searchParams.set('location', entry.slug);
            url.hash = '';
            if (history && history.replaceState) {
              history.replaceState({ hhtLocation: entry.slug }, '', url.pathname + url.search);
            }
          } catch (err) {
            if (history && history.replaceState) {
              history.replaceState(null, '', '?location=' + entry.slug);
            }
          }
        }
        return true;
      }

      function activateBySlug(slug, updateHash) {
        if (!slug) return false;
        slug = String(slug).trim().toLowerCase();
        for (var i = 0; i < locationMap.length; i++) {
          if (locationMap[i].slug && locationMap[i].slug === slug) {
            return activateByEntry(locationMap[i], updateHash);
          }
        }
        return false;
      }

      if (btn1) btn1.addEventListener('click', function () { activateByEntry(locationMap[0], true); });
      if (btn2) btn2.addEventListener('click', function () { activateByEntry(locationMap[1], true); });
      if (btn3) btn3.addEventListener('click', function () { activateByEntry(locationMap[2], true); });

      function applyFromUrl() {
        if (lockedLocation) {
          activateByCity(defaultLoc);
          return;
        }
        var search = window.location.search || '';
        var m = search.match(/[?&](?:loc|location)=([^&#]+)/i);
        if (m && m[1]) {
          if (activateBySlug(decodeURIComponent(m[1]), false)) return;
        }
        var hash = (window.location.hash || '').replace(/^#/, '');
        if (activateBySlug(hash, false)) return;
        var path = (window.location.pathname || '').toLowerCase();
        if (path.indexOf('dallas') !== -1) { activateByCity('dallas'); return; }
        if (path.indexOf('houston') !== -1) { activateByCity('houston'); return; }
        if (path.indexOf('austin') !== -1) { activateByCity('austin'); return; }
        activateByCity(defaultLoc);
      }
      try {
        applyFromUrl();
      } finally {
        wrapper.classList.remove('hht-loc-booting');
      }
      window.addEventListener('hashchange', applyFromUrl);
      window.addEventListener('popstate', applyFromUrl);
    });
  })();
</script>

