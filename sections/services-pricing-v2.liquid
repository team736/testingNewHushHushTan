{%- comment -%}
  Hush Hush Tan — Services / Pricing V2
  Location-tabbed services menu aligned with homepage design system
  (base.css tokens, section-head, hht-location-tabs, btn--pill).
{%- endcomment -%}

{%- assign uid = 'hht-spv2-' | append: section.id -%}

{%- assign book_austin  = settings.book_austin_url  | default: 'https://go.booker.com/location/hushhushtan/service-menu' -%}
{%- assign book_houston = settings.book_houston_url | default: 'https://go.booker.com/location/hushhushtanhouston/service-menu' -%}
{%- assign book_dallas  = settings.book_dallas_url  | default: 'https://go.booker.com/location/hushhushtandallas/service-menu' -%}

<section id="{{ uid }}" class="section section-white hht-spv2" aria-labelledby="{{ uid }}-title">
  {%- if section.settings.homepage_anchors -%}
    <span id="services" class="hht-spv2__anchor" aria-hidden="true"></span>
    <span id="memberships" class="hht-spv2__anchor" aria-hidden="true"></span>
  {%- endif -%}

  <div class="container container--home">
    <div class="section-head">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 id="{{ uid }}-title">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="section-head__sub">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="hht-spv2__tabs-wrap">
      <div class="hht-location-tabs hht-spv2__location-tabs" role="tablist" aria-label="Choose location">
        <button type="button" class="hht-location-tab active" role="tab" aria-selected="true" data-tab="austin" aria-controls="{{ uid }}-panel">Austin</button>
        <button type="button" class="hht-location-tab" role="tab" aria-selected="false" data-tab="houston" aria-controls="{{ uid }}-panel">Houston</button>
        <button type="button" class="hht-location-tab" role="tab" aria-selected="false" data-tab="dallas" aria-controls="{{ uid }}-panel">Dallas</button>
      </div>
    </div>

    <div id="{{ uid }}-panel" class="hht-spv2__grid" role="tabpanel" data-panel></div>
  </div>
</section>

<script>
(function(){
  "use strict";
  var root = document.getElementById('{{ uid }}');
  if(!root) return;
  var panel = root.querySelector('[data-panel]');

  var URL = {
    austin:  { book: {{ book_austin | json }},  join: {{ section.settings.membership_austin_url | default: 'https://go.booker.com/location/hushhushtan/buy/membership' | json }},  pack: {{ section.settings.package_austin_url | default: 'https://go.booker.com/location/hushhushtan/buy/series' | json }} },
    houston: { book: {{ book_houston | json }}, join: {{ section.settings.membership_houston_url | default: 'https://go.booker.com/location/hushhushtanhouston/buy/membership' | json }}, pack: {{ section.settings.package_houston_url | default: 'https://go.booker.com/location/hushhushtanhouston/buy/series' | json }} },
    dallas:  { book: {{ book_dallas | json }},  join: {{ section.settings.membership_dallas_url | default: 'https://go.booker.com/location/hushhushtandallas/buy/membership' | json }},  pack: {{ section.settings.package_dallas_url | default: 'https://go.booker.com/location/hushhushtandallas/buy/series' | json }} }
  };

  var ICONS = {
    sun:'<img class="hht-spv2__icimg" src="{{ 'icon-core-services.png' | asset_url }}" alt="" width="240" height="240" loading="lazy">',
    sparkle:'<img class="hht-spv2__icimg" src="{{ 'icon-add-ons.png' | asset_url }}" alt="" width="240" height="240" loading="lazy">',
    sunrise:'<img class="hht-spv2__icimg" src="{{ 'icon-partial-tans.png' | asset_url }}" alt="" width="240" height="240" loading="lazy">',
    crown:'<img class="hht-spv2__icimg" src="{{ 'icon-memberships.png' | asset_url }}" alt="" width="240" height="240" loading="lazy">',
    gift:'<img class="hht-spv2__icimg" src="{{ 'icon-tan-packages.png' | asset_url }}" alt="" width="240" height="240" loading="lazy">',
    star:'<img class="hht-spv2__icimg" src="{{ 'icon-special-offer.png' | asset_url }}" alt="" width="240" height="240" loading="lazy">',
    heart:'<img class="hht-spv2__icimg" src="{{ 'icon-group-experiences.png' | asset_url }}" alt="" width="240" height="240" loading="lazy">'
  };

  function makeLocation(cfg){
    var U = cfg.urls, cats = [];

    cats.push({ icon:'sun', title:'Core Services', span:'full', subtitle:'First-timer? Start here.', rows:[
      { name:'Custom Glow', badge:'Most Popular', desc:'Customized to your individual skin tone', price:'$'+cfg.core.custom, btn:{label:'Book Now',url:U.book} },
      { name:'Clear Glow', badge:'First-Timer Fave', desc:'Clear solution for a natural finish', price:'$'+cfg.core.clear, btn:{label:'Book Now',url:U.book} },
      { name:'Rapid Glow', badge:'Fast Results', desc:'Rinse in 2-4 hours', price:'$'+cfg.core.rapid, btn:{label:'Book Now',url:U.book} }
    ]});

    cats.push({ icon:'crown', title:'Memberships Services', span:'half',
      note:'Rapid Glow is not available for the complimentary tan; option to upgrade available.',
      rows:[
        { name:'Glow Pass', bullets:['35% off all tans','15% off all products','Cancel anytime'], price:'$'+cfg.memb.pass, priceSub:'per month', btn:{label:'Join Now',url:U.join} },
        { name:'Glow Club', bullets:['1 complimentary tan per month','25% off all additional tans','15% off all products','Cancel anytime'], price:'$'+cfg.memb.club, priceSub:'per month', btn:{label:'Join Now',url:U.join} }
      ]});

    cats.push({ icon:'gift', title:'Tan Packages', span:'half',
      note:'Please note, Rapid Glow is not included in the package pricing. Upgrade available upon request. Packages available for non-members only.',
      rows:[
        { name:'6-Pack', bullets:['6 full spray tan sessions','Mix and match any core service','Valid for 6 months from purchase'], price:'$'+cfg.pack.six, priceSub:'just $'+cfg.pack.sixSession+'/session', btn:{label:'Buy the 6-Pack',url:U.pack} },
        { name:'10-Pack', bullets:['10 full spray tan sessions','Mix and match any core service','Valid for 6 months from purchase'], price:'$'+cfg.pack.ten, priceSub:'just $'+cfg.pack.tenSession+'/session', btn:{label:'Buy the 10-Pack',url:U.pack} }
      ]});

    cats.push({ icon:'sunrise', title:'Partial Tans', span:'half', rows:[
      { name:'Face', desc:'Face only', price:'$'+cfg.partial.face, btn:{label:'Book Now',url:U.book} },
      { name:'Upper / Lower Only', desc:'An upper or lower spray; upper is torso and arms only, a lower is full legs only. Exclude face spray.', price:'$'+cfg.partial.ul, btn:{label:'Book Now',url:U.book} },
      { name:'Partial Upper / Lower', desc:'Partial upper or partial lower spray; partial upper is chest and arms or partial lower is calves and feet. Excludes face spray.', price:'$'+cfg.partial.partial, btn:{label:'Book Now',url:U.book} }
    ]});

    cats.push({ icon:'sparkle', title:'Add Ons', span:'half', rows:[
      { name:'Gold Glow', desc:'Gold drops are added to give you a subtle elegant shimmer.', price:'+$5', btn:{label:'Book Now',url:U.book} },
      { name:'Bye Bye Tan Line', desc:'Tan line erasing glow by a full body spray.', price:'+$20', btn:{label:'Book Now',url:U.book} },
      { name:'Brazilian Glow', desc:'Custom fabulous double dip. Sprayed twice for a rich, dark tan.', price:'+$25', btn:{label:'Book Now',url:U.book} }
    ]});

    cats.push({ icon:'star', title:'Special Offer', span:'half', rows:[
      { name:'Birthday Glow', desc:'Exclusive pricing for one Custom Glow during your birthday month.', price:'$'+cfg.special, btn:{label:'Book Now',url:U.book} }
    ]});

    cats.push({ icon:'heart', title:'Group Experiences', span:'half',
      note:'Group bookings require advance notice.',
      rows:[
        { name:'Tanning & Mimosas', bullets:['Includes 5 Custom Glow tans','Studio access for your group','Complimentary champagne & mimosas'], price:'$'+cfg.group.mimosas, priceSub:'+$50 ea add’l guest', btn:{label:'Book Now',url:U.book} },
        { name:'Austin Mobile Tanning', badge:'Austin Only', desc:'Bring Hush Hush to you! Requires parties of 5 or more. $75 per person, $15 travel fee if further than 10 miles from studio, $30 hotel travel fee. Please include address and party size in request notes box!', price:'$75 / hour', btn:{label:'Book Now',url:U.book} }
      ]});

    cats.push({ title:'Accessories', span:'full', acc:true, plain:true, rows:[
      { name:'Disposable Boxers', desc:'Purchase available on-site.', price:'$3', priceSub:'Per Pair' },
      { name:'Floral Pasties', desc:'Purchase available on-site.', price:'$2', priceSub:'Per Pair' },
      { name:'C-String Undies', desc:'Wash and wear for multiple glow sessions. Purchase available on-site.', price:'$2', priceSub:'Per Pair' }
    ]});

    cats.push({ title:'Complimentary Gear', span:'full', acc:true, plain:true, rows:[
      { name:'Disposable Undies', price:'Free' },
      { name:'Disposable Nose Plugs', price:'Free' },
      { name:'Disposable Hair Caps', price:'Free' }
    ]});

    return cats;
  }

  function assign(o){ var r={},i,a; for(i=0;i<arguments.length;i++){a=arguments[i];for(var k in a){if(Object.prototype.hasOwnProperty.call(a,k))r[k]=a[k];}} return r; }

  var AH = {
    core:{custom:50,clear:50,rapid:60},
    memb:{pass:29,club:45},
    pack:{six:270,sixSession:'45',ten:400,tenSession:'40'},
    partial:{face:10,ul:25,partial:35},
    special:39,
    group:{mimosas:300}
  };

  var DATA = {
    austin:  makeLocation(assign({urls:URL.austin},  AH)),
    houston: makeLocation(assign({urls:URL.houston}, AH)),
    dallas:  makeLocation({ urls:URL.dallas,
      core:{custom:55,clear:55,rapid:65},
      memb:{pass:39,club:50},
      pack:{six:285,sixSession:'47.50',ten:420,tenSession:'42'},
      partial:{face:12,ul:30,partial:40},
      special:44,
      group:{mimosas:325} })
  };

  function titleHTML(t){ var p=t.split(' '); var last=p.pop(); return (p.length?p.join(' ')+' ':'')+'<em>'+last+'</em>'; }
  function rowHTML(r){
    var price='<div class="hht-spv2__pricewrap"><span class="hht-spv2__price">'+r.price+'</span>'+(r.priceSub?'<span class="hht-spv2__pricesub">'+r.priceSub+'</span>':'')+'</div>';
    var badge=r.badge?'<span class="hht-spv2__badge"><span class="hht-spv2__badge-spark" aria-hidden="true">✨</span> '+r.badge+'</span>':'';
    var name='<div class="hht-spv2__namewrap"><span class="hht-spv2__name">'+r.name+'</span>'+badge+'</div>';
    var detail=r.bullets?'<ul class="hht-spv2__bullets">'+r.bullets.map(function(b){return '<li>'+b+'</li>';}).join('')+'</ul>':(r.desc?'<p class="hht-spv2__desc">'+r.desc+'</p>':'');
    var btn=r.btn?'<a class="hht-spv2__btn" href="'+r.btn.url+'" target="_blank" rel="noopener">'+r.btn.label+'</a>':'';
    return '<div class="hht-spv2__row"><div class="hht-spv2__row-top">'+name+price+'</div>'+detail+btn+'</div>';
  }
  function cardHTML(c){
    var ic = c.icon ? '<span class="hht-spv2__ic">'+(ICONS[c.icon]||'')+'</span>' : '';
    var title = c.plain ? c.title : titleHTML(c.title);
    var head='<div class="hht-spv2__head">'+ic+'<h3 class="hht-spv2__ctitle">'+title+'</h3>'+(c.subtitle?'<p class="hht-spv2__csub">'+c.subtitle+'</p>':'')+'</div>';
    var body='<div class="hht-spv2__body">'+(c.intro?'<p class="hht-spv2__intro">'+c.intro+'</p>':'')+c.rows.map(rowHTML).join('')+(c.note?'<p class="hht-spv2__note">'+c.note+'</p>':'')+'</div>';
    return '<div class="hht-spv2__card'+(c.span==='full'?' hht-spv2__card--full':'')+(c.acc?' hht-spv2__card--acc':'')+'">'+head+body+'</div>';
  }
  function render(loc){ panel.innerHTML = DATA[loc].map(cardHTML).join(''); }

  var tabs = [].slice.call(root.querySelectorAll('[data-tab]'));
  function activate(tab){
    tabs.forEach(function(t){
      var on = t === tab;
      t.classList.toggle('active', on);
      t.setAttribute('aria-selected', on ? 'true' : 'false');
    });
    render(tab.getAttribute('data-tab'));
  }
  tabs.forEach(function(tab,i){
    tab.addEventListener('click', function(){ activate(tab); });
    tab.addEventListener('keydown', function(e){
      if(e.key==='ArrowRight'||e.key==='ArrowLeft'){
        e.preventDefault();
        var d = e.key==='ArrowRight' ? 1 : -1;
        var n = tabs[(i+d+tabs.length)%tabs.length];
        n.focus();
        activate(n);
      }
    });
  });
  render('austin');
})();
</script>

{% schema %}
{
  "name": "Services / Pricing V2",
  "tag": "section",
  "class": "section-services-pricing-v2",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Services & Pricing" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Our Services" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Select a location to get started:" },
    { "type": "checkbox", "id": "homepage_anchors", "label": "Add #services / #memberships scroll anchors", "info": "Keep on when this section is the homepage services/pricing block so the hero CTAs scroll here.", "default": true },
    { "type": "header", "content": "Booker links — Memberships (JOIN NOW)" },
    { "type": "text", "id": "membership_austin_url",  "label": "Austin membership URL",  "default": "https://go.booker.com/location/hushhushtan/buy/membership" },
    { "type": "text", "id": "membership_houston_url", "label": "Houston membership URL", "default": "https://go.booker.com/location/hushhushtanhouston/buy/membership" },
    { "type": "text", "id": "membership_dallas_url",  "label": "Dallas membership URL",  "default": "https://go.booker.com/location/hushhushtandallas/buy/membership" },
    { "type": "header", "content": "Booker links — Packages (BUY PACKAGE)" },
    { "type": "text", "id": "package_austin_url",  "label": "Austin packages URL",  "default": "https://go.booker.com/location/hushhushtan/buy/series" },
    { "type": "text", "id": "package_houston_url", "label": "Houston packages URL", "default": "https://go.booker.com/location/hushhushtanhouston/buy/series" },
    { "type": "text", "id": "package_dallas_url",  "label": "Dallas packages URL",  "default": "https://go.booker.com/location/hushhushtandallas/buy/series" }
  ],
  "presets": [{ "name": "Services / Pricing V2" }]
}
{% endschema %}
