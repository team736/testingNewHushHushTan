{%- comment -%} Austin Mobile Tanning — full page (Default-template fallback) {%- endcomment -%}
{%- liquid
  assign mobile_book = 'https://go.booker.com/location/hushhushtan/detail-summary/4253915?campaign=hush_hush_tan_website_1&source=web_direct'
-%}

{{ 'hht-supporting.css' | asset_url | stylesheet_tag }}

<div class="hht-sp" id="hht-mobile-page">
  <section class="hht-sp__section">
    <div class="hht-sp__wrap">
      <div class="hht-sp-hero__panel">
        <div class="hht-sp-hero__body">
          <span class="hht-sp__eyebrow">Austin-Only Mobile Service</span>
          <h1 class="hht-sp__h1">The Glow Comes to You</h1>
          <p class="hht-sp__lead">Bring the Hush Hush Tan experience to your home, hotel, or event location. Our Austin mobile tanning service is designed for groups of five or more who want personalized airbrush tans without visiting the studio.</p>
          <div class="hht-sp__ctas">
            <a class="btn" href="{{ mobile_book }}" target="_blank" rel="noopener noreferrer">Book Mobile Tanning</a>
            <a class="btn btn--outline" href="#mobile-pricing">View Pricing &amp; Details</a>
          </div>
        </div>
        <div class="hht-sp-hero__media">
          <img src="{{ 'hht-loc-austin-hero.jpg' | asset_url }}" alt="Hush Hush Tan Austin studio exterior and surrounding area" width="900" height="1100" loading="eager">
        </div>
      </div>
    </div>
  </section>

  <section class="hht-sp__section hht-sp__section--lavender" id="mobile-pricing">
    <div class="hht-sp__wrap">
      <div class="hht-sp__center">
        <span class="hht-sp__eyebrow">Austin Mobile</span>
        <h2 class="hht-sp__h2">A Private Group Glow, Wherever You Are</h2>
        <p class="hht-sp__lead">A Hush Hush Tan specialist travels to your Austin-area location and provides individually customized tans for your group. Mobile appointments are designed for parties of five or more and require advance coordination.</p>
      </div>
      <div class="hht-sp-price">
        <span class="hht-sp__eyebrow">Pricing</span>
        <p class="hht-sp-price__amount">$75 <span style="font-size:0.45em;font-family:var(--font-body);font-weight:500;letter-spacing:0.04em;">per person</span></p>
        <p class="hht-sp-price__sub">Five-person minimum · Austin service area only</p>
        <ul class="hht-sp-price__list">
          <li>$75 per person (not per hour)</li>
          <li>$15 travel fee for locations more than 10 miles from the Austin studio</li>
          <li>$30 hotel travel fee where applicable</li>
          <li>Include address and party size in the booking notes</li>
        </ul>
        <a class="btn" href="{{ mobile_book }}" target="_blank" rel="noopener noreferrer">Book Mobile Tanning</a>
      </div>
    </div>
  </section>

  <section class="hht-sp__section">
    <div class="hht-sp__wrap">
      <div class="hht-sp__center">
        <span class="hht-sp__eyebrow">Why Mobile</span>
        <h2 class="hht-sp__h2">Why Book Mobile Tanning</h2>
      </div>
      <div class="hht-sp-grid hht-sp-grid--4">
        <article class="hht-sp-card"><span class="hht-sp-card__label">Convenient Location</span><p>Host the appointment at an eligible home, hotel, or event location.</p></article>
        <article class="hht-sp-card"><span class="hht-sp-card__label">Personalized for Every Guest</span><p>Each application can be tailored to the individual guest’s skin tone and desired result.</p></article>
        <article class="hht-sp-card"><span class="hht-sp-card__label">Ideal for Groups</span><p>A convenient option for bridal parties, celebrations, trips, and event preparation.</p></article>
        <article class="hht-sp-card"><span class="hht-sp-card__label">Professional Experience</span><p>Receive the same personalized Hush Hush Tan approach outside the studio.</p></article>
      </div>
    </div>
  </section>

  <section class="hht-sp__section hht-sp__section--warm">
    <div class="hht-sp__wrap">
      <div class="hht-sp__center">
        <span class="hht-sp__eyebrow">Occasions</span>
        <h2 class="hht-sp__h2">Ideal for Celebrations and Prep</h2>
      </div>
      <div class="hht-sp-grid hht-sp-grid--4">
        <article class="hht-sp-card"><span class="hht-sp-card__label">Bridal Parties</span><p>Glow together before the big day without studio logistics.</p></article>
        <article class="hht-sp-card"><span class="hht-sp-card__label">Bachelorette Weekends</span><p>Keep the itinerary flexible while everyone gets customized color.</p></article>
        <article class="hht-sp-card"><span class="hht-sp-card__label">Birthdays</span><p>Turn a gathering into a shared Hush Hush experience.</p></article>
        <article class="hht-sp-card"><span class="hht-sp-card__label">Hotel Stays</span><p>Ideal when guests are already settled in one place.</p></article>
        <article class="hht-sp-card"><span class="hht-sp-card__label">Vacations</span><p>Prep before travel when timing is tight.</p></article>
        <article class="hht-sp-card"><span class="hht-sp-card__label">Photoshoots</span><p>Coordinate color before on-camera moments.</p></article>
        <article class="hht-sp-card"><span class="hht-sp-card__label">Private Events</span><p>Convenient for corporate or private gatherings with five or more guests.</p></article>
        <article class="hht-sp-card"><span class="hht-sp-card__label">Special Occasions</span><p>Any event where getting to the studio is harder than hosting on-site.</p></article>
      </div>
    </div>
  </section>

  <section class="hht-sp__section">
    <div class="hht-sp__wrap">
      <div class="hht-sp__center">
        <span class="hht-sp__eyebrow">How It Works</span>
        <h2 class="hht-sp__h2">Five Steps to Mobile Glow</h2>
      </div>
      <div class="hht-sp-steps hht-sp-steps--5">
        <div class="hht-sp-step"><h3 class="hht-sp__h3">Gather Your Group</h3><p>A minimum of five people is required.</p></div>
        <div class="hht-sp-step"><h3 class="hht-sp__h3">Submit the Details</h3><p>Include the service address, party size, and relevant access information in the booking notes.</p></div>
        <div class="hht-sp-step"><h3 class="hht-sp__h3">Confirm Travel Charges</h3><p>Travel and hotel fees may apply based on the booking location.</p></div>
        <div class="hht-sp-step"><h3 class="hht-sp__h3">Prepare the Space</h3><p>Follow the confirmed setup instructions provided by the Hush Hush Tan team.</p></div>
        <div class="hht-sp-step"><h3 class="hht-sp__h3">Get Glowing</h3><p>Each guest receives their scheduled personalized application.</p></div>
      </div>
    </div>
  </section>

  <section class="hht-sp__section hht-sp__section--soft">
    <div class="hht-sp__wrap">
      <div class="hht-sp-split">
        <div>
          <span class="hht-sp__eyebrow">Service Area</span>
          <h2 class="hht-sp__h2">Austin and Surrounding Areas</h2>
          <p class="hht-sp__lead">Mobile tanning is currently offered through the Austin studio only. A travel fee applies for eligible locations more than ten miles from the studio, and a separate hotel travel fee may apply.</p>
          <div class="hht-sp__ctas">
            <a class="btn btn--outline" href="/pages/austin-new">View Austin Location</a>
            <a class="btn" href="{{ mobile_book }}" target="_blank" rel="noopener noreferrer">Book Mobile Tanning</a>
          </div>
        </div>
        <div class="hht-sp-split__media">
          <img src="{{ 'hht-location-austin.jpg' | asset_url }}" alt="Hush Hush Tan Austin studio" width="800" height="600" loading="lazy">
        </div>
      </div>
    </div>
  </section>

  <section class="hht-sp__section">
    <div class="hht-sp__wrap" style="max-width:820px;">
      <div class="hht-sp-notice">
        <span class="hht-sp__eyebrow">What to Provide</span>
        <h2 class="hht-sp__h2">Details That Help Your Booking</h2>
        <ul>
          <li>Exact service address and any gate or building access notes</li>
          <li>Confirmed party size (minimum five)</li>
          <li>Preferred timing and any parking guidance</li>
          <li>Whether the location is a home, hotel, or event venue</li>
        </ul>
        <p style="margin:16px 0 0;color:var(--sp-muted);">We only list setup requirements confirmed by the team—follow the instructions shared after booking.</p>
      </div>
    </div>
  </section>

  <section class="hht-sp__section hht-sp__section--warm">
    <div class="hht-sp__wrap">
      <div class="hht-sp__center">
        <span class="hht-sp__eyebrow">Gallery</span>
        <h2 class="hht-sp__h2">The Austin Glow Experience</h2>
      </div>
      <div class="hht-sp-gallery">
        <figure><img src="{{ 'hht-moment-prep.jpg' | asset_url }}" alt="Preparing for a Hush Hush Tan application" width="600" height="750" loading="lazy"></figure>
        <figure><img src="{{ 'hht-moment-group.jpg' | asset_url }}" alt="Guests celebrating a group glow experience" width="600" height="750" loading="lazy"></figure>
        <figure><img src="{{ 'hht-gal-austin-01.jpg' | asset_url }}" alt="Hush Hush Tan Austin studio interior" width="600" height="750" loading="lazy"></figure>
      </div>
    </div>
  </section>

  <section class="hht-sp__section" id="mobile-faq">
    <div class="hht-sp__wrap" style="max-width:900px;">
      <div class="hht-sp__center">
        <span class="hht-sp__eyebrow">FAQ</span>
        <h2 class="hht-sp__h2">Mobile Tanning Questions</h2>
      </div>
      <div class="hht-sp-acc" data-hht-acc>
        <div class="hht-sp-acc__item is-open">
          <button type="button" class="hht-sp-acc__trig" aria-expanded="true">Is mobile tanning available outside Austin?<span class="hht-sp-acc__icon" aria-hidden="true"></span></button>
          <div class="hht-sp-acc__panel"><p>No. Mobile tanning is currently offered through the Austin studio only—not Dallas or Houston.</p></div>
        </div>
        <div class="hht-sp-acc__item">
          <button type="button" class="hht-sp-acc__trig" aria-expanded="false">How many guests are required?<span class="hht-sp-acc__icon" aria-hidden="true"></span></button>
          <div class="hht-sp-acc__panel"><p>A minimum of five guests is required.</p></div>
        </div>
        <div class="hht-sp-acc__item">
          <button type="button" class="hht-sp-acc__trig" aria-expanded="false">How much does the service cost?<span class="hht-sp-acc__icon" aria-hidden="true"></span></button>
          <div class="hht-sp-acc__panel"><p>Mobile tanning is $75 per person with a five-person minimum. Travel and hotel fees may apply.</p></div>
        </div>
        <div class="hht-sp-acc__item">
          <button type="button" class="hht-sp-acc__trig" aria-expanded="false">When does the travel fee apply?<span class="hht-sp-acc__icon" aria-hidden="true"></span></button>
          <div class="hht-sp-acc__panel"><p>A $15 travel fee applies for eligible locations more than 10 miles from the Austin studio.</p></div>
        </div>
        <div class="hht-sp-acc__item">
          <button type="button" class="hht-sp-acc__trig" aria-expanded="false">Is there a hotel travel fee?<span class="hht-sp-acc__icon" aria-hidden="true"></span></button>
          <div class="hht-sp-acc__panel"><p>Yes. A $30 hotel travel fee may apply where applicable.</p></div>
        </div>
        <div class="hht-sp-acc__item">
          <button type="button" class="hht-sp-acc__trig" aria-expanded="false">What information should I include when booking?<span class="hht-sp-acc__icon" aria-hidden="true"></span></button>
          <div class="hht-sp-acc__panel"><p>Include the service address, party size, and any access notes in the request notes box on Booker.</p></div>
        </div>
        <div class="hht-sp-acc__item">
          <button type="button" class="hht-sp-acc__trig" aria-expanded="false">How far in advance should I reserve?<span class="hht-sp-acc__icon" aria-hidden="true"></span></button>
          <div class="hht-sp-acc__panel"><p>Book as early as possible—especially for weekends and peak seasons. Availability depends on artist schedule and location.</p></div>
        </div>
        <div class="hht-sp-acc__item">
          <button type="button" class="hht-sp-acc__trig" aria-expanded="false">Does every guest receive a personalized shade?<span class="hht-sp-acc__icon" aria-hidden="true"></span></button>
          <div class="hht-sp-acc__panel"><p>Yes. Each guest can receive a personalized application based on skin tone and desired result.</p></div>
        </div>
        <div class="hht-sp-acc__item">
          <button type="button" class="hht-sp-acc__trig" aria-expanded="false">How should guests prepare?<span class="hht-sp-acc__icon" aria-hidden="true"></span></button>
          <div class="hht-sp-acc__panel"><p>Shower, shave, and exfoliate beforehand. Arrive with clean, dry skin and avoid lotions, deodorant, and perfume unless otherwise instructed. See our <a href="/pages/faqs">FAQ</a> for full prep guidance.</p></div>
        </div>
        <div class="hht-sp-acc__item">
          <button type="button" class="hht-sp-acc__trig" aria-expanded="false">What should guests wear afterward?<span class="hht-sp-acc__icon" aria-hidden="true"></span></button>
          <div class="hht-sp-acc__panel"><p>Loose, dark clothing is best while the tan develops. Avoid tight straps and light fabrics.</p></div>
        </div>
      </div>
    </div>
  </section>

  <section class="hht-sp__section hht-sp__section--lavender">
    <div class="hht-sp__wrap hht-sp-final">
      <span class="hht-sp__eyebrow">Austin Mobile Only</span>
      <h2 class="hht-sp__h2">Bring Hush Hush Tan to Your Location</h2>
      <p class="hht-sp__lead">Ready for five or more guests in the Austin area? Reserve mobile tanning through Booker.</p>
      <div class="hht-sp__ctas">
        <a class="btn" href="{{ mobile_book }}" target="_blank" rel="noopener noreferrer">Book Mobile Tanning</a>
        <a class="btn btn--outline" href="/pages/contact">Contact Us</a>
      </div>
    </div>
  </section>
</div>

<script>
(function () {
  var root = document.getElementById('hht-mobile-page');
  if (!root) return;
  root.querySelectorAll('[data-hht-acc]').forEach(function (acc) {
    acc.querySelectorAll('.hht-sp-acc__trig').forEach(function (trig) {
      trig.addEventListener('click', function () {
        var item = trig.closest('.hht-sp-acc__item');
        var open = item.classList.contains('is-open');
        acc.querySelectorAll('.hht-sp-acc__item').forEach(function (el) {
          el.classList.remove('is-open');
          var b = el.querySelector('.hht-sp-acc__trig');
          if (b) b.setAttribute('aria-expanded', 'false');
        });
        if (!open) {
          item.classList.add('is-open');
          trig.setAttribute('aria-expanded', 'true');
        }
      });
    });
  });
})();
</script>
