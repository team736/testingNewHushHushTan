{%- comment -%} Tanning Tips — prep & aftercare guide {%- endcomment -%}
{{ 'hht-supporting.css' | asset_url | stylesheet_tag }}

<div class="hht-sp" id="hht-tips-page">
  <section class="hht-sp__section">
    <div class="hht-sp__wrap">
      <div class="hht-sp-hero__panel">
        <div class="hht-sp-hero__body">
          <span class="hht-sp__eyebrow">Glow Guide</span>
          <h1 class="hht-sp__h1">Tanning Tips for a Longer, Even Glow</h1>
          <p class="hht-sp__lead">Preparation and aftercare make a meaningful difference in how your custom spray tan looks and lasts. Use this guide before your visit, on appointment day, and while your glow develops.</p>
          <div class="hht-sp__ctas">
            <a class="btn" href="https://go.booker.com/location/hushhushtan/service-menu" target="_blank" rel="noopener noreferrer">Book Now</a>
            <a class="btn btn--outline" href="/pages/our-services">View Services</a>
          </div>
        </div>
        <div class="hht-sp-hero__media">
          <img src="{{ 'hht-moment-prep.jpg' | asset_url }}" alt="Spray tan preparation at Hush Hush Tan" width="900" height="1100" loading="eager">
        </div>
      </div>
    </div>
  </section>

  <section class="hht-sp__section hht-sp__section--warm" id="before">
    <div class="hht-sp__wrap">
      <div class="hht-sp__center">
        <img src="{{ 'icon-core-services-sun.png' | asset_url }}" alt="" width="44" height="44" loading="lazy" class="hht-tips-icon">
        <span class="hht-sp__eyebrow">Before Your Appointment</span>
        <h2 class="hht-sp__h2">Prep for a Smooth, Even Finish</h2>
        <p class="hht-sp__lead">Clean, dry, exfoliated skin helps the solution develop evenly. Complete workouts, hair appointments, and spa treatments before you arrive whenever possible.</p>
      </div>
      <div class="hht-sp-grid hht-sp-grid--3">
        <article class="hht-sp-card">
          <h3 class="hht-sp__h3">Exfoliate</h3>
          <p>Gently exfoliate about 24 hours before your appointment, focusing on dry areas like elbows, knees, ankles, and feet.</p>
        </article>
        <article class="hht-sp-card">
          <h3 class="hht-sp__h3">Shave or wax</h3>
          <p>Shave or wax at least 24 hours prior so pores can settle before application.</p>
        </article>
        <article class="hht-sp-card">
          <h3 class="hht-sp__h3">Skip lotions &amp; oils</h3>
          <p>After showering, avoid moisturizer, body oil, makeup, deodorant, and perfume unless the studio gives different instructions.</p>
        </article>
        <article class="hht-sp-card">
          <h3 class="hht-sp__h3">Arrive clean &amp; bare</h3>
          <p>Come with clean, dry skin. Remove jewelry when possible and wear loose, dark clothing for after your session.</p>
        </article>
        <article class="hht-sp-card">
          <h3 class="hht-sp__h3">Hydrate dry skin</h3>
          <p>In the days leading up, keep skin moisturized so it is healthy and even — then skip products the day of your tan.</p>
        </article>
        <article class="hht-sp-card">
          <h3 class="hht-sp__h3">Plan your timing</h3>
          <p>Allow development time after your appointment before swimming, heavy workouts, or events.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="hht-sp__section" id="day-of">
    <div class="hht-sp__wrap">
      <div class="hht-sp-split">
        <div>
          <img src="{{ 'HHT_Icons_Clock.png' | asset_url }}" alt="" width="48" height="48" loading="lazy" class="hht-tips-icon hht-tips-icon--left">
          <span class="hht-sp__eyebrow">Appointment Day</span>
          <h2 class="hht-sp__h2">What to Expect</h2>
          <p class="hht-sp__lead">Your artist will discuss your skin tone, undertones, occasion, and desired depth of color. Wear or bring loose, dark clothing and avoid products on the skin that can create barriers.</p>
          <ul class="hht-sp-list">
            <li>Arrive a few minutes early so check-in is relaxed.</li>
            <li>Skip deodorant, perfume, lotion, and makeup on areas being sprayed.</li>
            <li>Tell your artist about dry patches, previous tans, or sensitivity concerns.</li>
            <li>Ask about rinse timing for your specific service (Custom Glow vs Rapid).</li>
          </ul>
        </div>
        <div class="hht-sp-split__media">
          <img src="{{ 'hht-glow-editorial.jpg' | asset_url }}" alt="Custom airbrush tan consultation" width="800" height="1000" loading="lazy">
        </div>
      </div>
    </div>
  </section>

  <section class="hht-sp__section hht-sp__section--lavender" id="after">
    <div class="hht-sp__wrap">
      <div class="hht-sp__center">
        <img src="{{ 'HHT_Icons_Shower.png' | asset_url }}" alt="" width="48" height="48" loading="lazy" class="hht-tips-icon">
        <span class="hht-sp__eyebrow">Immediately After</span>
        <h2 class="hht-sp__h2">Protect the Developing Tan</h2>
      </div>
      <div class="hht-sp-grid hht-sp-grid--3">
        <article class="hht-sp-card">
          <h3 class="hht-sp__h3">Loose clothing</h3>
          <p>Choose loose, dark pieces. Avoid tight straps and light fabrics while the solution finishes developing.</p>
        </article>
        <article class="hht-sp-card">
          <h3 class="hht-sp__h3">Avoid water &amp; sweat</h3>
          <p>Skip showers, swimming, heavy workouts, and activities that cause heavy sweating until after your first rinse.</p>
        </article>
        <article class="hht-sp-card">
          <h3 class="hht-sp__h3">First rinse timing</h3>
          <p>Rinse according to your service guidance — typically about 2–4 hours for Rapid and longer for Custom Glow. Follow the timing your artist confirms.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="hht-sp__section" id="maintain">
    <div class="hht-sp__wrap">
      <div class="hht-sp__center">
        <img src="{{ 'HHT_Icons_Water.png' | asset_url }}" alt="" width="48" height="48" loading="lazy" class="hht-tips-icon">
        <span class="hht-sp__eyebrow">Maintaining the Tan</span>
        <h2 class="hht-sp__h2">Help Your Glow Last Longer</h2>
      </div>
      <div class="hht-sp-grid hht-sp-grid--3">
        <article class="hht-sp-card">
          <h3 class="hht-sp__h3">Moisturize daily</h3>
          <p>Use an oil-free moisturizer to support even fading and comfortable skin.</p>
        </article>
        <article class="hht-sp-card">
          <h3 class="hht-sp__h3">Gentle showers</h3>
          <p>Prefer shorter, lukewarm showers. Avoid long hot baths when possible.</p>
        </article>
        <article class="hht-sp-card">
          <h3 class="hht-sp__h3">Skip harsh exfoliation</h3>
          <p>Avoid scrubbing, loofahs, and strong acids until the tan has faded.</p>
        </article>
        <article class="hht-sp-card">
          <h3 class="hht-sp__h3">Chlorine &amp; hot tubs</h3>
          <p>Pools, hot tubs, and chlorinated water can lighten the tan more quickly.</p>
        </article>
        <article class="hht-sp-card">
          <h3 class="hht-sp__h3">Even fading</h3>
          <p>Consistent moisturizing and gentle cleansing help the color fade more evenly.</p>
        </article>
        <article class="hht-sp-card">
          <h3 class="hht-sp__h3">Extend the glow</h3>
          <p>Book a follow-up or use approved aftercare products from our studio to refresh between visits.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="hht-sp__section hht-sp__section--warm" id="faq">
    <div class="hht-sp__wrap" style="max-width:900px;">
      <div class="hht-sp__center">
        <span class="hht-sp__eyebrow">Common Questions</span>
        <h2 class="hht-sp__h2">Quick Answers</h2>
      </div>
      <div class="hht-sp-acc" data-hht-acc>
        <div class="hht-sp-acc__item is-open">
          <button type="button" class="hht-sp-acc__trig" aria-expanded="true">How long does a spray tan last?<span class="hht-sp-acc__icon" aria-hidden="true"></span></button>
          <div class="hht-sp-acc__panel"><p>Most clients enjoy their glow for several days to about a week, depending on skin type, aftercare, and activity level. Moisturizing and gentle showers help it last longer.</p></div>
        </div>
        <div class="hht-sp-acc__item">
          <button type="button" class="hht-sp-acc__trig" aria-expanded="false">When can I shower?<span class="hht-sp-acc__icon" aria-hidden="true"></span></button>
          <div class="hht-sp-acc__panel"><p>Follow the rinse window for your service. Rapid options typically rinse sooner; Custom Glow usually develops longer. Your artist will confirm the timing for your appointment.</p></div>
        </div>
        <div class="hht-sp-acc__item">
          <button type="button" class="hht-sp-acc__trig" aria-expanded="false">Can I work out afterward?<span class="hht-sp-acc__icon" aria-hidden="true"></span></button>
          <div class="hht-sp-acc__panel"><p>Wait until after your first rinse. Sweat during development can affect the finish.</p></div>
        </div>
        <div class="hht-sp-acc__item">
          <button type="button" class="hht-sp-acc__trig" aria-expanded="false">Can I swim?<span class="hht-sp-acc__icon" aria-hidden="true"></span></button>
          <div class="hht-sp-acc__panel"><p>Avoid swimming until after development and your first rinse. Chlorine can also fade color more quickly afterward.</p></div>
        </div>
        <div class="hht-sp-acc__item">
          <button type="button" class="hht-sp-acc__trig" aria-expanded="false">Can I shave after my tan?<span class="hht-sp-acc__icon" aria-hidden="true"></span></button>
          <div class="hht-sp-acc__panel"><p>Wait until after your first rinse, then shave gently. Avoid waxing while the tan is fresh when possible.</p></div>
        </div>
        <div class="hht-sp-acc__item">
          <button type="button" class="hht-sp-acc__trig" aria-expanded="false">What should I wear?<span class="hht-sp-acc__icon" aria-hidden="true"></span></button>
          <div class="hht-sp-acc__panel"><p>Loose, dark clothing is best after your session. Tight straps and light fabrics can leave marks while the solution develops.</p></div>
        </div>
      </div>
      <div class="hht-sp__center" style="margin-top: 2rem;">
        <a class="btn btn--outline" href="/pages/faqs">Read All FAQs</a>
      </div>
    </div>
  </section>

  <section class="hht-sp__section hht-sp__section--lavender">
    <div class="hht-sp__wrap">
      <div class="hht-sp-cta-center">
        <span class="hht-sp__eyebrow">Book Your Glow</span>
        <h2 class="hht-sp__h2">Ready for Your Next Glow?</h2>
        <p class="hht-sp__lead">Book a Custom Glow at Austin, Dallas, or Houston — or shop aftercare products to maintain your color.</p>
        <div class="hht-sp__ctas">
          <a class="btn" href="https://go.booker.com/location/hushhushtan/service-menu" target="_blank" rel="noopener noreferrer">Book Now</a>
          <a class="btn btn--outline" href="/collections/tanning-products">Shop Products</a>
          <a class="btn btn--outline" href="/pages/austin">Austin</a>
          <a class="btn btn--outline" href="/pages/dallas">Dallas</a>
          <a class="btn btn--outline" href="/pages/houston">Houston</a>
        </div>
      </div>
    </div>
  </section>
</div>

<style>
  #hht-tips-page .hht-tips-icon {
    display: block;
    margin: 0 auto 12px;
    width: 48px;
    height: auto;
  }
  #hht-tips-page .hht-tips-icon--left { margin-left: 0; }
  #hht-tips-page .hht-sp-list {
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
    color: var(--sp-body);
    line-height: 1.6;
  }
  #hht-tips-page .hht-sp-list li {
    position: relative;
    margin: 0 0 10px;
    padding-left: 1.15rem;
  }
  #hht-tips-page .hht-sp-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--sp-accent);
  }
  #hht-tips-page .hht-sp-card {
    border-radius: 22px;
    border-color: rgba(166, 159, 226, 0.28);
    box-shadow: 0 14px 34px -28px rgba(143, 131, 214, 0.35);
  }
  #hht-tips-page .hht-sp-card .hht-sp__h3 {
    margin-bottom: 10px;
  }
  #hht-tips-page .hht-sp-card p {
    color: var(--sp-body);
    font-size: 0.95rem;
    line-height: 1.55;
  }
</style>

<script>
(function () {
  var root = document.getElementById('hht-tips-page');
  if (!root) return;
  root.querySelectorAll('[data-hht-acc]').forEach(function (acc) {
    acc.querySelectorAll('.hht-sp-acc__trig').forEach(function (trig) {
      trig.addEventListener('click', function () {
        var item = trig.closest('.hht-sp-acc__item');
        var open = item.classList.contains('is-open');
        acc.querySelectorAll('.hht-sp-acc__item').forEach(function (el) {
          el.classList.remove('is-open');
          var b = el.querySelector('.hht-sp-acc__trig');
          if (b) b.setAttribute('aria-expanded', 'false');
        });
        if (!open) {
          item.classList.add('is-open');
          trig.setAttribute('aria-expanded', 'true');
        }
      });
    });
  });
})();
</script>
