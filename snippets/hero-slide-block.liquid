{%- liquid
  assign image_fallback = block.settings.image_fallback | default: 'hht-hero-slide-1.webp'
  assign show_pills = block.settings.show_pills

  assign primary_url = block.settings.cta_primary_url
  if primary_url == blank
    if block.settings.cta_primary_text contains 'Membership'
      assign primary_url = '#memberships'
    else
      assign primary_url = settings.book_now_url | default: settings.book_austin_url | default: 'https://go.booker.com/location/hushhushtan/service-menu'
    endif
  endif

  assign secondary_url = block.settings.cta_secondary_url
  if secondary_url == blank
    assign secondary_url = '#locations'
  endif
-%}
<article
  class="hero2__slide{% if is_first %} is-active{% endif %}"
  data-hero-slide="{{ slide_index }}"
  aria-hidden="{% if is_first %}false{% else %}true{% endif %}"
  {{ block.shopify_attributes }}>

  <div class="hero2__copy">
    {%- if block.settings.eyebrow != blank -%}
      <span class="hero2__eyebrow">{{ block.settings.eyebrow }} {% render 'icon', name: 'sparkle' %}</span>
    {%- endif -%}

    {%- if is_first -%}<h1 class="hero2__title">{%- else -%}<h2 class="hero2__title">{%- endif -%}
      {{ block.settings.title_line1 }}
      {%- if block.settings.title_line2 != blank -%}
        <br><span class="hero2__title-accent">{{ block.settings.title_line2 }}</span>
      {%- endif -%}
      {%- if block.settings.title_line3 != blank -%}
        <br>{{ block.settings.title_line3 }}
      {%- endif -%}
    {%- if is_first -%}</h1>{%- else -%}</h2>{%- endif -%}

    {%- if block.settings.subtitle != blank -%}
      <p class="hero2__sub">{{ block.settings.subtitle }}</p>
    {%- endif -%}

    <div class="hero2__ctas">
      {%- if block.settings.cta_primary_text != blank -%}
        <a href="{{ primary_url }}" class="btn-pill btn-pill--dark"{% if primary_url contains 'booker.com' %} target="_blank" rel="noopener"{% endif %}>{{ block.settings.cta_primary_text }}</a>
      {%- endif -%}
      {%- if block.settings.cta_secondary_text != blank -%}
        <a href="{{ secondary_url }}" class="btn-pill btn-pill--outline"{% if secondary_url contains 'booker.com' %} target="_blank" rel="noopener"{% endif %}>{{ block.settings.cta_secondary_text }}</a>
      {%- endif -%}
    </div>

    <div class="hero2__trust">
      <span class="hero2__trust-item">{% render 'icon', name: 'sparkle' %}<span>Clean &amp; Conscious</span></span>
      <span class="hero2__trust-item">{% render 'icon', name: 'heart' %}<span>Custom to You</span></span>
      <span class="hero2__trust-item">{% render 'icon', name: 'shield' %}<span>Trusted Since 2007</span></span>
    </div>
  </div>

  <div class="hero2__media">
    {%- if block.settings.image != blank -%}
      <img
        src="{{ block.settings.image | image_url: width: 1400 }}"
        srcset="{{ block.settings.image | image_url: width: 800 }} 800w, {{ block.settings.image | image_url: width: 1400 }} 1400w"
        sizes="(min-width: 990px) 52vw, 100vw"
        alt="{{ block.settings.image.alt | default: block.settings.title_line1 | escape }}"
        width="1400"
        height="1180"
        class="hero2__image"
        {% if is_first %}fetchpriority="high"{% else %}loading="lazy"{% endif %}>
    {%- else -%}
      <img
        src="{{ image_fallback | asset_url }}"
        alt="{{ block.settings.title_line1 | escape }}"
        width="1400"
        height="1180"
        class="hero2__image"
        {% if is_first %}fetchpriority="high"{% else %}loading="lazy"{% endif %}>
    {%- endif -%}

    {%- if show_pills -%}
      <div class="hero2__pills" aria-hidden="true">
        <span class="hero2__pill">{% render 'icon', name: 'leaf' %}<span>Clean Ingredients</span></span>
        <span class="hero2__pill"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3s6 6.5 6 11a6 6 0 0 1-12 0c0-4.5 6-11 6-11z"/></svg><span>Custom Results</span></span>
        <span class="hero2__pill">{% render 'icon', name: 'sparkle' %}<span>Luxury Experience</span></span>
      </div>
    {%- endif -%}
  </div>
</article>
