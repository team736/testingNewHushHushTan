{%- liquid
  assign fallback = block.settings.image_fallback | default: 'hht-products.png'
  assign slide_id = 'hero-slide-' | append: index
  assign is_cutout = block.settings.transparent_image
  if is_cutout == false and block.settings.image == blank and fallback contains '.png'
    assign is_cutout = true
  endif
-%}

<article
  id="{{ slide_id }}"
  class="hero-slider__slide hero hero--split{% if first %} is-active{% endif %}"
  role="tabpanel"
  aria-hidden="{% if first %}false{% else %}true{% endif %}"
  {{ block.shopify_attributes }}
  data-hero-slide="{{ index | minus: 1 }}">
  <div class="container hero--split__grid">
    <div class="hero__copy">
      {%- if block.settings.eyebrow != blank -%}
        <span class="hero__eyebrow hero__anim-item">{{ block.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if first -%}
        <h1 class="hero__title hero__anim-item">
          {{ block.settings.title_line1 }}
          {%- if block.settings.title_line2 != blank -%}
            <br><span class="hero__title-accent">{{ block.settings.title_line2 }}</span>
          {%- endif -%}
          {%- if block.settings.title_line3 != blank -%}
            <br>{{ block.settings.title_line3 }}
          {%- endif -%}
        </h1>
      {%- else -%}
        <h2 class="hero__title hero__anim-item">
          {{ block.settings.title_line1 }}
          {%- if block.settings.title_line2 != blank -%}
            <br><span class="hero__title-accent">{{ block.settings.title_line2 }}</span>
          {%- endif -%}
          {%- if block.settings.title_line3 != blank -%}
            <br>{{ block.settings.title_line3 }}
          {%- endif -%}
        </h2>
      {%- endif -%}
      {%- if block.settings.subtitle != blank -%}
        <p class="hero__sub hero__anim-item">{{ block.settings.subtitle }}</p>
      {%- endif -%}
      {%- if block.settings.cta_text != blank or block.settings.cta_secondary_text != blank -%}
        <div class="hero__ctas hero__anim-item">
          {%- if block.settings.cta_text != blank -%}
            <a href="{{ block.settings.cta_url | default: '#' }}" class="btn btn--pill btn--hero">{{ block.settings.cta_text }}</a>
          {%- endif -%}
          {%- if block.settings.cta_secondary_text != blank -%}
            <a href="{{ block.settings.cta_secondary_url | default: '#' }}" class="btn btn--pill btn--hero btn--hero-outline">{{ block.settings.cta_secondary_text }}</a>
          {%- endif -%}
        </div>
      {%- endif -%}
      {%- if block.settings.show_trust_row -%}
        <div class="hero__trust hero__anim-item">
          <span>{{ block.settings.trust_1 | default: 'Award Winning' }}</span>
          <span class="hero__trust-divider" aria-hidden="true"></span>
          <span>{{ block.settings.trust_2 | default: 'Since 2007' }}</span>
          <span class="hero__trust-divider" aria-hidden="true"></span>
          <span>{{ block.settings.trust_3 | default: '3 Texas Studios' }}</span>
        </div>
      {%- endif -%}
    </div>

    <div class="hero__visual hero__anim-item">
      <div class="hero__visual-frame">
        {%- if block.settings.image != blank -%}
          <img
            src="{{ block.settings.image | image_url: width: 1280 }}"
            srcset="{{ block.settings.image | image_url: width: 800 }} 800w, {{ block.settings.image | image_url: width: 1280 }} 1280w"
            sizes="(min-width: 990px) 46vw, 88vw"
            alt="{{ block.settings.image.alt | default: block.settings.title_line1 | escape }}"
            width="1280"
            height="1280"
            class="hero__visual-img{% if is_cutout %} hero__visual-img--cutout{% endif %}"
            {% if first %}fetchpriority="high"{% else %}loading="lazy"{% endif %}>
        {%- else -%}
          <img
            src="{{ fallback | asset_url }}"
            alt="{{ block.settings.title_line1 | escape }}"
            width="1280"
            height="1280"
            class="hero__visual-img{% if is_cutout %} hero__visual-img--cutout{% endif %}"
            {% if first %}fetchpriority="high"{% else %}loading="lazy"{% endif %}>
        {%- endif -%}
      </div>
      {%- if block.settings.show_shade_badge -%}
        <div class="hero__shade-card hero__anim-item" aria-hidden="true">
          <div class="hero__shade-swatches">
            <span class="hero__shade-swatch hero__shade-swatch--1"></span>
            <span class="hero__shade-swatch hero__shade-swatch--2"></span>
            <span class="hero__shade-swatch hero__shade-swatch--3"></span>
          </div>
          <div class="hero__shade-card-text">
            <strong>{{ block.settings.shade_badge_title | default: '12 custom shades' }}</strong>
            <span>{{ block.settings.shade_badge_sub | default: 'Color-matched to you' }}</span>
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</article>
