<script>
(function () {
  var root = document.getElementById('hht-group-page');
  if (!root) return;

  function activateCity(city, updateUrl) {
    root.querySelectorAll('[data-city]').forEach(function (btn) {
      var on = btn.getAttribute('data-city') === city;
      btn.setAttribute('aria-selected', on ? 'true' : 'false');
    });
    root.querySelectorAll('[data-city-panel]').forEach(function (panel) {
      var on = panel.getAttribute('data-city-panel') === city;
      if (on) panel.removeAttribute('hidden');
      else panel.setAttribute('hidden', '');
    });
    if (updateUrl && window.history && window.history.replaceState) {
      try {
        var url = new URL(window.location.href);
        url.searchParams.set('location', city);
        window.history.replaceState({}, '', url.toString());
      } catch (e) {}
    }
  }

  root.querySelectorAll('[data-city]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      activateCity(btn.getAttribute('data-city'), true);
    });
  });

  try {
    var params = new URLSearchParams(window.location.search);
    var loc = (params.get('location') || '').toLowerCase();
    if (loc === 'austin' || loc === 'dallas' || loc === 'houston') {
      activateCity(loc, false);
    }
  } catch (e) {}

  root.querySelectorAll('[data-hht-acc]').forEach(function (acc) {
    acc.querySelectorAll('.hht-sp-acc__trig').forEach(function (trig) {
      trig.addEventListener('click', function () {
        var item = trig.closest('.hht-sp-acc__item');
        var open = item.classList.contains('is-open');
        acc.querySelectorAll('.hht-sp-acc__item').forEach(function (el) {
          el.classList.remove('is-open');
          var b = el.querySelector('.hht-sp-acc__trig');
          if (b) b.setAttribute('aria-expanded', 'false');
        });
        if (!open) {
          item.classList.add('is-open');
          trig.setAttribute('aria-expanded', 'true');
        }
      });
    });
  });
})();
</script>
