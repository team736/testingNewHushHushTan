<article class="hero-slider__slide hero hero--split is-active" role="tabpanel" aria-hidden="false" data-hero-slide="0">
  <div class="container hero--split__grid">
    <div class="hero__copy">
      <span class="hero__eyebrow hero__anim-item">Memberships & Packages</span>
      <h1 class="hero__title hero__anim-item">Glow More,<br><span class="hero__title-accent">Save More</span></h1>
      <p class="hero__sub hero__anim-item">Join the HHT family and enjoy exclusive savings, priority booking, and the perks of glowing all year long.</p>
      <div class="hero__ctas hero__anim-item">
        <a href="/pages/memberships" class="btn btn--pill btn--hero">View Memberships</a>
        <a href="/pages/locations" class="btn btn--pill btn--hero btn--hero-outline">Choose Your Location</a>
      </div>
      <div class="hero__trust hero__anim-item">
        <span>Award Winning</span>
        <span class="hero__trust-divider" aria-hidden="true"></span>
        <span>Since 2007</span>
        <span class="hero__trust-divider" aria-hidden="true"></span>
        <span>3 Texas Studios</span>
      </div>
    </div>
    <div class="hero__visual hero__anim-item">
      <div class="hero__visual-frame">
        <img src="{{ 'hht-products.png' | asset_url }}" alt="Hush Hush Tan products" width="1280" height="1280" class="hero__visual-img hero__visual-img--cutout" fetchpriority="high">
      </div>
      <div class="hero__shade-card hero__anim-item" aria-hidden="true">
        <div class="hero__shade-swatches">
          <span class="hero__shade-swatch hero__shade-swatch--1"></span>
          <span class="hero__shade-swatch hero__shade-swatch--2"></span>
          <span class="hero__shade-swatch hero__shade-swatch--3"></span>
        </div>
        <div class="hero__shade-card-text">
          <strong>12 custom shades</strong>
          <span>Color-matched to you</span>
        </div>
      </div>
    </div>
  </div>
</article>
