{%- comment -%} render 'product-card', product: product {%- endcomment -%}
<a href="{{ product.url }}" class="product-card">
  <div class="product-card__media">
    {%- if product.compare_at_price > product.price -%}
      <div class="product-card__badges"><span class="badge badge--sale">Sale</span></div>
    {%- elsif product.metafields.custom.new_arrival -%}
      <div class="product-card__badges"><span class="badge badge--new">New</span></div>
    {%- endif -%}
    {%- if product.featured_image -%}
      <img class="is-front"
        src="{{ product.featured_image | image_url: width: 600 }}"
        srcset="{{ product.featured_image | image_url: width: 400 }} 400w,
                {{ product.featured_image | image_url: width: 600 }} 600w,
                {{ product.featured_image | image_url: width: 900 }} 900w"
        sizes="(max-width: 720px) 50vw, 25vw"
        alt="{{ product.featured_image.alt | default: product.title | escape }}"
        loading="lazy"
        width="600" height="750">
      {%- if product.images[1] -%}
        <img class="is-back"
          src="{{ product.images[1] | image_url: width: 600 }}"
          alt=""
          loading="lazy"
          width="600" height="750">
      {%- endif -%}
    {%- else -%}
      <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:var(--muted);font-family:var(--font-heading);font-size:1.4rem;">
        Hush Hush Tan
      </div>
    {%- endif -%}
  </div>
  <h3 class="product-card__title">{{ product.title }}</h3>
  <div class="product-card__price">
    {%- if product.compare_at_price > product.price -%}
      <span class="on-sale">{{ product.price | money }}</span>
      <s>{{ product.compare_at_price | money }}</s>
    {%- elsif product.price_varies -%}
      From {{ product.price_min | money }}
    {%- else -%}
      {{ product.price | money }}
    {%- endif -%}
  </div>
</a>
