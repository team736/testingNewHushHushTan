{%- comment -%} Our Story — brand story page {%- endcomment -%}
{{ 'hht-supporting.css' | asset_url | stylesheet_tag }}

<div class="hht-sp" id="hht-story-page">
  <section class="hht-sp__section">
    <div class="hht-sp__wrap">
      <div class="hht-sp-hero__panel">
        <div class="hht-sp-hero__body">
          <span class="hht-sp__eyebrow">Our Story</span>
          <h1 class="hht-sp__h1">A Healthier Glow, Made Personal</h1>
          <p class="hht-sp__lead">Hush Hush Tan was created around a simple belief: a spray tan should complement the person wearing it. From our Austin beginnings to studios in Dallas and Houston, every Hush Hush Tan experience is built around personalized color, attentive service, and natural-looking results.</p>
          <div class="hht-sp__ctas">
            <a class="btn" href="#founder">Discover Our Story</a>
            <a class="btn btn--outline" href="/pages/locations">Choose a Location</a>
          </div>
        </div>
        <div class="hht-sp-hero__media">
          <img src="{{ 'hht-glow-editorial.jpg' | asset_url }}" alt="Personalized Hush Hush Tan glow experience" width="900" height="1100" loading="eager">
        </div>
      </div>
    </div>
  </section>

  <section class="hht-sp__section hht-sp__section--warm" id="founder">
    <div class="hht-sp__wrap">
      <div class="hht-sp-split">
        <div class="hht-sp-split__media">
          <img src="{{ 'hht-team-group-01.jpg' | asset_url }}" alt="Hush Hush Tan team" width="800" height="1000" loading="lazy">
        </div>
        <div>
          <span class="hht-sp__eyebrow">Founded in Texas</span>
          <h2 class="hht-sp__h2">Created by Izabel Wicker</h2>
          <p class="hht-sp__lead">Hush Hush Tan was founded in Austin by Izabel Wicker with a vision for a more personalized approach to sunless tanning. Instead of treating every client the same, the Hush Hush Tan method focuses on skin tone, undertones, desired depth of color, and the occasion behind each appointment.</p>
          <p class="hht-sp__lead">What began as one Texas studio has grown into three locations serving Austin, Dallas, and Houston while maintaining the same attention to detail and welcoming client experience.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="hht-sp__section">
    <div class="hht-sp__wrap">
      <div class="hht-sp__center">
        <span class="hht-sp__eyebrow">The Hush Hush Difference</span>
        <h2 class="hht-sp__h2">Mixed for Your Undertones</h2>
        <p class="hht-sp__lead">Every appointment begins with a conversation. The artist considers the client’s complexion, undertones, schedule, and desired result before selecting or mixing the appropriate color. The goal is not a one-shade-fits-all tan, but a glow that feels believable and individual.</p>
      </div>
      <div class="hht-sp-grid hht-sp-grid--3">
        <article class="hht-sp-card"><span class="hht-sp-card__label">Personalized Color</span><p>Each service is selected around the individual client.</p></article>
        <article class="hht-sp-card"><span class="hht-sp-card__label">Expert Application</span><p>Detailed airbrush application supports an even, controlled finish.</p></article>
        <article class="hht-sp-card"><span class="hht-sp-card__label">Comfortable Experience</span><p>Private appointments and attentive artists help clients feel informed and at ease.</p></article>
      </div>
    </div>
  </section>

  <section class="hht-sp__section hht-sp__section--lavender">
    <div class="hht-sp__wrap">
      <div class="hht-sp__center">
        <span class="hht-sp__eyebrow">Values</span>
        <h2 class="hht-sp__h2">What Guides Every Glow</h2>
      </div>
      <div class="hht-sp-grid hht-sp-grid--4">
        <article class="hht-sp-card"><span class="hht-sp-card__label">Personalization</span><p>No two skin tones or desired results are identical.</p></article>
        <article class="hht-sp-card"><span class="hht-sp-card__label">Confidence</span><p>The experience should help clients feel comfortable, prepared, and confident.</p></article>
        <article class="hht-sp-card"><span class="hht-sp-card__label">Consistency</span><p>From consultation through aftercare, details matter.</p></article>
        <article class="hht-sp-card"><span class="hht-sp-card__label">Care</span><p>Clients should understand their service, development time, and aftercare before leaving.</p></article>
      </div>
    </div>
  </section>

  <section class="hht-sp__section">
    <div class="hht-sp__wrap">
      <div class="hht-sp__center">
        <span class="hht-sp__eyebrow">Recognized Beyond Texas</span>
        <h2 class="hht-sp__h2">A Local Brand with National Recognition</h2>
        <p class="hht-sp__lead">Hush Hush Tan’s personalized approach has been recognized by leading fashion, lifestyle, and Texas publications.</p>
      </div>
      <div class="hht-sp-press">
        <img src="{{ 'press-vogue.png' | asset_url }}" alt="Vogue" width="120" height="40" loading="lazy">
        <img src="{{ 'press-instyle.png' | asset_url }}" alt="InStyle" width="120" height="40" loading="lazy">
        <img src="{{ 'press-austin-monthly.png' | asset_url }}" alt="Austin Monthly" width="140" height="40" loading="lazy">
      </div>
      <p class="hht-sp__center" style="margin-top:28px;">
        <a class="btn btn--outline" href="/pages/press">Read Press</a>
      </p>
    </div>
  </section>

  <section class="hht-sp__section hht-sp__section--warm">
    <div class="hht-sp__wrap">
      <div class="hht-sp__center">
        <span class="hht-sp__eyebrow">Studios</span>
        <h2 class="hht-sp__h2">Three Texas Studios. One Personalized Experience.</h2>
      </div>
      <div class="hht-sp-grid hht-sp-grid--3">
        <article class="hht-sp-loccard">
          <div class="hht-sp-loccard__img">
            <img src="{{ 'hht-location-austin.jpg' | asset_url }}" alt="Hush Hush Tan Austin" width="640" height="400" loading="lazy">
          </div>
          <div class="hht-sp-loccard__body">
            <span class="hht-sp-card__label">Austin</span>
            <h3 class="hht-sp__h3">Austin</h3>
            <p>The original Hush Hush Tan flagship serving central Austin.</p>
            <div class="hht-sp-loccard__actions">
              <a class="btn" href="/pages/austin-new">Visit Austin</a>
            </div>
          </div>
        </article>
        <article class="hht-sp-loccard">
          <div class="hht-sp-loccard__img">
            <img src="{{ 'hht-location-dallas.jpg' | asset_url }}" alt="Hush Hush Tan Dallas" width="640" height="400" loading="lazy">
          </div>
          <div class="hht-sp-loccard__body">
            <span class="hht-sp-card__label">Dallas</span>
            <h3 class="hht-sp__h3">Dallas</h3>
            <p>A personalized glow experience at The Shops at Highland Park.</p>
            <div class="hht-sp-loccard__actions">
              <a class="btn" href="/pages/dallas-new">Visit Dallas</a>
            </div>
          </div>
        </article>
        <article class="hht-sp-loccard">
          <div class="hht-sp-loccard__img">
            <img src="{{ 'hht-location-houston.jpg' | asset_url }}" alt="Hush Hush Tan Houston" width="640" height="400" loading="lazy">
          </div>
          <div class="hht-sp-loccard__body">
            <span class="hht-sp-card__label">Houston</span>
            <h3 class="hht-sp__h3">Houston</h3>
            <p>Customized tanning at M-K-T Heights.</p>
            <div class="hht-sp-loccard__actions">
              <a class="btn" href="/pages/houston-new">Visit Houston</a>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="hht-sp__section">
    <div class="hht-sp__wrap">
      <div class="hht-sp__center">
        <span class="hht-sp__eyebrow">Gallery</span>
        <h2 class="hht-sp__h2">Behind the Glow</h2>
      </div>
      <div class="hht-sp-gallery">
        <a href="https://www.instagram.com/hushhushtan/" target="_blank" rel="noopener noreferrer">
          <img src="{{ 'hht-reception.jpg' | asset_url }}" alt="Hush Hush Tan reception" width="600" height="750" loading="lazy">
        </a>
        <a href="https://www.instagram.com/hushhushtan/" target="_blank" rel="noopener noreferrer">
          <img src="{{ 'hht-product-shelf.jpg' | asset_url }}" alt="Hush Hush Tan product display" width="600" height="750" loading="lazy">
        </a>
        <a href="https://www.instagram.com/hushhushtan/" target="_blank" rel="noopener noreferrer">
          <img src="{{ 'hht-team-group-02.jpg' | asset_url }}" alt="Hush Hush Tan team together" width="600" height="750" loading="lazy">
        </a>
        <a href="https://www.instagram.com/hushhushtan/" target="_blank" rel="noopener noreferrer">
          <img src="{{ 'hht-gal-shared-01.jpg' | asset_url }}" alt="Hush Hush Tan studio atmosphere" width="600" height="750" loading="lazy">
        </a>
        <a href="https://www.instagram.com/hushhushtan/" target="_blank" rel="noopener noreferrer">
          <img src="{{ 'hht-moment-aftercare.jpg' | asset_url }}" alt="Aftercare products and glow moment" width="600" height="750" loading="lazy">
        </a>
        <a href="https://www.instagram.com/hushhushtan/" target="_blank" rel="noopener noreferrer">
          <img src="{{ 'hht-glow-wall-art.jpg' | asset_url }}" alt="Hush Hush Tan studio glow wall art" width="600" height="750" loading="lazy">
        </a>
      </div>
      <p class="hht-sp__center" style="margin-top:22px;">
        <a class="btn btn--outline" href="https://www.instagram.com/hushhushtan/" target="_blank" rel="noopener noreferrer">Follow @hushhushtan</a>
      </p>
    </div>
  </section>

  <section class="hht-sp__section hht-sp__section--lavender">
    <div class="hht-sp__wrap hht-sp-final hht-sp__center">
      <span class="hht-sp__eyebrow">Come Glow with Us</span>
      <h2 class="hht-sp__h2">Experience Hush Hush Tan for Yourself</h2>
      <p class="hht-sp__lead">Choose your nearest Texas studio and book a personalized airbrush-tanning experience.</p>
      <div class="hht-sp__ctas">
        <a class="btn" href="/pages/locations">Choose a Location</a>
        <a class="btn btn--outline" href="/pages/our-services">Explore Services</a>
      </div>
    </div>
  </section>
</div>
