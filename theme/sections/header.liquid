<header class="site-header site-header--left-logo" role="banner">
  <div class="site-header__inner">
    <a href="{{ routes.root_url }}" class="site-header__logo" aria-label="{{ shop.name }} — Home">
      {%- if section.settings.logo != blank -%}
        <img
          src="{{ section.settings.logo | image_url: width: 520 }}"
          alt="{{ shop.name }}"
          width="260"
          height="40"
          loading="eager"
          class="site-header__logo-img">
      {%- elsif settings.logo != blank -%}
        <img
          src="{{ settings.logo | image_url: width: 520 }}"
          alt="{{ shop.name }}"
          width="{{ settings.logo_width | default: 220 }}"
          height="40"
          loading="eager"
          class="site-header__logo-img"
          style="max-width: {{ settings.logo_width | default: 220 }}px;">
      {%- else -%}
        <img
          src="{{ 'hht-logo-horizontal.png' | asset_url }}"
          alt="{{ shop.name }}"
          width="260"
          height="36"
          loading="eager"
          class="site-header__logo-img site-header__logo-img--brand">
      {%- endif -%}
    </a>

    <button class="icon-btn menu-toggle" data-drawer-open="#MobileDrawer" aria-label="Open menu">
      {% render 'icon', name: 'menu' %}
    </button>

    <nav class="site-header__nav" aria-label="Primary">
      {%- if section.settings.menu != blank -%}
        {%- for link in section.settings.menu.links -%}
          {%- if link.links.size > 0 -%}
            <div class="has-submenu">
              <a href="{{ link.url }}"{% if link.active %} aria-current="page"{% endif %}>{{ link.title }}</a>
              <div class="submenu">
                {%- for child in link.links -%}<a href="{{ child.url }}">{{ child.title }}</a>{%- endfor -%}
              </div>
            </div>
          {%- else -%}
            <a href="{{ link.url }}"{% if link.active %} aria-current="page"{% endif %}>{{ link.title }}</a>
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        <a href="{{ routes.root_url }}"{% if request.path == '/' %} aria-current="page"{% endif %}>Home</a>
        <div class="has-submenu">
          <a href="/pages/locations">Locations</a>
          <div class="submenu">
            <a href="/pages/austin">Austin</a>
            <a href="/pages/dallas">Dallas</a>
            <a href="/pages/houston">Houston</a>
          </div>
        </div>
        <a href="{{ routes.collections_url }}/tanning-products">Products</a>
        <a href="/pages/memberships">Memberships</a>
        <div class="has-submenu">
          <a href="/pages/tanning-gift-certificates">Tanning Gift Certificate</a>
          <div class="submenu">
            <a href="{{ settings.gift_austin_url }}">Austin</a>
            <a href="{{ settings.gift_dallas_url }}">Dallas</a>
            <a href="{{ settings.gift_houston_url }}">Houston</a>
          </div>
        </div>
        <div class="has-submenu">
          <a href="/pages/about-us">About</a>
          <div class="submenu">
            <a href="/pages/about-us">Our Story</a>
            <a href="/pages/press">Press</a>
            <a href="/pages/faqs">FAQ</a>
            <a href="/pages/careers">Careers</a>
          </div>
        </div>
        <div class="has-submenu">
          <a href="/pages/houston-services">Houston Services</a>
          <div class="submenu">
            <a href="/pages/austin-services">Austin Services</a>
            <a href="/pages/dallas-services">Dallas Services</a>
            <a href="/pages/houston-services">Houston Services</a>
          </div>
        </div>
        <a href="/pages/contact">Contact</a>
      {%- endif -%}
    </nav>

    <div class="site-header__actions">
      <a href="{{ routes.search_url }}" class="icon-btn" aria-label="Search">{% render 'icon', name: 'search' %}</a>
      <a href="{{ routes.account_url }}" class="icon-btn" aria-label="Account">{% render 'icon', name: 'account' %}</a>
      <a href="{{ routes.cart_url }}" class="icon-btn" aria-label="Cart">
        {% render 'icon', name: 'cart' %}
        {%- if cart.item_count > 0 -%}<span class="cart-count">{{ cart.item_count }}</span>{%- endif -%}
      </a>
      {%- if section.settings.show_book_cta -%}
        <a href="{{ section.settings.book_url | default: settings.book_now_url }}" class="btn btn--small btn--header-book">Book Now</a>
      {%- endif -%}
    </div>
  </div>
</header>

<div class="drawer" id="MobileDrawer" aria-hidden="true">
  <div class="drawer__panel" role="dialog" aria-modal="true" aria-label="Menu">
    <button class="icon-btn drawer__close" data-drawer-close aria-label="Close menu">{% render 'icon', name: 'close' %}</button>
    <a href="{{ routes.root_url }}" class="site-header__logo site-header__logo--drawer">
      <img src="{{ 'hht-logo-horizontal.png' | asset_url }}" alt="{{ shop.name }}" width="220" height="32" class="site-header__logo-img site-header__logo-img--brand">
    </a>
    <nav class="drawer__nav" aria-label="Mobile">
      {%- if section.settings.menu != blank -%}
        {%- for link in section.settings.menu.links -%}
          {%- if link.links.size > 0 -%}
            <details>
              <summary>{{ link.title }}</summary>
              <div class="drawer__sub">
                {%- for child in link.links -%}<a href="{{ child.url }}">{{ child.title }}</a>{%- endfor -%}
              </div>
            </details>
          {%- else -%}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        <a href="{{ routes.root_url }}">Home</a>
        <details>
          <summary>Locations</summary>
          <div class="drawer__sub"><a href="/pages/austin">Austin</a><a href="/pages/dallas">Dallas</a><a href="/pages/houston">Houston</a></div>
        </details>
        <a href="{{ routes.collections_url }}/tanning-products">Products</a>
        <a href="/pages/memberships">Memberships</a>
        <details>
          <summary>Tanning Gift Certificate</summary>
          <div class="drawer__sub">
            <a href="{{ settings.gift_austin_url }}">Austin</a><a href="{{ settings.gift_dallas_url }}">Dallas</a><a href="{{ settings.gift_houston_url }}">Houston</a>
          </div>
        </details>
        <details>
          <summary>About</summary>
          <div class="drawer__sub">
            <a href="/pages/about-us">Our Story</a><a href="/pages/press">Press</a><a href="/pages/faqs">FAQ</a><a href="/pages/careers">Careers</a>
          </div>
        </details>
        <details>
          <summary>Houston Services</summary>
          <div class="drawer__sub">
            <a href="/pages/austin-services">Austin Services</a><a href="/pages/dallas-services">Dallas Services</a><a href="/pages/houston-services">Houston Services</a>
          </div>
        </details>
        <a href="/pages/contact">Contact</a>
      {%- endif -%}
      <a href="{{ section.settings.book_url | default: settings.book_now_url }}" class="btn btn--block" style="margin-top: 28px;">Book Now</a>
    </nav>
  </div>
</div>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Header logo (horizontal)" },
    { "type": "link_list", "id": "menu", "label": "Main menu", "default": "main-menu" },
    { "type": "checkbox", "id": "show_book_cta", "label": "Show Book Now CTA", "default": true },
    { "type": "url", "id": "book_url", "label": "Book Now URL (overrides global)" }
  ]
}
{% endschema %}
