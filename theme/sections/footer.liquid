<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="site-footer__top">
      {%- for block in section.blocks -%}
        {%- if block.type == 'menu_column' -%}
          <div class="site-footer__col" {{ block.shopify_attributes }}>
            <h4>{{ block.settings.heading }}</h4>
            <ul>
              {%- if block.settings.menu != blank -%}
                {%- for link in block.settings.menu.links -%}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {%- endfor -%}
              {%- else -%}
                {%- assign items = block.settings.fallback_items | newline_to_br | split: '<br />' -%}
                {%- for item in items -%}
                  {%- assign parts = item | split: '|' -%}
                  {%- if parts[0] != blank -%}<li><a href="{{ parts[1] | default: '#' | strip }}">{{ parts[0] | strip }}</a></li>{%- endif -%}
                {%- endfor -%}
              {%- endif -%}
            </ul>
          </div>
        {%- elsif block.type == 'newsletter' -%}
          <div class="site-footer__newsletter" {{ block.shopify_attributes }}>
            <h4>{{ block.settings.heading }}</h4>
            <p class="muted" style="font-size: .92rem; margin-bottom: 18px;">{{ block.settings.text }}</p>
            {%- form 'customer', class: 'newsletter-form' -%}
              <input type="hidden" name="contact[tags]" value="newsletter">
              <input type="email" name="contact[email]" placeholder="Enter your email address" required>
              <button type="submit">Subscribe →</button>
            {%- endform -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="site-footer__bottom">
      <div class="site-footer__social">
        {%- if settings.social_instagram != blank -%}<a href="{{ settings.social_instagram }}" aria-label="Instagram">{% render 'icon', name: 'instagram' %}</a>{%- endif -%}
        {%- if settings.social_facebook  != blank -%}<a href="{{ settings.social_facebook  }}" aria-label="Facebook">{%  render 'icon', name: 'facebook'  %}</a>{%- endif -%}
        {%- if settings.social_tiktok    != blank -%}<a href="{{ settings.social_tiktok    }}" aria-label="TikTok">{%    render 'icon', name: 'tiktok'    %}</a>{%- endif -%}
        {%- if settings.social_pinterest != blank -%}<a href="{{ settings.social_pinterest }}" aria-label="Pinterest">{% render 'icon', name: 'pinterest' %}</a>{%- endif -%}
      </div>
      <a href="{{ routes.root_url }}" class="site-footer__logo">
        {%- if settings.logo != blank -%}
          <img src="{{ settings.logo | image_url: width: 240 }}" alt="{{ shop.name }}" width="160" height="40" style="height:auto;" loading="lazy">
        {%- else -%}
          {{ shop.name }}
        {%- endif -%}
      </a>
      <div class="site-footer__payments">
        <span>VISA</span><span>MC</span><span>AMEX</span><span>PAYPAL</span><span>APPLE</span>
      </div>
    </div>
    <div class="text-center" style="margin-top: 18px; color: var(--muted); font-size: .82rem;">
      © {{ 'now' | date: '%Y' }} {{ shop.name }} · {{ section.settings.colophon }}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "colophon", "label": "Bottom text", "default": "Customizable spray tanning · Austin · Dallas · Houston" }
  ],
  "blocks": [
    {
      "type": "menu_column",
      "name": "Menu column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Explore" },
        { "type": "link_list", "id": "menu", "label": "Menu (assign in Online Store → Navigation)" },
        { "type": "textarea", "id": "fallback_items", "label": "Fallback items (Title|URL per line)", "info": "Used only if no Menu is selected above" }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Good emails." },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Enter your email below to be the first to know about new collections and product launches." }
      ]
    }
  ],
  "max_blocks": 6,
  "default": {
    "blocks": [
      { "type": "menu_column", "settings": { "heading": "Company", "fallback_items": "Our Story|/pages/about-us\nLocations|/pages/locations\nPress|/pages/press\nCareers|https://hushhushtan.com/a/careers/\nSitemap|/sitemap.xml" } },
      { "type": "menu_column", "settings": { "heading": "Useful Links", "fallback_items": "Products|/collections/tanning-products\nGift Certificates|/pages/tanning-gift-certificates\nGroup Tanning & Mimosas|/pages/hush-hush-tan-group-tanning-mimosas-package\nAustin Mobile Tanning|/pages/mobile-spray-tan\nParental Consent Form|https://docs.google.com/forms/d/e/1FAIpQLSemwKKAfDiy9N901J4PoE1oBDY2ZbLfGtbPSLMokwVHhiH_Ag/viewform" } },
      { "type": "menu_column", "settings": { "heading": "Information", "fallback_items": "Contact|/pages/contact\nFAQ|/pages/faqs\nShipping|/pages/shipping\nTanning Tips|/pages/tanning-tips\nPrivacy Policy|/policies/privacy-policy\nTerms of Service|/policies/terms-of-service" } },
      { "type": "menu_column", "settings": { "heading": "Locations", "fallback_items": "Austin|/pages/austin\nDallas|/pages/dallas\nHouston|/pages/houston" } },
      { "type": "newsletter" }
    ]
  }
}
{% endschema %}
