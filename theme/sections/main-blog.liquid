<div class="container section">
  <header class="text-center" style="margin-bottom: 48px;">
    <span class="eyebrow">Get Glowing Guide</span>
    <h1 class="mb-0">{{ blog.title }}</h1>
  </header>
  {%- paginate blog.articles by 12 -%}
    <div class="blog-grid">
      {%- for article in blog.articles -%}
        <a class="blog-card" href="{{ article.url }}">
          <div class="blog-card__media">
            {%- if article.image -%}
              <img src="{{ article.image | image_url: width: 800 }}" alt="{{ article.title | escape }}" width="800" height="600" loading="lazy">
            {%- endif -%}
          </div>
          <h3 class="blog-card__title">{{ article.title }}</h3>
          <p class="blog-card__excerpt">{{ article.excerpt_or_content | strip_html | truncate: 130 }}</p>
          <div class="muted small" style="margin-top: 8px;">{{ article.published_at | date: '%B %d, %Y' }}</div>
        </a>
      {%- endfor -%}
    </div>
    <div class="text-center" style="margin-top: 40px;">{% render 'pagination', paginate: paginate %}</div>
  {%- endpaginate -%}
</div>

{% schema %}
{ "name": "Blog", "settings": [] }
{% endschema %}
