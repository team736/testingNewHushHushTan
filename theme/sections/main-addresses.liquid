<div class="container section">
  <h1>Your addresses</h1>
  <p><a href="{{ routes.account_url }}" class="muted small">← Back to account</a></p>
  {%- for address in customer.addresses -%}
    <div style="padding: 20px; border: 1px solid var(--line); border-radius: var(--radius); margin-bottom: 16px;">
      <p>{{ address | format_address }}</p>
      {%- form 'customer_address', address -%}
        <button type="submit" name="_method" value="delete" class="btn btn--ghost btn--small">Delete</button>
      {%- endform -%}
    </div>
  {%- endfor -%}
  <h3 style="margin-top: 40px;">Add a new address</h3>
  {%- form 'customer_address', customer.new_address, class: 'form' -%}
    <div class="field"><label>First name</label><input type="text" name="address[first_name]" value="{{ form.first_name }}"></div>
    <div class="field"><label>Last name</label><input type="text" name="address[last_name]" value="{{ form.last_name }}"></div>
    <div class="field"><label>Address</label><input type="text" name="address[address1]" value="{{ form.address1 }}"></div>
    <div class="field"><label>City</label><input type="text" name="address[city]" value="{{ form.city }}"></div>
    <div class="field"><label>Country</label><select name="address[country]" data-default="{{ form.country }}">{{ all_country_option_tags }}</select></div>
    <div class="field"><label>Postal code</label><input type="text" name="address[zip]" value="{{ form.zip }}"></div>
    <div class="field"><label>Phone</label><input type="tel" name="address[phone]" value="{{ form.phone }}"></div>
    <button type="submit" class="btn">Save address</button>
  {%- endform -%}
</div>
{% schema %}{ "name": "Addresses", "settings": [] }{% endschema %}
