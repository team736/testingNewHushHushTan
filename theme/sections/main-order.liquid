<div class="container section">
  <h1>Order {{ order.name }}</h1>
  <p class="muted">{{ order.created_at | date: '%B %d, %Y' }}</p>
  <table class="cart-table" style="margin-top: 24px;">
    <thead><tr><th>Item</th><th>Qty</th><th>Price</th></tr></thead>
    <tbody>
      {%- for line in order.line_items -%}
        <tr><td>{{ line.title }}</td><td>{{ line.quantity }}</td><td>{{ line.final_line_price | money }}</td></tr>
      {%- endfor -%}
    </tbody>
  </table>
  <div class="cart-summary">
    <div class="cart-summary__row"><span>Subtotal</span><span>{{ order.line_items_subtotal_price | money }}</span></div>
    <div class="cart-summary__row"><span>Shipping</span><span>{{ order.shipping_price | money }}</span></div>
    <div class="cart-summary__row"><strong>Total</strong><strong>{{ order.total_price | money }}</strong></div>
  </div>
</div>
{% schema %}{ "name": "Order", "settings": [] }{% endschema %}
