{%- assign slide_count = section.blocks.size -%}
{%- if slide_count == 0 -%}
  {%- assign slide_count = 1 -%}
{%- endif -%}

<section
  class="hero-slider"
  id="top"
  data-hero-slider
  data-autoplay="{{ section.settings.autoplay_speed | default: 5 | times: 1000 }}"
  {% unless section.settings.autoplay %}data-autoplay-off{% endunless %}
  aria-label="Featured highlights"
  aria-roledescription="carousel">
  <div class="hero-slider__viewport">
    <div class="hero-slider__track">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- render 'hero-slide', block: block, index: forloop.index, first: forloop.first -%}
        {%- endfor -%}
      {%- else -%}
        {%- render 'hero-slide-fallback' -%}
      {%- endif -%}
    </div>
  </div>

  {%- if slide_count > 1 -%}
    <div class="hero-slider__dots" role="tablist" aria-label="Choose slide">
      {%- for block in section.blocks -%}
        <button
          type="button"
          class="hero-slider__dot{% if forloop.first %} is-active{% endif %}"
          role="tab"
          aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
          aria-controls="hero-slide-{{ forloop.index }}"
          data-hero-dot="{{ forloop.index0 }}"
          aria-label="Slide {{ forloop.index }} of {{ section.blocks.size }}">
        </button>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Hero slider",
  "settings": [
    { "type": "checkbox", "id": "autoplay", "label": "Auto-advance slides", "default": true },
    { "type": "range", "id": "autoplay_speed", "label": "Seconds per slide", "min": 4, "max": 12, "step": 1, "default": 5, "unit": "s" }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image (right)" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Memberships & Packages" },
        { "type": "text", "id": "title_line1", "label": "Headline line 1", "default": "Glow More," },
        { "type": "text", "id": "title_line2", "label": "Headline line 2 (accent)", "default": "Save More" },
        { "type": "textarea", "id": "subtitle", "label": "Paragraph", "default": "Join the HHT family and enjoy exclusive savings, priority booking, and the perks of glowing all year long." },
        { "type": "text", "id": "cta_text", "label": "Primary button text", "default": "View Memberships" },
        { "type": "url", "id": "cta_url", "label": "Primary button URL" },
        { "type": "text", "id": "cta_secondary_text", "label": "Secondary button text" },
        { "type": "url", "id": "cta_secondary_url", "label": "Secondary button URL" },
        { "type": "text", "id": "image_fallback", "label": "Default image asset filename", "default": "hero-products.jpg", "info": "Used when no image is uploaded. PNG works for transparent product shots." },
        { "type": "checkbox", "id": "transparent_image", "label": "Transparent / cutout image (no crop)", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero slider",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Memberships & Packages",
            "title_line1": "Glow More,",
            "title_line2": "Save More",
            "subtitle": "Join the HHT family and enjoy exclusive savings, priority booking, and the perks of glowing all year long.",
            "cta_text": "View Memberships",
            "cta_url": "/pages/memberships",
            "cta_secondary_text": "Choose Your Location",
            "cta_secondary_url": "/pages/locations",
            "image_fallback": "hero-products.jpg",
            "transparent_image": true
          }
        },
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Custom Spray Tanning",
            "title_line1": "Healthier Glow.",
            "title_line2": "Flawless Confidence.",
            "subtitle": "Customized spray tan salons in Austin, Dallas, and Houston.",
            "cta_text": "Book Now",
            "cta_url": "https://go.booker.com/location/hushhushtan/service-menu",
            "cta_secondary_text": "Choose Your Location",
            "cta_secondary_url": "/pages/locations",
            "image_fallback": "hht-spray-tanning.png",
            "transparent_image": true
          }
        },
        {
          "type": "slide",
          "settings": {
            "eyebrow": "The Hush Hush Experience",
            "title_line1": "Everyone will notice.",
