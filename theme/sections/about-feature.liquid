<section class="section">
  <div class="container">
    <div class="image-with-text{% if section.settings.image_side == 'right' %} image-with-text--reverse{% endif %}">
      <div class="image-with-text__media">
        {%- if section.settings.image != blank -%}
          <img src="{{ section.settings.image | image_url: width: 1200 }}" sizes="(max-width: 900px) 100vw, 50vw" alt="{{ section.settings.heading | escape }}" width="1000" height="1200" loading="lazy">
        {%- else -%}
          <div style="width:100%;height:100%;background:linear-gradient(135deg,var(--soft),var(--pale));"></div>
        {%- endif -%}
      </div>
      <div class="image-with-text__copy">
        {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        <h2>{{ section.settings.heading }}</h2>
        <div class="rte">{{ section.settings.text }}</div>
        {%- if section.settings.cta_text != blank -%}
          <a href="{{ section.settings.cta_url | default: '#' }}" class="btn" style="margin-top: 18px;">{{ section.settings.cta_text }}</a>
        {%- endif -%}
        {%- if section.settings.show_info -%}
          <div class="about-info-grid">
            <div>
              <h4>{{ section.settings.info1_title }}</h4>
              <p>{{ section.settings.info1_text }}</p>
              {%- if section.settings.info1_link_text != blank -%}<p><a href="{{ section.settings.info1_link_url | default: '#' }}" class="btn--ghost">{{ section.settings.info1_link_text }} →</a></p>{%- endif -%}
            </div>
            <div>
              <h4>{{ section.settings.info2_title }}</h4>
              {%- assign rows = section.settings.info2_text | newline_to_br | split: '<br />' -%}
              {%- for row in rows -%}
                {%- assign parts = row | split: '|' -%}
                {%- if parts.size == 2 -%}
                  <div class="hours-row"><span>{{ parts[0] | strip }}</span><span>{{ parts[1] | strip }}</span></div>
                {%- elsif parts[0] != blank -%}
                  <p>{{ parts[0] | strip }}</p>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "About feature",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "select", "id": "image_side", "label": "Image side", "options": [
      {"value":"left","label":"Left"},{"value":"right","label":"Right"}
    ], "default": "left" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "About Hush Hush Tan" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Everyone will notice. No one will know." },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Our masterful airbrush technique uses natural, eco-certified DHA formulas that are cruelty-free, paraben-free, and alcohol-free. The result is a flawless, customizable glow that looks like it's truly yours.</p>" },
    { "type": "text", "id": "cta_text", "label": "CTA text" },
    { "type": "url", "id": "cta_url", "label": "CTA URL" },
    { "type": "checkbox", "id": "show_info", "label": "Show info grid below text", "default": false },
    { "type": "text", "id": "info1_title", "label": "Info 1 title", "default": "Message" },
    { "type": "textarea", "id": "info1_text", "label": "Info 1 text", "default": "Send us a text & an ambassador will respond when available." },
    { "type": "text", "id": "info1_link_text", "label": "Info 1 link text", "default": "1-512-482-8339" },
    { "type": "url", "id": "info1_link_url", "label": "Info 1 link URL" },
    { "type": "text", "id": "info2_title", "label": "Info 2 title", "default": "Store Hours" },
    { "type": "textarea", "id": "info2_text", "label": "Info 2 text (Day | Time per line)", "default": "Mon – Fri:|10:00 – 21:00\nSat & Sun:|10:00 – 17:00" }
  ],
  "presets": [{ "name": "About feature" }]
}
{% endschema %}
