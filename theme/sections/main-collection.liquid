<div class="container">
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="{{ routes.root_url }}">Home</a><span class="breadcrumb__sep">/</span>
    <span aria-current="page">{{ collection.title }}</span>
  </nav>

  <header class="collection-header">
    <h1 class="mb-0">{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <div class="collection-header__sub">{{ collection.description }}</div>
    {%- endif -%}
  </header>

  {%- paginate collection.products by 24 -%}
    <div class="collection-layout">
      <aside class="collection-sidebar" aria-label="Filters">
        <details class="mobile-filter-toggle">
          <summary>Filter products</summary>
          <div class="mobile-filter-toggle__body">
        {%- if collection.filters.size > 0 -%}
          <form method="get" class="facet-form">
            {%- if collection.sort_by != blank -%}<input type="hidden" name="sort_by" value="{{ collection.sort_by }}">{%- endif -%}
            {%- for filter in collection.filters -%}
              <div class="collection-sidebar__group">
                <h3>{{ filter.label }}</h3>
                {%- case filter.type -%}
                  {%- when 'price_range' -%}
                    <div class="facet-price">
                      <input name="{{ filter.min_value.param_name }}" type="number" placeholder="Min" min="0" value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}">
                      <input name="{{ filter.max_value.param_name }}" type="number" placeholder="Max" min="0" value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}">
                    </div>
                  {%- else -%}
                    {%- for value in filter.values -%}
                      <label class="{% if value.count == 0 and value.active == false %}is-disabled{% endif %}">
                        <input type="checkbox" name="{{ value.param_name }}" value="{{ value.value }}" {% if value.active %}checked{% endif %} {% if value.count == 0 and value.active == false %}disabled{% endif %} onchange="this.form.submit()">
                        <span>{{ value.label }} ({{ value.count }})</span>
                      </label>
                    {%- endfor -%}
                {%- endcase -%}
              </div>
            {%- endfor -%}
            <button type="submit" class="btn btn--outline btn--small btn--block">Apply filters</button>
            {%- if collection.current_vendor or collection.current_type or collection.filters.size > 0 -%}
              <a href="{{ collection.url }}" class="btn--ghost" style="margin-top: 14px;">Clear filters</a>
            {%- endif -%}
          </form>
        {%- else -%}
          <div class="collection-sidebar__group">
            <h3>Availability</h3>
            <label><input type="checkbox" checked disabled> In stock ({{ collection.products_count }})</label>
          </div>
        {%- endif -%}
          </div>
        </details>
      </aside>

      <div>
        <div class="collection-toolbar">
          <div class="collection-toolbar__count">We found <strong>{{ collection.products_count }}</strong> products available for you.</div>
          <form method="get" id="SortForm" class="collection-sort">
            {%- for filter in collection.filters -%}
              {%- for value in filter.active_values -%}
                <input type="hidden" name="{{ value.param_name }}" value="{{ value.value }}">
              {%- endfor -%}
              {%- if filter.type == 'price_range' -%}
                {%- if filter.min_value.value -%}<input type="hidden" name="{{ filter.min_value.param_name }}" value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}">{%- endif -%}
                {%- if filter.max_value.value -%}<input type="hidden" name="{{ filter.max_value.param_name }}" value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}">{%- endif -%}
              {%- endif -%}
            {%- endfor -%}
            <select name="sort_by" onchange="this.form.submit()">
              {%- assign current_sort = collection.sort_by | default: collection.default_sort_by -%}
              {%- for option in collection.sort_options -%}
                <option value="{{ option.value }}" {% if option.value == current_sort %}selected{% endif %}>{{ option.name }}</option>
              {%- endfor -%}
            </select>
          </form>
        </div>

        {%- if collection.products.size > 0 -%}
          <div class="collection-grid">
            {%- for product in collection.products -%}
              {% render 'product-card', product: product %}
            {%- endfor -%}
          </div>
        {%- else -%}
          <p class="text-center muted" style="padding: 60px 0;">No products found in this collection.</p>
        {%- endif -%}

        <div class="text-center" style="margin-top: 56px;">{% render 'pagination', paginate: paginate %}</div>
      </div>
    </div>
  {%- endpaginate -%}
</div>

{% schema %}
{
  "name": "Collection",
  "settings": [
    { "type": "checkbox", "id": "show_color_swatches", "label": "Show color swatches in filters", "default": true }
  ]
}
{% endschema %}
